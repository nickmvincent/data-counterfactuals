---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import { courseModules, paperTrail } from "../lib/learning-content.js";

const practicePaths = [
  {
    label: "Turn a question into a study brief",
    body: "Specify the intervention, reference world, outcome, methods, evidence checks, and caveats.",
    href: "/frame",
  },
  {
    label: "Compare all worked cases",
    body: "Training, evaluation, governance, deletion, privacy, and adversarial worlds use the same checklist differently.",
    href: "/examples",
  },
  {
    label: "Open the advanced sandbox",
    body: "Use the full grid and graph controls after the comparison and method family are clear.",
    href: "/labs",
  },
];

const learningChecks = [
  "Name the two worlds being compared.",
  "Identify what changed and what stayed fixed.",
  "Choose an evidence standard that matches the claim.",
  "State one tempting conclusion the comparison cannot support.",
];
---

<Layout
  title="Learn"
  description="A guided learning path from nearby data worlds to methods, evidence, privacy, evaluation, and institutions."
>
  <style>
    .learn-page {
      display: grid;
      gap: clamp(3rem, 6vw, 5.8rem);
      padding-top: clamp(2rem, 4vw, 3.8rem);
    }

    .learn-hero {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 0.42fr);
      gap: clamp(1.8rem, 5vw, 5rem);
      align-items: end;
      margin: 0;
    }

    .learn-title {
      max-width: 12ch;
      font-size: clamp(2.8rem, 5.6vw, 4.9rem);
      letter-spacing: -0.025em;
    }

    .learn-start {
      display: grid;
      gap: 0.7rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border-strong);
    }

    .learn-kicker,
    .learn-module-number,
    .learn-module-status,
    .learn-section-kicker {
      margin: 0;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.055em;
      text-transform: uppercase;
    }

    .learn-start h2 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.7rem, 3vw, 2.5rem);
      line-height: 1.02;
    }

    .learn-start p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }

    .learn-map {
      display: grid;
      gap: 1.3rem;
    }

    .learn-section-title {
      max-width: 15ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.015em;
    }

    .learn-map-intro {
      display: grid;
      gap: 0.65rem;
      max-width: 46rem;
    }

    .learn-map-intro p:last-child {
      margin: 0;
      color: var(--muted);
      line-height: 1.75;
    }

    .learn-module-list {
      position: relative;
      display: grid;
      margin: 0;
      padding: 0;
      border-top: 1px solid var(--border-strong);
      list-style: none;
    }

    .learn-module-link {
      display: grid;
      grid-template-columns: 3.4rem minmax(12rem, 0.56fr) minmax(0, 1.44fr) auto;
      gap: clamp(0.8rem, 2vw, 1.6rem);
      align-items: start;
      padding: clamp(1rem, 2.3vw, 1.55rem) 0;
      border-bottom: 1px solid var(--border);
      color: inherit;
      text-decoration: none;
    }

    .learn-module-number {
      width: 2.25rem;
      height: 2.25rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(47, 107, 111, 0.32);
      border-radius: 50%;
      background: #f7f1e8;
      color: var(--ring-thin);
    }

    .learn-module-summary {
      display: grid;
      gap: 0.45rem;
    }

    .learn-module-link h3 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.35rem, 2.2vw, 1.9rem);
      line-height: 1.06;
    }

    .learn-module-link p,
    .learn-module-facts dd {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .learn-module-facts {
      display: grid;
      gap: 0.45rem;
      margin: 0;
    }

    .learn-module-facts > div {
      display: grid;
      grid-template-columns: 4.4rem minmax(0, 1fr);
      gap: 0.7rem;
    }

    .learn-module-facts dt {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.74rem;
      font-weight: 700;
    }

    .learn-module-facts dd {
      font-size: 0.9rem;
    }

    .learn-module-end {
      display: grid;
      justify-items: end;
      gap: 0.45rem;
      min-width: 9rem;
      text-align: right;
    }

    .learn-module-cta {
      color: var(--ring-thick);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: 700;
    }

    .learn-module-link:hover h3,
    .learn-module-link:focus-visible h3,
    .learn-practice-link:hover h3,
    .learn-practice-link:focus-visible h3,
    .learn-paper-link:hover strong,
    .learn-paper-link:focus-visible strong {
      color: var(--ring-thick);
    }

    .learn-module-link:focus-visible,
    .learn-practice-link:focus-visible,
    .learn-paper-link:focus-visible {
      outline: var(--focus-outline);
      outline-offset: 4px;
    }

    .learn-practice {
      display: grid;
      grid-template-columns: minmax(16rem, 0.54fr) minmax(0, 1.46fr);
      gap: clamp(1.5rem, 5vw, 5rem);
      padding-top: 1.3rem;
      border-top: 1px solid var(--border);
    }

    .learn-checks {
      margin: 1.1rem 0 0;
      padding-left: 1.15rem;
      color: var(--muted);
      line-height: 1.7;
    }

    .learn-checks li {
      margin-bottom: 0.45rem;
    }

    .learn-practice-list {
      display: grid;
      margin: 0;
      padding: 0;
      border-top: 1px solid var(--border);
      list-style: none;
    }

    .learn-practice-list li {
      border-bottom: 1px solid var(--border);
    }

    .learn-practice-link {
      display: grid;
      gap: 0.35rem;
      padding: 1rem 0;
      color: inherit;
      text-decoration: none;
    }

    .learn-practice-link h3 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.3rem, 2vw, 1.75rem);
      line-height: 1.08;
    }

    .learn-practice-link p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .learn-readings {
      display: grid;
      gap: 1.2rem;
    }

    .learn-paper-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--border);
      background: var(--border);
    }

    .learn-paper-link {
      min-height: 13rem;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      padding: 1rem;
      background: #f7f1e8;
      color: inherit;
      text-decoration: none;
    }

    .learn-paper-link strong {
      font-family: var(--font-display);
      font-size: 1.35rem;
      line-height: 1.08;
    }

    .learn-paper-link span {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.86rem;
      line-height: 1.6;
    }

    .learn-paper-link em {
      margin-top: auto;
      color: var(--ring-thick);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-style: normal;
      font-weight: 700;
    }

    @media (max-width: 900px) {
      .learn-hero,
      .learn-practice {
        grid-template-columns: 1fr;
      }

      .learn-module-link {
        grid-template-columns: 2.6rem minmax(0, 1fr);
      }

      .learn-module-facts,
      .learn-module-end {
        grid-column: 2;
      }

      .learn-module-end {
        justify-items: start;
        text-align: left;
      }

      .learn-paper-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 560px) {
      .learn-paper-grid {
        grid-template-columns: 1fr;
      }

      .learn-paper-link {
        min-height: 0;
      }
    }
  </style>

  <Nav />

  <main class="page learn-page" id="main-content" tabindex="-1">
    <header class="page-header learn-hero">
      <div>
        <p class="learn-kicker">Learning path</p>
        <h1 class="page-title learn-title">Learn to compare data worlds.</h1>
        <p class="page-lede">
          Begin with two nearby worlds. Then learn how different fields define the intervention,
          evidence, aggregation rule, observer, reference standard, and claim boundary.
        </p>
      </div>

      <aside class="learn-start" aria-label="Recommended starting point">
        <p class="learn-section-kicker">Recommended start · 5 minutes</p>
        <h2>Name the two worlds.</h2>
        <p>
          Read the visual primer, write down what changed and what stayed fixed, then state one
          conclusion the comparison would not support.
        </p>
        <div class="action-row">
          <a class="btn" href="/story">Start the primer</a>
          <a class="btn ghost" href="/examples">See an example</a>
        </div>
      </aside>
    </header>

    <section class="learn-map" aria-labelledby="learn-map-title">
      <div class="learn-map-intro">
        <p class="learn-section-kicker">Six-part route</p>
        <h2 class="learn-section-title" id="learn-map-title">From one contrast to the neighboring fields.</h2>
        <p>
          Each module has a goal, a concrete output, and a check. The linked pages now carry the
          previous and next steps so the route works as a course rather than a reading list.
        </p>
      </div>

      <ol class="learn-module-list">
        {courseModules.map((module) => (
          <li>
            <a class="learn-module-link" href={module.href}>
              <span class="learn-module-number">{module.id}</span>
              <div class="learn-module-summary">
                <h3>{module.title}</h3>
                <p>{module.body}</p>
              </div>
              <dl class="learn-module-facts">
                <div><dt>Goal</dt><dd>{module.objective}</dd></div>
                <div><dt>Output</dt><dd>{module.deliverable}</dd></div>
                <div><dt>Check</dt><dd>{module.exercise}</dd></div>
              </dl>
              <span class="learn-module-end">
                <span class="learn-module-status">{module.status} · {module.time}</span>
                <span class="learn-module-cta">{module.cta} →</span>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section class="learn-practice" id="course-complete" aria-labelledby="learn-practice-title">
      <div>
        <p class="learn-section-kicker">Practice the reasoning pattern</p>
        <h2 class="learn-section-title" id="learn-practice-title">Four checks, every time.</h2>
        <ol class="learn-checks">
          {learningChecks.map((check) => <li>{check}</li>)}
        </ol>
      </div>

      <ul class="learn-practice-list">
        {practicePaths.map((path) => (
          <li>
            <a class="learn-practice-link" href={path.href}>
              <h3>{path.label}</h3>
              <p>{path.body}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="learn-readings" aria-labelledby="learn-readings-title">
      <div>
        <p class="learn-section-kicker">A short paper trail</p>
        <h2 class="learn-section-title" id="learn-readings-title">Branch into the primary sources.</h2>
      </div>

      <div class="learn-paper-grid">
        {paperTrail.map((paper) => (
          <a class="learn-paper-link" href={paper.href} target="_blank" rel="noreferrer noopener">
            <strong>{paper.title}</strong>
            <span>{paper.body}</span>
            <em>Open primary source ↗</em>
          </a>
        ))}
      </div>

      <div class="action-row">
        <a class="btn ghost" href="/collections">Search the full paper collection</a>
        <a class="btn ghost" href="/teach">Use the teaching paths</a>
      </div>
    </section>
  </main>
</Layout>
