---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import NetworkDiscussions from "../../helpers/astro/NetworkDiscussions.astro";
import type { NetworkData } from "../../helpers/network-data";
import networkData from "../data/network.json";
import { getRequiredPageEntry, renderMarkdownBlocks } from "../lib/page-content";

const page = await getRequiredPageEntry("discussions");
const headerNote = page.data.notes?.header;
const discussions = networkData.discussions ?? [];
const updatedAt = networkData.generatedAt ? new Date(networkData.generatedAt) : null;
const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style>
    .discussion-page {
      gap: 2.6rem;
    }
    .discussion-page .page-header {
      margin-bottom: 0;
    }
    .discussion-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 2vw, 2rem);
      letter-spacing: -0.03em;
    }
  </style>

  <Nav />

  <main class="page essay-page discussion-page" id="main-content" tabindex="-1">
    <header class="essay-header page-header">
      <div>
        {page.data.eyebrow && <span class="page-eyebrow">{page.data.eyebrow}</span>}
        <h1 class="page-title">{page.data.title}</h1>
        {page.data.lede && <p class="page-lede">{page.data.lede}</p>}
        <div class="page-meta">
          <span class="pill">{discussions.length} discussion venues</span>
          {updatedAt && <span class="pill">Updated {dateFormatter.format(updatedAt)}</span>}
        </div>
      </div>

      <aside class="essay-side">
        {headerNote?.label && <p class="note-label">{headerNote.label}</p>}
        {renderMarkdownBlocks(headerNote?.body ?? []).map((html) => (
          <div set:html={html}></div>
        ))}
      </aside>
    </header>

    <section class="section-card">
      <NetworkDiscussions
        networkData={networkData as NetworkData}
        backLinkHref="/"
        backLinkLabel="Back to overview"
        hideProjectLinks={true}
        hideRelatedProjects={true}
        hideGeneratedAt={true}
        classes={{
          container: "discussion-helper",
          title: "discussion-title",
        }}
        styles={{
          container: "max-width:none; margin:0; padding:0;",
          header: "margin-bottom:1.5rem;",
          subtitle: "color:var(--muted); margin-bottom:1rem; line-height:1.75;",
          backLink: "color:var(--ring-thick); font-weight:700;",
          section: "background:rgba(255, 250, 243, 0.62); border:1px solid var(--border); border-radius:22px; padding:1.2rem; margin-bottom:1rem;",
          list: "list-style:none; padding:0; margin:0;",
          discussionListItem: "margin-bottom:0.85rem;",
          listItem: "margin-bottom:0.5rem;",
          description: "color:var(--muted); display:block; font-size:0.95rem; margin-top:0.25rem; line-height:1.65;",
          muted: "color:var(--muted); font-size:0.92rem;",
          emptySection: "background:rgba(255, 250, 243, 0.62); border:1px solid var(--border); border-radius:22px; padding:1.2rem;",
        }}
      />
    </section>
  </main>
</Layout>
