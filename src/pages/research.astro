---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import {
  evidenceReuseRows,
  resolveSources,
  strategicLeverageSteps,
} from "../lib/research-content.js";

const synthesisSources = resolveSources([
  "koh2017",
  "ghorbani2019",
  "dwork2006",
  "guo2020",
  "hardt2023",
  "mitchell2019",
]);

const claimLevels = [
  {
    label: "Descriptive",
    title: "A shared comparative scaffold",
    body: "Several fields compare outcomes across changed datasets, evaluation samples, releases, or access regimes.",
  },
  {
    label: "Analytical",
    title: "The comparison exposes the differences",
    body: "Intervention, estimand, observer, aggregation, reference standard, and evidence requirements explain why the answers diverge.",
  },
  {
    label: "Practical",
    title: "One experiment can support several estimates",
    body: "Matched subset experiments can support specific analyses when they contain the required coalitions, references, and uncertainty estimates.",
  },
  {
    label: "Generative",
    title: "The map exposes open questions",
    body: "Role-specific data value, evaluation-side value, and the path from technical dependence to institutional power remain active project questions.",
  },
];

const crosswalk = [
  {
    field: "Influence and attribution",
    change: "Infinitesimally reweight an example; validate against removal where relevant",
    compares: "Prediction, loss, or fitted behavior",
    extra: "Objective, differentiability regime, local approximation, and retraining validation",
    claim: "An estimated local change under the specified approximation",
    href: "/methods#influence",
  },
  {
    field: "Shapley-style valuation",
    change: "Add a data unit across many coalitions",
    compares: "Task utility across subset worlds",
    extra: "Player set, characteristic function, allocation rule, and approximation scheme",
    claim: "An allocation under the specified cooperative-game value—not price or entitlement",
    href: "/methods#semivalues",
  },
  {
    field: "Same-target evaluation",
    change: "Add or replace observations for the same construct and population",
    compares: "Estimate, calibration, or uncertainty for a fixed target",
    extra: "Sampling frame, dependence assumptions, metric, and uncertainty analysis",
    claim: "A more or less informative estimate of the same target",
    href: "/methods#evaluation",
  },
  {
    field: "Target or slice evaluation",
    change: "Change the population, capability, subgroup, stress condition, or construct",
    compares: "Fixed-model behavior on a newly defined target",
    extra: "Target definition, construct validity, sampling frame, and metric",
    claim: "Performance on the new target—not a refinement of the old estimate",
    href: "/methods#evaluation",
  },
  {
    field: "Decision information",
    change: "Reveal independent evidence before selection, deployment, or audit action",
    compares: "Expected decision loss or probability of a decision change",
    extra: "Decision rule, loss function, prior information, and evidence independence",
    claim: "Value of information for the stated decision",
    href: "/methods#evaluation",
  },
  {
    field: "Differential privacy",
    change: "Move between adjacent input datasets",
    compares: "Distributions of released outputs",
    extra: "Randomized mechanism, adjacency, and worst-case quantification",
    claim: "Bounded distinguishability under the formal mechanism",
    href: "/methods#privacy",
  },
  {
    field: "Machine unlearning",
    change: "Remove requested data from a trained system",
    compares: "Unlearned output with a retraining reference",
    extra: "Deletion request, retained-data reference, and audit criterion",
    claim: "Closeness or certification relative to the reference",
    href: "/methods#unlearning",
  },
  {
    field: "Collective action",
    change: "Withhold, redirect, or condition access to a source",
    compares: "Operator and participant payoffs under a stated strategic model",
    extra: "Control, outside options, participation, timing, strategies, information, and equilibrium concept",
    claim: "A contingent leverage or welfare conclusion—not one implied by technical dependence",
    href: "/methods#collective-action",
  },
];

const bridgeStudies = [
  {
    label: "Bridge study 01",
    title: "Same training worlds, different estimands",
    body: "Use one bank of subset experiments to compare ablation, influence, Shapley-style aggregation, and subset-response curves—then mark where the interpretations stop being interchangeable.",
    href: "/methods",
    cta: "Compare method families",
  },
  {
    label: "Bridge study 02",
    title: "Same data object, different role",
    body: "Treat one source as trainable, evaluable, reserved, contaminated, or unavailable and separate training-side, evaluation-side, and trust-side value.",
    href: "/memo/evaluation-counterfactuals",
    cta: "Read When the Column Changes",
  },
  {
    label: "Bridge study 03",
    title: "From technical dependence to institutional power",
    body: "Begin with a group-ablation result, then add substitution, coordination, rights, timing, and institutional response before making a leverage claim.",
    href: "/examples#collective-withholding",
    cta: "Open the worked case",
  },
];
---

<Layout
  title="Research"
  description="A cross-field research map for comparing interventions, estimands, observers, reference standards, and evidence across data worlds."
>
  <style>
    .research-page {
      display: grid;
      gap: clamp(3.2rem, 6vw, 6rem);
      padding-top: clamp(2rem, 4vw, 3.8rem);
    }

    .research-hero {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 0.42fr);
      gap: clamp(1.8rem, 5vw, 5rem);
      align-items: end;
      margin: 0;
    }

    .research-title {
      max-width: 12ch;
      font-size: clamp(2.8rem, 5.6vw, 4.9rem);
      letter-spacing: -0.025em;
    }

    .research-note {
      margin: 0;
      padding-top: 1rem;
      border-top: 1px solid var(--border-strong);
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.91rem;
      line-height: 1.72;
    }

    .research-kicker,
    .research-section-kicker,
    .research-level-label,
    .research-bridge-label,
    .research-status {
      margin: 0;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.055em;
      text-transform: uppercase;
    }

    .research-section-title {
      max-width: 15ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.6rem);
      line-height: 1;
      letter-spacing: -0.015em;
    }

    .research-section-copy {
      max-width: 42rem;
      margin: 0;
      color: var(--muted);
      font-size: 1.04rem;
      line-height: 1.8;
    }

    .research-claims {
      display: grid;
      gap: 1.3rem;
    }

    .research-claim-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--border);
      background: var(--border);
    }

    .research-level {
      min-height: 18rem;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      padding: clamp(1rem, 2vw, 1.35rem);
      background: #f7f1e8;
    }

    .research-level h3 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 2.2vw, 1.9rem);
      line-height: 1.05;
    }

    .research-level p:last-child {
      margin: 0;
      color: var(--muted);
      line-height: 1.68;
    }

    .research-crosswalk {
      display: grid;
      gap: 1.2rem;
      padding-top: 1.3rem;
      border-top: 1px solid var(--border);
    }

    .research-crosswalk-head {
      display: grid;
      grid-template-columns: minmax(16rem, 0.58fr) minmax(0, 1.42fr);
      gap: clamp(1.5rem, 5vw, 5rem);
      align-items: end;
    }

    .research-crosswalk-wrap {
      min-width: 0;
      overflow-x: auto;
      border-top: 1px solid var(--border-strong);
    }

    .research-table {
      width: 100%;
      min-width: 68rem;
      border-collapse: collapse;
    }

    .research-table th,
    .research-table td {
      padding: 0.85rem 0.75rem;
      border-bottom: 1px solid var(--border);
      text-align: left;
      vertical-align: top;
    }

    .research-table th {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.75rem;
      line-height: 1.4;
    }

    .research-table td {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.55;
    }

    .research-table a {
      color: var(--fg);
      font-family: var(--font-display);
      font-size: 1.05rem;
      font-weight: 700;
      line-height: 1.2;
      text-decoration: none;
    }

    .research-table a:hover,
    .research-table a:focus-visible {
      color: var(--ring-thick);
    }

    .research-table a:focus-visible {
      outline: var(--focus-outline);
      outline-offset: 3px;
    }

    .research-crosswalk-cards {
      display: none;
    }

    .research-reuse,
    .research-strategy {
      display: grid;
      gap: 1.25rem;
      padding-top: 1.3rem;
      border-top: 1px solid var(--border);
    }

    .research-reuse-head,
    .research-strategy-head {
      display: grid;
      grid-template-columns: minmax(16rem, 0.58fr) minmax(0, 1.42fr);
      gap: clamp(1.5rem, 5vw, 5rem);
      align-items: end;
    }

    .research-reuse-list,
    .research-strategy-list {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .research-reuse-list {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--border);
      background: var(--border);
    }

    .research-reuse-list li {
      display: grid;
      align-content: start;
      gap: 0.55rem;
      min-height: 15rem;
      padding: 1rem;
      background: #f7f1e8;
    }

    .research-reuse-list strong,
    .research-strategy-list h3 {
      font-family: var(--font-display);
      line-height: 1.1;
    }

    .research-reuse-list strong {
      font-size: 1.15rem;
    }

    .research-reuse-support {
      color: var(--ring-thin);
      font: 700 0.75rem/1.4 var(--font-ui);
      letter-spacing: 0.045em;
      text-transform: uppercase;
    }

    .research-reuse-list span:last-child {
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.6;
    }

    .research-strategy-list {
      display: grid;
      border-top: 1px solid var(--border-strong);
    }

    .research-strategy-list li {
      display: grid;
      grid-template-columns: 3rem minmax(12rem, 0.62fr) repeat(3, minmax(0, 1fr));
      gap: clamp(0.75rem, 2vw, 1.35rem);
      padding: 1rem 0;
      border-bottom: 1px solid var(--border);
      align-items: start;
    }

    .research-strategy-list h3,
    .research-strategy-list p {
      margin: 0;
    }

    .research-strategy-list h3 {
      font-size: clamp(1.25rem, 2vw, 1.65rem);
    }

    .research-strategy-list p {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .research-strategy-list p strong {
      display: block;
      margin-bottom: 0.18rem;
      font-family: var(--font-ui);
      font-size: 0.74rem;
    }

    .research-bridges {
      display: grid;
      gap: 1.2rem;
    }

    .research-bridge-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--border);
      background: var(--border);
    }

    .research-bridge {
      min-height: 20rem;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      padding: clamp(1rem, 2.2vw, 1.45rem);
      background: #f7f1e8;
      color: inherit;
      text-decoration: none;
    }

    .research-bridge h3 {
      max-width: 14ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.55rem, 2.6vw, 2.2rem);
      line-height: 1.04;
    }

    .research-bridge p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }

    .research-bridge-cta {
      margin-top: auto;
      color: var(--ring-thick);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: 700;
    }

    .research-bridge:hover h3,
    .research-bridge:focus-visible h3 {
      color: var(--ring-thick);
    }

    .research-bridge:focus-visible {
      outline: var(--focus-outline);
      outline-offset: 4px;
    }

    .research-evidence {
      display: grid;
      grid-template-columns: minmax(16rem, 0.55fr) minmax(0, 1.45fr);
      gap: clamp(1.5rem, 5vw, 5rem);
      padding: 1.3rem 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .research-status-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .research-status-list li {
      padding-top: 0.7rem;
      border-top: 1px solid var(--border);
    }

    .research-status-list strong {
      display: block;
      margin-top: 0.25rem;
      font-family: var(--font-display);
      font-size: 1.22rem;
      line-height: 1.2;
    }

    .research-status-list span:last-child {
      display: block;
      margin-top: 0.35rem;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.86rem;
      line-height: 1.6;
    }

    .research-sources {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 0.9rem;
      margin: 1rem 0 0;
      padding: 0;
      list-style: none;
    }

    .research-sources a {
      color: var(--fg);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: 600;
    }

    @media (max-width: 940px) {
      .research-hero,
      .research-crosswalk-head,
      .research-reuse-head,
      .research-strategy-head,
      .research-evidence {
        grid-template-columns: 1fr;
      }

      .research-claim-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .research-bridge-grid {
        grid-template-columns: 1fr;
      }

      .research-bridge {
        min-height: 0;
      }

      .research-reuse-list {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .research-reuse-list li {
        min-height: 0;
      }

      .research-strategy-list li {
        grid-template-columns: 2.6rem minmax(0, 1fr);
      }

      .research-strategy-list li > p {
        grid-column: 2;
      }
    }

    @media (max-width: 700px) {
      .research-crosswalk-wrap {
        display: none;
      }

      .research-crosswalk-cards {
        display: grid;
        gap: 0.8rem;
      }

      .research-crosswalk-card {
        display: grid;
        gap: 0.8rem;
        padding: 1rem;
        border: 1px solid var(--border);
        background: rgba(255, 250, 243, 0.52);
      }

      .research-crosswalk-card h3 {
        margin: 0;
        font-family: var(--font-display);
        font-size: 1.45rem;
        line-height: 1.08;
      }

      .research-crosswalk-card h3 a {
        color: var(--fg);
        text-decoration: none;
      }

      .research-crosswalk-card dl {
        display: grid;
        gap: 0.6rem;
        margin: 0;
      }

      .research-crosswalk-card dl > div {
        display: grid;
        gap: 0.12rem;
        padding-top: 0.55rem;
        border-top: 1px solid var(--border);
      }

      .research-crosswalk-card dt {
        color: var(--muted);
        font: 700 0.74rem/1.4 var(--font-ui);
      }

      .research-crosswalk-card dd {
        margin: 0;
        color: var(--muted);
        line-height: 1.55;
      }

      .research-claim-grid,
      .research-status-list,
      .research-reuse-list {
        grid-template-columns: 1fr;
      }

      .research-level {
        min-height: 0;
      }
    }
  </style>

  <Nav />

  <main class="page research-page" id="main-content" tabindex="-1">
    <header class="page-header research-hero">
      <div>
        <p class="research-kicker">Cross-field research map</p>
        <h1 class="page-title research-title">Same scaffold. Different estimands.</h1>
        <p class="page-lede">
          Data attribution, valuation, evaluation, privacy, unlearning, and collective action all
          compare nearby worlds. They do not estimate the same object or support the same claim.
        </p>
      </div>

      <p class="research-note">
        These fields share a comparison pattern. They do not share an estimand or guarantee.
      </p>
    </header>

    <section class="research-crosswalk" aria-labelledby="research-crosswalk-title">
      <div class="research-crosswalk-head">
        <div>
          <p class="research-section-kicker">Cross-field comparison</p>
          <h2 class="research-section-title" id="research-crosswalk-title">Line up the reference worlds.</h2>
        </div>
        <p class="research-section-copy">
          The first column names the family resemblance. The remaining columns show why the same
          neighboring-world language does not imply the same estimand, guarantee, or institutional conclusion.
        </p>
      </div>

      <div class="research-crosswalk-wrap">
        <table class="research-table">
          <thead>
            <tr>
              <th>Field</th>
              <th>World change</th>
              <th>Object compared</th>
              <th>Essential extra structure</th>
              <th>Defensible conclusion</th>
            </tr>
          </thead>
          <tbody>
            {crosswalk.map((row) => (
              <tr>
                <td><a href={row.href}>{row.field}</a></td>
                <td>{row.change}</td>
                <td>{row.compares}</td>
                <td>{row.extra}</td>
                <td>{row.claim}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="research-crosswalk-cards" aria-label="Cross-field comparison cards">
        {crosswalk.map((row) => (
          <article class="research-crosswalk-card">
            <h3><a href={row.href}>{row.field}</a></h3>
            <dl>
              <div>
                <dt>World change</dt>
                <dd>{row.change}</dd>
              </div>
              <div>
                <dt>Object compared</dt>
                <dd>{row.compares}</dd>
              </div>
              <div>
                <dt>Essential extra structure</dt>
                <dd>{row.extra}</dd>
              </div>
              <div>
                <dt>Defensible conclusion</dt>
                <dd>{row.claim}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
    </section>

    <section class="research-claims" aria-labelledby="research-claims-title">
      <div>
        <p class="research-section-kicker">What the comparison reveals</p>
        <h2 class="research-section-title" id="research-claims-title">A ladder of increasingly strong claims.</h2>
      </div>

      <div class="research-claim-grid">
        {claimLevels.map((level) => (
          <article class="research-level">
            <p class="research-level-label">{level.label}</p>
            <h3>{level.title}</h3>
            <p>{level.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="research-reuse" aria-labelledby="research-reuse-title">
      <div class="research-reuse-head">
        <div>
          <p class="research-section-kicker">Evidence reuse</p>
          <h2 class="research-section-title" id="research-reuse-title">Which evidence can travel?</h2>
        </div>
        <p class="research-section-copy">
          A shared experiment does not make the resulting analyses interchangeable. Each method
          needs its own inputs, assumptions, and validation.
        </p>
      </div>

      <ul class="research-reuse-list">
        {evidenceReuseRows.map((row) => (
          <li>
            <strong>{row.analysis}</strong>
            <span class="research-reuse-support">{row.support}</span>
            <span>{row.requirement}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="research-bridges" aria-labelledby="research-bridges-title">
      <div>
        <p class="research-section-kicker">Bridge studies</p>
        <h2 class="research-section-title" id="research-bridges-title">Test whether the connection does useful work.</h2>
      </div>

      <div class="research-bridge-grid">
        {bridgeStudies.map((study) => (
          <a class="research-bridge" href={study.href}>
            <span class="research-bridge-label">{study.label}</span>
            <h3>{study.title}</h3>
            <p>{study.body}</p>
            <span class="research-bridge-cta">{study.cta} →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="research-strategy" aria-labelledby="research-strategy-title">
      <div class="research-strategy-head">
        <div>
          <p class="research-section-kicker">Institutional translation</p>
          <h2 class="research-section-title" id="research-strategy-title">From dependence to strategic leverage.</h2>
        </div>
        <p class="research-section-copy">
          A technical effect is the first input to a leverage argument. The remaining steps require
          evidence about control, alternatives, participation, response, and incidence.
        </p>
      </div>

      <ol class="research-strategy-list">
        {strategicLeverageSteps.map((step) => (
          <li>
            <span class="research-level-label">{step.number}</span>
            <h3>{step.title}</h3>
            <p><strong>Question</strong>{step.question}</p>
            <p><strong>Evidence</strong>{step.evidence}</p>
            <p><strong>Failure condition</strong>{step.failure}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="research-evidence" aria-labelledby="research-evidence-title">
      <div>
        <p class="research-section-kicker">Evidence and status</p>
        <h2 class="research-section-title" id="research-evidence-title">Show the status of each claim.</h2>
        <ul class="research-sources" aria-label="Starting sources">
          {synthesisSources.map((source) => (
            <li><a href={source.href} target="_blank" rel="noreferrer noopener">{source.short} ↗</a></li>
          ))}
        </ul>
      </div>

      <ul class="research-status-list">
        <li>
          <span class="research-status">Reviewed site material</span>
          <strong>Worked cases and method limits</strong>
          <span>Use the case and method pages for the most concise, claim-aware orientation.</span>
        </li>
        <li>
          <span class="research-status">Draft synthesis</span>
          <strong>Formalisms memo</strong>
          <span>The long technical mapping remains explicitly labeled as a draft pending deeper domain-expert review.</span>
        </li>
        <li>
          <span class="research-status">Curated map</span>
          <strong>Primary-source collection</strong>
          <span>The bibliography is a traceable starting shelf, not a systematic review or claim of exhaustive coverage.</span>
        </li>
        <li>
          <span class="research-status">Project questions</span>
          <strong>Evaluation comparisons and institutional translation</strong>
          <span>Three evaluation objects and the dependence-to-leverage chain define the open research program.</span>
        </li>
      </ul>
    </section>

    <div class="action-row">
      <a class="btn" href="/methods">Compare method families</a>
      <a class="btn secondary" href="/collections">Search the papers</a>
      <a class="btn ghost" href="/memo/formalisms">Read the draft formalism</a>
    </div>
  </main>
</Layout>
