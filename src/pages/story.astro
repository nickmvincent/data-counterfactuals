---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import CounterfactualBoard from "../components/CounterfactualBoard.astro";
import {
  pipelineSteps,
  primerBoardBaselines,
  primerBoardColumns,
  primerBoardHighlights,
  primerBoardRows,
  primerScenes,
} from "../lib/learning-content.js";
---

<Layout
  title="Quick Primer"
  description="A short introduction to the data counterfactuals idea."
>
  <style>
    .primer-page {
      display: grid;
      gap: 2.8rem;
    }

    .primer-header {
      max-width: var(--measure);
      margin-bottom: 0;
    }

    .primer-title {
      max-width: 12ch;
    }

    .primer-section {
      display: grid;
      grid-template-columns: minmax(0, var(--measure)) minmax(19rem, 0.72fr);
      gap: clamp(1.3rem, 4vw, 3rem);
      align-items: start;
      padding-top: 1.3rem;
      border-top: 1px solid var(--border);
    }

    .primer-copy {
      max-width: var(--measure);
    }

    .primer-kicker {
      margin: 0 0 0.45rem;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.86rem;
      font-weight: 650;
    }

    .primer-copy h2 {
      margin: 0 0 0.75rem;
      font-family: var(--font-display);
      font-size: clamp(1.65rem, 2.3vw, 2.25rem);
      line-height: 1.06;
      letter-spacing: 0;
    }

    .primer-copy p {
      margin: 0;
      color: var(--muted);
      font-size: clamp(1.05rem, 1.2vw, 1.12rem);
      line-height: 1.88;
    }

    .primer-pipeline {
      display: grid;
      gap: 0.7rem;
      max-width: 48rem;
      padding-top: 1.3rem;
      border-top: 1px solid var(--border);
    }

    .primer-pipeline h2 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.65rem, 2.3vw, 2.25rem);
      line-height: 1.06;
      letter-spacing: 0;
    }

    .primer-pipeline p {
      margin: 0;
      color: var(--muted);
      font-size: clamp(1.05rem, 1.2vw, 1.12rem);
      line-height: 1.85;
    }

    .pipeline-strip {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 2px;
      margin-top: 0.35rem;
    }

    .pipeline-strip span {
      min-height: 3.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.55rem;
      border: 1px solid rgba(92, 72, 52, 0.12);
      background: rgba(95, 132, 91, 0.12);
      color: #26362f;
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: 650;
      line-height: 1.25;
      text-align: center;
    }

    @media (max-width: 880px) {
      .primer-section {
        grid-template-columns: 1fr;
      }

      .pipeline-strip {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <Nav />

  <main class="page primer-page" id="main-content" tabindex="-1">
    <header class="page-header primer-header">
      <h1 class="page-title primer-title">A quick primer on data counterfactuals</h1>
      <p class="page-lede">
        The idea is to compare nearby data worlds. Hold most things still, change one fact about the
        data, and ask how the model, the measurement, or the governance story changes.
      </p>
      <div class="action-row">
        <a class="btn" href="/grid">Open the grid</a>
        <a class="btn ghost" href="/learn">Study further</a>
      </div>
    </header>

    {primerScenes.map((scene) => (
      <section class="primer-section">
        <div class="primer-copy">
          <p class="primer-kicker">{scene.kicker}</p>
          <h2>{scene.title}</h2>
          <p>{scene.body}</p>
        </div>

        <CounterfactualBoard
          ariaLabel={`${scene.kicker} counterfactual board`}
          rows={primerBoardRows}
          columns={primerBoardColumns}
          variant={scene.variant}
          highlights={primerBoardHighlights}
          baselines={primerBoardBaselines}
          caption={scene.caption}
        />
      </section>
    ))}

    <section class="primer-pipeline" aria-labelledby="primer-post-training-title">
      <h2 id="primer-post-training-title">After pretraining, the data path can become a pipeline.</h2>
      <p>
        Human feedback can enter as demonstrations, preferences, critiques, rubrics, red-team traces,
        or deployment reports. Those signals may train a reward model, steer a policy update, or
        become evidence for an evaluation. That is still a data counterfactual, but it is no longer
        just one grid cell.
      </p>
      <div class="pipeline-strip" aria-label="Simplified post-training pipeline">
        {pipelineSteps.map((step) => <span>{step}</span>)}
      </div>
    </section>
  </main>
</Layout>
