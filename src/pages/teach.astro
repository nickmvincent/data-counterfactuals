---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import { resolveSources } from "../lib/research-content.js";

const lessonSources = resolveSources(["koh2017", "ghorbani2019", "dwork2006", "hardt2023", "mitchell2019", "gebru2021"]);

const teachingPaths = [
  {
    time: "5 minutes",
    title: "Name the two worlds",
    steps: [
      "Read the quick primer’s baseline and row-move sections.",
      "Write one sentence naming what changes and what stays fixed.",
      "State one claim the comparison would not support.",
    ],
    href: "/story",
    cta: "Open the primer",
  },
  {
    time: "50 minutes",
    title: "From grid move to research claim",
    steps: [
      "Choose one case from the examples page.",
      "Use the framing tool to create a working study brief.",
      "Reproduce the comparison in the grid’s guided mode.",
      "Compare the brief with one primary paper and revise the caveat.",
    ],
    href: "/frame",
    cta: "Start the class activity",
  },
  {
    time: "3 sessions",
    title: "Methods, institutions, and evidence",
    steps: [
      "Session 1: ablation, influence, and Shapley-style valuation.",
      "Session 2: evaluation data, privacy, and unlearning references.",
      "Session 3: data leverage, collective action, and the limits of technical dependence estimates.",
      "Finish with a short proposal that separates the technical and institutional claims.",
    ],
    href: "/memo/loose-syllabus",
    cta: "Open the longer syllabus",
  },
];
---

<Layout
  title="Teach"
  description="Short, classroom-length, and multi-session teaching paths for data counterfactuals."
>
  <style>
    .teach-page { display:grid; gap:3rem; padding-top:clamp(2rem,4vw,3.8rem); }
    .teach-header { max-width:52rem; margin:0; }
    .teach-title { font-size:clamp(2.7rem,5.4vw,4.9rem); letter-spacing:-.025em; }
    .teach-paths { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:1px; border:1px solid var(--border); background:var(--border); }
    .teach-path { display:flex; flex-direction:column; gap:1rem; min-height:25rem; padding:clamp(1.1rem,2.4vw,1.7rem); background:#f7f1e8; }
    .teach-time { margin:0; color:var(--ring-thin); font:700 .78rem/1.3 var(--font-ui); letter-spacing:.055em; text-transform:uppercase; }
    .teach-path h2 { max-width:13ch; margin:0; font-family:var(--font-display); font-size:clamp(1.7rem,2.8vw,2.35rem); line-height:1.03; }
    .teach-steps { margin:0; padding-left:1.2rem; color:var(--muted); line-height:1.7; }
    .teach-steps li { margin-bottom:.6rem; }
    .teach-path .btn { align-self:flex-start; margin-top:auto; }
    .teach-principles { display:grid; grid-template-columns:minmax(16rem,.58fr) minmax(0,1.42fr); gap:clamp(1.5rem,5vw,5rem); padding-top:1.3rem; border-top:1px solid var(--border); }
    .teach-principles h2 { max-width:13ch; margin:0; font-family:var(--font-display); font-size:clamp(1.9rem,3.5vw,3.2rem); line-height:1.02; }
    .teach-principle-list { display:grid; gap:0; margin:0; padding:0; list-style:none; border-top:1px solid var(--border); }
    .teach-principle-list li { display:grid; grid-template-columns:2rem minmax(0,1fr); gap:.8rem; padding:.9rem 0; border-bottom:1px solid var(--border); color:var(--muted); line-height:1.65; }
    .teach-principle-list span { color:var(--ring-thick); font:700 .82rem/1.6 var(--font-ui); }
    .teach-sources { display:grid; gap:1rem; padding:1.2rem 0; border-top:1px solid var(--border); border-bottom:1px solid var(--border); }
    .teach-sources h2 { margin:0; font-family:var(--font-ui); font-size:.9rem; }
    .teach-source-list { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:.6rem 1.2rem; margin:0; padding:0; list-style:none; }
    .teach-source-list a { color:var(--fg); font:.86rem/1.5 var(--font-ui); }
    @media (max-width:900px) { .teach-paths, .teach-source-list { grid-template-columns:1fr; } .teach-path { min-height:0; } .teach-principles { grid-template-columns:1fr; } }
  </style>

  <Nav />
  <main class="page teach-page" id="main-content" tabindex="-1">
    <header class="page-header teach-header">
      <h1 class="page-title teach-title">Teach the contrast, not just the vocabulary.</h1>
      <p class="page-lede">
        Each path asks learners to name two data worlds, identify what is held fixed, choose an
        evidence standard, and write down the conclusion the comparison cannot support.
      </p>
    </header>

    <div class="teach-paths">
      {teachingPaths.map((path) => (
        <section class="teach-path">
          <p class="teach-time">{path.time}</p>
          <h2>{path.title}</h2>
          <ol class="teach-steps">
            {path.steps.map((step) => <li>{step}</li>)}
          </ol>
          <a class="btn ghost" href={path.href}>{path.cta}</a>
        </section>
      ))}
    </div>

    <section class="teach-principles" aria-labelledby="teach-principles-title">
      <h2 id="teach-principles-title">Four checks for every activity.</h2>
      <ol class="teach-principle-list">
        <li><span>01</span><div><strong>Intervention:</strong> Which data, role, or access condition changes?</div></li>
        <li><span>02</span><div><strong>Reference world:</strong> What is the comparison baseline?</div></li>
        <li><span>03</span><div><strong>Evidence:</strong> Which metric, population, uncertainty estimate, or institutional fact supports the answer?</div></li>
        <li><span>04</span><div><strong>Boundary:</strong> What tempting causal, privacy, fairness, economic, or governance claim remains unsupported?</div></li>
      </ol>
    </section>

    <section class="teach-sources" aria-labelledby="teach-sources-title">
      <h2 id="teach-sources-title">Primary-source spine</h2>
      <ul class="teach-source-list">
        {lessonSources.map((source) => (
          <li><a href={source.href} target="_blank" rel="noreferrer noopener" title={source.title}>{source.short} — {source.title}</a></li>
        ))}
      </ul>
    </section>
  </main>
</Layout>
