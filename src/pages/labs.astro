---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";

const recommendedRoute = [
  {
    number: "01",
    title: "Choose a worked case",
    body: "Start from a concrete training, evaluation, governance, deletion, privacy, or adversarial question.",
    href: "/examples",
  },
  {
    number: "02",
    title: "Frame the comparison",
    body: "Name the intervention, reference world, outcome, evidence checks, and claim boundary.",
    href: "/frame",
  },
  {
    number: "03",
    title: "Open the instrument",
    body: "Use the advanced grid only after the comparison and method family are clear.",
    href: "/grid",
  },
];

const primaryTools = [
  {
    status: "Worked cases",
    title: "Examples before abstractions",
    body: "Six concrete cases pair a comparison and measurement plan with sources and a do-not-overclaim boundary.",
    href: "/examples",
    cta: "Browse the cases",
  },
  {
    status: "Interactive brief",
    title: "Question framer",
    body: "Turn a data change into a working brief with notation, method families, evidence checks, and caveats.",
    href: "/frame",
    cta: "Frame a study",
  },
  {
    status: "Advanced sandbox",
    title: "Grid and graph explorer",
    body: "Manipulate subset worlds, valuation modes, evaluation columns, uncertainty, deletion references, and adversarial views.",
    href: "/grid",
    cta: "Open the grid",
  },
];

const experimentalTools = [
  {
    label: "Graph explorer",
    status: "Experimental",
    body: "View the same subset worlds as paths, edges, strike trajectories, and valuation sweeps.",
    href: "/graph",
  },
  {
    label: "Post-training feedback",
    status: "Provisional",
    body: "Explore value pathways through demonstrations, preferences, reward modeling, policy updates, and evaluation.",
    href: "/post-training",
  },
  {
    label: "Explorer API",
    status: "Developer tool",
    body: "Inspect grid and graph state through request-and-response style queries.",
    href: "/api-explorer",
  },
  {
    label: "3D viewer",
    status: "Heavy prototype",
    body: "Use the earlier three-dimensional view of the subset space and advanced controls.",
    href: "/advanced.html",
  },
];
---

<Layout
  title="Cases & Labs"
  description="Worked data-counterfactual cases, a question-framing tool, and advanced interactive sandboxes."
>
  <style>
    .labs-page {
      display: grid;
      gap: clamp(3.2rem, 6vw, 5.8rem);
      padding-top: clamp(2rem, 4vw, 3.8rem);
    }

    .labs-hero {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 0.42fr);
      gap: clamp(1.8rem, 5vw, 5rem);
      align-items: end;
      margin: 0;
    }

    .labs-title {
      max-width: 11ch;
      font-size: clamp(2.8rem, 5.6vw, 4.9rem);
      letter-spacing: -0.025em;
    }

    .labs-note {
      margin: 0;
      padding-top: 1rem;
      border-top: 1px solid var(--border-strong);
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.91rem;
      line-height: 1.72;
    }

    .labs-kicker,
    .labs-section-kicker,
    .labs-tool-status,
    .labs-route-number {
      margin: 0;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.055em;
      text-transform: uppercase;
    }

    .labs-section-title {
      max-width: 15ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.6rem);
      line-height: 1;
      letter-spacing: -0.015em;
    }

    .labs-route {
      display: grid;
      grid-template-columns: minmax(16rem, 0.54fr) minmax(0, 1.46fr);
      gap: clamp(1.5rem, 5vw, 5rem);
      padding-top: 1.3rem;
      border-top: 1px solid var(--border);
    }

    .labs-route-copy {
      display: grid;
      align-content: start;
      gap: 0.75rem;
    }

    .labs-route-copy p:last-child {
      margin: 0;
      color: var(--muted);
      line-height: 1.75;
    }

    .labs-route-list {
      display: grid;
      margin: 0;
      padding: 0;
      border-top: 1px solid var(--border);
      list-style: none;
    }

    .labs-route-link {
      display: grid;
      grid-template-columns: 2.8rem minmax(12rem, 0.64fr) minmax(0, 1fr) auto;
      gap: 1rem;
      align-items: start;
      padding: 1rem 0;
      border-bottom: 1px solid var(--border);
      color: inherit;
      text-decoration: none;
    }

    .labs-route-link h3 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.3rem, 2vw, 1.7rem);
      line-height: 1.08;
    }

    .labs-route-link p {
      margin: 0;
      color: var(--muted);
      line-height: 1.62;
    }

    .labs-route-cta,
    .labs-tool-cta {
      color: var(--ring-thick);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .labs-primary,
    .labs-experimental {
      display: grid;
      gap: 1.3rem;
    }

    .labs-tool-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--border);
      background: var(--border);
    }

    .labs-tool {
      min-height: 20rem;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      padding: clamp(1rem, 2.2vw, 1.45rem);
      background: #f7f1e8;
      color: inherit;
      text-decoration: none;
    }

    .labs-tool h3 {
      max-width: 13ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 2.7vw, 2.25rem);
      line-height: 1.04;
    }

    .labs-tool p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }

    .labs-tool-cta {
      margin-top: auto;
    }

    .labs-route-link:hover h3,
    .labs-route-link:focus-visible h3,
    .labs-tool:hover h3,
    .labs-tool:focus-visible h3,
    .labs-experimental-link:hover h3,
    .labs-experimental-link:focus-visible h3 {
      color: var(--ring-thick);
    }

    .labs-route-link:focus-visible,
    .labs-tool:focus-visible,
    .labs-experimental-link:focus-visible {
      outline: var(--focus-outline);
      outline-offset: 4px;
    }

    .labs-experimental-head {
      display: grid;
      grid-template-columns: minmax(15rem, 0.5fr) minmax(0, 1.5fr);
      gap: clamp(1.5rem, 5vw, 5rem);
      align-items: end;
      padding-top: 1.3rem;
      border-top: 1px solid var(--border);
    }

    .labs-experimental-head p:last-child {
      max-width: 42rem;
      margin: 0;
      color: var(--muted);
      line-height: 1.75;
    }

    .labs-experimental-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin: 0;
      padding: 0;
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
      list-style: none;
    }

    .labs-experimental-list li {
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .labs-experimental-link {
      min-height: 11rem;
      display: grid;
      align-content: start;
      gap: 0.55rem;
      padding: 1rem;
      color: inherit;
      text-decoration: none;
    }

    .labs-experimental-link h3 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.3rem, 2vw, 1.75rem);
      line-height: 1.08;
    }

    .labs-experimental-link p {
      margin: 0;
      color: var(--muted);
      line-height: 1.62;
    }

    .labs-boundary {
      margin: 0;
      padding: 1rem 1.1rem;
      border-left: 3px solid rgba(177, 79, 31, 0.4);
      background: rgba(177, 79, 31, 0.06);
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.9rem;
      line-height: 1.65;
    }

    @media (max-width: 900px) {
      .labs-hero,
      .labs-route,
      .labs-experimental-head {
        grid-template-columns: 1fr;
      }

      .labs-tool-grid {
        grid-template-columns: 1fr;
      }

      .labs-tool {
        min-height: 0;
      }
    }

    @media (max-width: 680px) {
      .labs-route-link {
        grid-template-columns: 2.4rem minmax(0, 1fr);
      }

      .labs-route-link > p,
      .labs-route-cta {
        grid-column: 2;
      }

      .labs-experimental-list {
        grid-template-columns: 1fr;
      }

      .labs-experimental-link {
        min-height: 0;
      }
    }
  </style>

  <Nav />

  <main class="page labs-page" id="main-content" tabindex="-1">
    <header class="page-header labs-hero">
      <div>
        <p class="labs-kicker">Cases and instruments</p>
        <h1 class="page-title labs-title">Examples before controls.</h1>
        <p class="page-lede">
          Start from a defensible comparison and evidence plan. Open the advanced instruments only
          after the intervention, reference world, and claim boundary are clear.
        </p>
      </div>

      <p class="labs-note">
        The grid, graph, and post-training views are toy or provisional tools for making assumptions
        visible. Their status is marked before each route.
      </p>
    </header>

    <section class="labs-route" aria-labelledby="labs-route-title">
      <div class="labs-route-copy">
        <p class="labs-section-kicker">Recommended route</p>
        <h2 class="labs-section-title" id="labs-route-title">Question first. Instrument second.</h2>
        <p>
          This sequence keeps the explorer useful without asking a newcomer to interpret every
          mode, metric, and control at once.
        </p>
      </div>

      <ol class="labs-route-list">
        {recommendedRoute.map((step) => (
          <li>
            <a class="labs-route-link" href={step.href}>
              <span class="labs-route-number">{step.number}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
              <span class="labs-route-cta">Open →</span>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section class="labs-primary" aria-labelledby="labs-primary-title">
      <div>
        <p class="labs-section-kicker">Core tools</p>
        <h2 class="labs-section-title" id="labs-primary-title">Move from case to working brief.</h2>
      </div>

      <div class="labs-tool-grid">
        {primaryTools.map((tool) => (
          <a class="labs-tool" href={tool.href}>
            <span class="labs-tool-status">{tool.status}</span>
            <h3>{tool.title}</h3>
            <p>{tool.body}</p>
            <span class="labs-tool-cta">{tool.cta} →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="labs-experimental" aria-labelledby="labs-experimental-title">
      <div class="labs-experimental-head">
        <div>
          <p class="labs-section-kicker">Experimental shelf</p>
          <h2 class="labs-section-title" id="labs-experimental-title">Keep the prototypes, label their status.</h2>
        </div>
        <p>
          These routes remain available for exploration and development. They are intentionally
          separated from the primary learning path so their density and provisional status are clear.
        </p>
      </div>

      <ul class="labs-experimental-list">
        {experimentalTools.map((tool) => (
          <li>
            <a class="labs-experimental-link" href={tool.href}>
              <span class="labs-tool-status">{tool.status}</span>
              <h3>{tool.label}</h3>
              <p>{tool.body}</p>
            </a>
          </li>
        ))}
      </ul>

      <p class="labs-boundary">
        Interpretation rule: every move should name the intervention, reference world, evidence
        standard, and the conclusion the view cannot support. If those are missing, return to the
        worked cases or question framer before reading the result.
      </p>
    </section>
  </main>
</Layout>
