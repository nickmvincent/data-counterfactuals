---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import { marked } from "marked";
import { loadMemos } from "../lib/content-loader";
import networkData from "../data/network.json";

const memos = await loadMemos();
const memo = memos.find((m) => m.slug === "data-counterfactuals") ?? memos[0];
const memoMeta = memo ? { title: memo.title, summary: memo.summary } : { title: "Exploring Data Counterfactuals" };
const memoBody = memo?.body ?? "";
const memoHtml = marked.parse(memoBody);
const githubUrl = networkData.links?.github;
const wordCount = memoBody.split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.round(wordCount / 220));
---

<Layout
  title={memoMeta.title}
  description={memoMeta.summary || "A unifying framework connecting data valuation, scaling laws, data poisoning, and collective action through the lens of data counterfactuals."}
>
  <style>
    .memo-page {
      display: grid;
      gap: 1rem;
    }
    .memo-card {
      padding: clamp(1.2rem, 2.5vw, 2rem);
    }
    .memo-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-top: 1.4rem;
    }
  </style>

  <Nav />

  <main class="page memo-page">
    <header class="page-header">
      <span class="page-eyebrow">Long-form argument</span>
      <h1 class="page-title">{memoMeta.title}</h1>
      {memoMeta.summary && <p class="page-lede">{memoMeta.summary}</p>}
      <div class="page-meta">
        <span class="pill">{readMinutes} minute read</span>
        <span class="pill">{wordCount} words</span>
      </div>
    </header>

    <article class="section-card memo-card">
      <div class="prose" set:html={memoHtml}></div>

      <div class="memo-actions">
        <a href="/grid" class="btn secondary">Try the explorer alongside the memo</a>
        <a href={githubUrl || "#"} target="_blank" rel="noopener" class="btn ghost">View source on GitHub</a>
      </div>
    </article>
  </main>
</Layout>
