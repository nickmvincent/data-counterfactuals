---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import {
  countWords,
  estimateReadMinutes,
  getPublicMemos,
  memoHref,
  numberedMemoTitle,
} from "../lib/memos";

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const memos = (await getPublicMemos()).map((memo) => {
  const wordCount = countWords(memo.body);

  return {
    ...memo,
    numberedTitle: numberedMemoTitle(memo.data.title, memo.data.order),
    wordCount,
    readMinutes: estimateReadMinutes(wordCount),
  };
});
---

<Layout
  title="Memos"
  description="Project memos, drafts, and longer notes from Data Counterfactuals."
>
  <style>
    .memo-index-page {
      display: grid;
      gap: 2rem;
    }
    .memo-index-page .page-header {
      margin-bottom: 0;
    }
    .memo-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0;
    }
    .memo-item {
      padding: 1.5rem 0;
      border-top: 1px solid var(--border);
    }
    .memo-item:first-child {
      padding-top: 0;
      border-top: 0;
    }
    .memo-link {
      display: block;
      color: inherit;
      text-decoration: none;
    }
    .memo-link:hover .memo-title,
    .memo-link:focus-visible .memo-title {
      color: var(--ring-thick);
    }
    .memo-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem 1rem;
      margin-bottom: 0.55rem;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.84rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .memo-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 2.4vw, 2.2rem);
      line-height: 1.08;
      letter-spacing: -0.03em;
      transition: color 160ms ease;
    }
    .memo-summary {
      margin: 0.7rem 0 0;
      max-width: var(--measure);
      color: var(--muted);
      font-size: 1.02rem;
      line-height: 1.8;
    }
  </style>

  <Nav />

  <main class="page memo-index-page">
    <header class="page-header">
      <div>
        <span class="page-eyebrow">Memo archive</span>
        <h1 class="page-title">Memos</h1>
        <div class="page-meta">
          <span class="pill">{memos.length} memos</span>
        </div>
      </div>
    </header>

    {memos.length ? (
      <ul class="memo-list">
        {memos.map((memo) => (
          <li class="memo-item">
            <a href={memoHref(memo.slug)} class="memo-link">
              <div class="memo-meta">
                {memo.data.date && <span>{dateFormatter.format(memo.data.date)}</span>}
                <span>{memo.readMinutes} minute read</span>
                <span>{memo.wordCount} words</span>
              </div>
              <h2 class="memo-title">{memo.numberedTitle}</h2>
              {memo.data.summary && <p class="memo-summary">{memo.data.summary}</p>}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="empty-state">No memos are published yet.</div>
    )}
  </main>
</Layout>
