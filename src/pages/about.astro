---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import networkData from "../data/network.json";

const githubUrl = networkData.links?.github;
const discussions = networkData.discussions ?? [];
const relatedProjects = networkData.relatedProjects ?? [];
---

<Layout
  title="About"
  description="Why Data Counterfactuals exists, what it is trying to do, and how to give feedback or contribute."
>
  <style>
    .about-page {
      display: grid;
      gap: 1rem;
    }
    .about-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.8fr);
      gap: 1rem;
      align-items: start;
    }
    .about-list {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
      display: grid;
      gap: 0.8rem;
    }
    .about-list li,
    .discussion-card,
    .project-card {
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: 20px;
      background: rgba(255, 250, 243, 0.72);
    }
    .about-list li {
      color: var(--muted);
      line-height: 1.7;
    }
    .discussion-list,
    .project-list {
      display: grid;
      gap: 0.8rem;
      margin-top: 1rem;
    }
    .discussion-card h3,
    .project-card h3 {
      margin: 0 0 0.4rem;
      font-size: 1rem;
    }
    .discussion-card p,
    .project-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }
    .sidebar-stack {
      display: grid;
      gap: 1rem;
    }
    @media (max-width: 960px) {
      .about-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <Nav />

  <main class="page about-page">
    <header class="page-header">
      <span class="page-eyebrow">Project notes</span>
      <h1 class="page-title">Why this site exists</h1>
      <p class="page-lede">
        Data Counterfactuals is an attempt to make training-data questions easier to see and easier to talk about.
        The project is part explainer, part toy lab, and part research map.
      </p>
      <div class="page-meta">
        <span class="pill">Work in progress</span>
        <span class="pill">Open source</span>
        <span class="pill">Built as a teaching tool</span>
      </div>
    </header>

    <section class="about-grid">
      <article class="section-card">
        <p class="section-kicker">What the project is trying to do</p>
        <h2 class="section-title">Make training data feel inspectable</h2>
        <div class="section-copy">
          <p>
            A lot of ML writing jumps straight into methods, benchmarks, or theory. That is useful, but it can leave
            people without a clean mental model for the underlying question: what changes when the training data changes?
          </p>
          <p>
            This site uses the phrase <strong>data counterfactuals</strong> and the grid metaphor as teaching tools. They are meant
            to connect several research areas without pretending the literature already uses exactly this framing.
          </p>
        </div>

        <ul class="about-list">
          <li><strong>Explorer:</strong> a toy environment for comparing training subsets, evaluation slices, and simple edits like poisoning or noise.</li>
          <li><strong>Memo:</strong> the longer argument for why this framing is useful and where it helps unify adjacent literatures.</li>
          <li><strong>Reference pages:</strong> paper collections and glossary entries for when you want to move from intuition to sources.</li>
        </ul>
      </article>

      <aside class="sidebar-stack">
        <section class="section-card">
          <p class="section-kicker">Status</p>
          <h2 class="section-title">Still being shaped</h2>
          <div class="section-copy">
            <p>
              The explorer works and the reference pages are already useful, but the site is still evolving. Some explanations
              are intentionally provisional while the framing gets pressure-tested.
            </p>
          </div>
        </section>

        <section class="section-card">
          <p class="section-kicker">Contribute</p>
          <h2 class="section-title">Corrections are welcome</h2>
          <div class="section-copy">
            <p>
              If a concept is misleading, a paper list is missing something obvious, or a UI detail gets in the way, please say so.
              That kind of feedback is exactly what helps this project get sharper.
            </p>
          </div>
          <div class="action-row">
            <a href={githubUrl || "#"} target="_blank" rel="noopener" class="btn">Open GitHub</a>
            <a href="#discussion" class="btn ghost">Jump to discussion links</a>
          </div>
        </section>
      </aside>
    </section>

    <section class="section-card" id="discussion">
      <p class="section-kicker">Talk back</p>
      <h2 class="section-title">Places to ask questions or leave feedback</h2>
      {discussions.length ? (
        <div class="discussion-list">
          {discussions.map((discussion) => (
            <article class="discussion-card">
              <h3>
                <a href={discussion.url} target="_blank" rel="noopener">{discussion.label}</a>
              </h3>
              <p>{discussion.description}</p>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">Discussion links have not been added yet.</div>
      )}
    </section>

    <section class="section-card">
      <p class="section-kicker">Related work</p>
      <h2 class="section-title">Projects nearby</h2>
      {relatedProjects.length ? (
        <div class="project-list">
          {relatedProjects.map((project) => (
            <article class="project-card">
              <h3>
                <a href={project.website} target="_blank" rel="noopener">{project.title}</a>
              </h3>
              <p>{project.name === project.title ? "A neighboring project in the same research orbit." : project.name}</p>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">No related projects have been listed yet.</div>
      )}
    </section>
  </main>
</Layout>
