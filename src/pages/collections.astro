---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import { loadPaperCollections, loadPapersForCollection, getPriority } from "../lib/content-loader";

const collections = await loadPaperCollections();

const collectionsWithPapers = await Promise.all(
  collections.map(async (collection) => ({
    ...collection,
    papers: await loadPapersForCollection(collection),
  }))
);

const totalPapers = collectionsWithPapers.reduce((sum, collection) => sum + collection.papers.length, 0);
const slugify = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
---

<Layout
  title="Paper Collections"
  description="Curated reading lists for the research areas that become easier to compare once you start thinking in data counterfactuals."
>
  <style>
    .collections-page {
      gap: 2.8rem;
    }
    .collections-page .page-header {
      margin-bottom: 0;
    }
    .collection-jumps {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
    }
    .collection-jumps li {
      padding: 0;
      border-top: 0;
    }
    .collection-jumps a {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.93rem;
      text-decoration: none;
      border-bottom: 1px solid transparent;
    }
    .collection-jumps a:hover {
      color: var(--fg);
      border-color: rgba(177, 79, 31, 0.24);
    }
    .collection-stack {
      display: grid;
      gap: 1.2rem;
    }
    .collection-section {
      scroll-margin-top: 6rem;
    }
    .collection-heading {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.8rem;
    }
    .collection-summary {
      margin: 1rem 0 0;
      max-width: var(--measure);
      color: var(--muted);
      line-height: 1.82;
      font-size: 1.03rem;
    }
    .paper-list {
      list-style: none;
      padding: 0;
      margin: 1.25rem 0 0;
      display: grid;
      gap: 0;
    }
    .paper-item {
      padding: 1rem 0;
      border-top: 1px solid var(--border);
    }
    .paper-item:first-child {
      padding-top: 0;
      border-top: 0;
    }
    .paper-title-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      align-items: center;
    }
    .paper-title {
      color: var(--fg);
      font-family: var(--font-display);
      font-size: 1.16rem;
      line-height: 1.2;
      text-decoration: none;
    }
    .paper-title:hover {
      color: var(--ring-thick);
    }
    .paper-meta {
      margin-top: 0.25rem;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.93rem;
      line-height: 1.65;
    }
    .paper-link {
      display: inline-block;
      margin-top: 0.45rem;
      font-family: var(--font-ui);
      font-size: 0.92rem;
      font-weight: 700;
      text-decoration: none;
    }
  </style>

  <Nav />

  <main class="page essay-page collections-page">
    <header class="essay-header page-header">
      <div>
        <span class="page-eyebrow">Reference shelf</span>
        <h1 class="page-title">Reading lists for the main branches of the idea</h1>
        <p class="page-lede">
          These lists are not meant to be exhaustive literature reviews. They are curated entry points for the clusters of
          work that become easier to relate once you start thinking in terms of data counterfactuals.
        </p>
        <div class="page-meta">
          <span class="pill">{collectionsWithPapers.length} collections</span>
          <span class="pill">{totalPapers} linked papers</span>
        </div>
      </div>

      <aside class="essay-side">
        <p class="note-label">How to use this page</p>
        <p>
          If you are new to the topic, pick one collection and read the highlighted papers first. If you already know the
          area, use the jump links to move directly to the shelf you care about.
        </p>
        <ul class="collection-jumps">
          {collectionsWithPapers.map((collection) => (
            <li><a href={`#${slugify(collection.title)}`}>{collection.title}</a></li>
          ))}
        </ul>
      </aside>
    </header>

    <section class="essay-section">
      <div class="essay-main">
        <h2>Start broad, then follow the thread you need</h2>
        <p>
          Each collection names one corner of the larger picture. The point is not to force everything into one taxonomy; it is
          to make the overlaps easier to notice once you keep the training-data intervention itself in view.
        </p>
        <p>
          Priority labels simply mark especially useful starting points for a collection. They do not mean the other papers are
          secondary in any global sense.
        </p>
      </div>

      <aside class="essay-side">
        <p class="note-label">Reading strategy</p>
        <p>
          Move between the memo, one collection, and the glossary if you want the fastest route from the broad concept to a
          specific literature.
        </p>
      </aside>
    </section>

    <div class="collection-stack">
      {collectionsWithPapers.map((collection) => (
        <section class="section-card collection-section" id={slugify(collection.title)}>
          <div class="collection-heading">
            <div>
              <p class="section-kicker">Collection</p>
              <h2 class="section-title">{collection.title}</h2>
            </div>
            <span class="pill">{collection.papers.length} papers</span>
          </div>

          {collection.body && <p class="collection-summary">{collection.body}</p>}

          {collection.papers.length ? (
            <ul class="paper-list">
              {collection.papers.map((paper) => {
                const priority = getPriority(paper);
                const isPriority = priority !== Infinity;
                const priorityLabel = priority === 1 ? "Start here" : `Priority ${priority}`;

                return (
                  <li class="paper-item">
                    <div class="paper-title-row">
                      {paper.url ? (
                        <a href={paper.url} target="_blank" rel="noreferrer noopener" class="paper-title">
                          {paper.title}
                        </a>
                      ) : (
                        <span class="paper-title">{paper.title}</span>
                      )}
                      {isPriority && <span class="pill">{priorityLabel}</span>}
                    </div>
                    {paper.authors?.length ? (
                      <div class="paper-meta">{paper.authors.join(", ")}</div>
                    ) : null}
                    <div class="paper-meta">
                      {paper.venue ? `${paper.venue}${paper.year ? ` (${paper.year})` : ""}` : paper.year}
                    </div>
                    {paper.url && (
                      <a href={paper.url} target="_blank" rel="noreferrer noopener" class="paper-link">
                        Read paper
                      </a>
                    )}
                  </li>
                );
              })}
            </ul>
          ) : (
            <div class="empty-state">This collection has not been populated yet.</div>
          )}
        </section>
      ))}
    </div>
  </main>
</Layout>
