---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import { loadPaperCollections, loadPapersForCollection, getPriority } from "../lib/content-loader";

const collections = await loadPaperCollections();

const collectionsWithPapers = await Promise.all(
  collections.map(async (collection) => ({
    ...collection,
    papers: await loadPapersForCollection(collection),
  }))
);

const totalPapers = collectionsWithPapers.reduce((sum, collection) => sum + collection.papers.length, 0);
const slugify = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
---

<Layout
  title="Paper Collections"
  description="Curated reading lists for the main research areas that show up in data counterfactuals."
>
  <style>
    .collections-page {
      display: grid;
      gap: 1rem;
    }
    .collection-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
    }
    .collection-nav a {
      padding: 0.55rem 0.8rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(255, 250, 243, 0.82);
      text-decoration: none;
      color: var(--muted);
      font-size: 0.9rem;
    }
    .collection-nav a:hover {
      color: var(--fg);
      border-color: rgba(177, 79, 31, 0.24);
    }
    .collections-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .collection-card {
      display: grid;
      gap: 1rem;
      align-content: start;
    }
    .collection-head {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 0.8rem;
      align-items: flex-start;
    }
    .collection-head h2 {
      margin: 0;
      font-size: 1.28rem;
    }
    .collection-desc {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }
    .paper-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.8rem;
    }
    .paper-card {
      padding: 0.95rem 1rem;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: rgba(255, 250, 243, 0.74);
    }
    .paper-card.priority {
      border-color: rgba(177, 79, 31, 0.24);
      background: linear-gradient(180deg, rgba(255, 246, 236, 0.92), rgba(250, 238, 224, 0.8));
    }
    .paper-title-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      align-items: center;
      margin-bottom: 0.3rem;
    }
    .paper-title {
      font-weight: 700;
      color: var(--fg);
    }
    .paper-meta {
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.6;
    }
    .paper-link {
      display: inline-flex;
      margin-top: 0.55rem;
      font-weight: 700;
      text-decoration: none;
    }
    @media (max-width: 960px) {
      .collections-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <Nav />

  <main class="page collections-page">
    <header class="page-header">
      <span class="page-eyebrow">Reference shelf</span>
      <h1 class="page-title">Reading lists for the main branches of the idea</h1>
      <p class="page-lede">
        These are not meant to be exhaustive literature reviews. They are curated entry points for the clusters
        of work that become easier to relate once you start thinking in training-data counterfactuals.
      </p>
      <div class="page-meta">
        <span class="pill">{collectionsWithPapers.length} collections</span>
        <span class="pill">{totalPapers} linked papers</span>
      </div>
    </header>

    <section class="section-card">
      <p class="section-kicker">How to use this page</p>
      <h2 class="section-title">Start broad, then dive</h2>
      <div class="section-copy">
        <p>
          If you are new to the topic, pick one collection and read the highlighted papers first. If you already know the area,
          use the jump links below to move straight to the subfield you care about.
        </p>
      </div>
      <nav class="collection-nav" aria-label="Collections">
        {collectionsWithPapers.map((collection) => (
          <a href={`#${slugify(collection.title)}`}>{collection.title}</a>
        ))}
      </nav>
    </section>

    <section class="collections-grid">
      {collectionsWithPapers.map((collection) => (
        <article class="section-card collection-card" id={slugify(collection.title)}>
          <div class="collection-head">
            <div>
              <p class="section-kicker">Collection</p>
              <h2>{collection.title}</h2>
            </div>
            <span class="pill">{collection.papers.length} papers</span>
          </div>

          {collection.body && <p class="collection-desc">{collection.body}</p>}

          {collection.papers.length ? (
            <ul class="paper-list">
              {collection.papers.map((paper) => {
                const priority = getPriority(paper);
                const isPriority = priority !== Infinity;
                const priorityLabel = priority === 1 ? "Start here" : `Priority ${priority}`;

                return (
                  <li class={`paper-card ${isPriority ? "priority" : ""}`}>
                    <div class="paper-title-row">
                      <span class="paper-title">{paper.title}</span>
                      {isPriority && <span class="pill">{priorityLabel}</span>}
                    </div>
                    {paper.authors?.length ? (
                      <div class="paper-meta">{paper.authors.join(", ")}</div>
                    ) : null}
                    <div class="paper-meta">
                      {paper.venue ? `${paper.venue}${paper.year ? ` (${paper.year})` : ""}` : paper.year}
                    </div>
                    {paper.url && (
                      <a href={paper.url} target="_blank" rel="noreferrer noopener" class="paper-link">
                        Read paper
                      </a>
                    )}
                  </li>
                );
              })}
            </ul>
          ) : (
            <div class="empty-state">This collection has not been populated yet.</div>
          )}
        </article>
      ))}
    </section>
  </main>
</Layout>
