---
import Site from "../layouts/Site.astro";
import { SITE_LINKS } from "../lib/site-config.js";
import {
  loadPaperCollectionsSnapshot,
  loadPapersForCollection,
} from "../lib/content-loader";

const snapshot = await loadPaperCollectionsSnapshot();
const collections = (
  await Promise.all(
    snapshot.collections.map(async (collection) => ({
      ...collection,
      papers: await loadPapersForCollection(collection),
    })),
  )
).sort((left, right) => left.title.localeCompare(right.title));

const COUNTERFACTUAL_ORDER = [
  "collective action",
  "data dividends",
  "data provenance and source attribution",
  "influence",
  "scaling laws",
  "selection and coresets",
  "poisoning",
  "semivalues",
  "user-generated content",
] as const;

const PAPER_TITLE_REPAIRS: Record<string, string> = {
  ash2020badge:
    "Deep Batch Active Learning by Diverse, Uncertain Gradient Lower Bounds",
  basu2021fragileinfluence: "Influence Functions in Deep Learning Are Fragile",
  jahagirdar2024novalidation:
    "Data Valuation in the Absence of a Reliable Validation Set",
  just2023lava: "LAVA: Data Valuation without Pre-Specified Learning Algorithms",
  kessler2025sava: "SAVA: Scalable Learning-Agnostic Data Valuation",
  khaddaj2023backdoor:
    "Backdoor or Feature? A New Perspective on Data Poisoning",
  ki2023nomodeltraining: "Data Valuation Without Training of a Model",
  longpre2024dataprovenance:
    "A Large-Scale Audit of Dataset Licensing and Attribution in AI",
  mlodozeniec2025dtda:
    "Distributional Training Data Attribution: What do Influence Functions Sample?",
  rubinstein2025rescaled:
    "Rescaled Influence Functions: Accurate Data Attribution in High Dimension",
  sener2018coreset:
    "Active Learning for Convolutional Neural Networks: A Core-Set Approach",
  shumailov2024modelcollapse:
    "AI Models Collapse When Trained on Recursively Generated Data",
  tamine2026utility:
    "On the Impact of the Utility in Semivalue-based Data Valuation",
  toneva2019forgetting:
    "An Empirical Study of Example Forgetting during Deep Neural Network Learning",
  wang2025hpsensitivity:
    "Taming Hyperparameter Sensitivity in Data Attribution: Practical Selection Without Costly Retraining",
  zhang2018mixup: "mixup: Beyond Empirical Risk Minimization",
  zhao2021gradientmatching: "Dataset Condensation with Gradient Matching",
  zhao2023distributionmatching:
    "Dataset Condensation with Distribution Matching",
};

const generatedAt = snapshot.generatedAt
  ? new Date(snapshot.generatedAt)
  : null;
const formattedDate =
  generatedAt && !Number.isNaN(generatedAt.valueOf())
    ? new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      }).format(generatedAt)
    : null;

function normalizeTitle(title: string) {
  return title.trim().toLowerCase().replace(/-/g, " ").replace(/\s+/g, " ");
}

function counterfactualRank(title: string, alphabeticalIndex: number) {
  const rank = COUNTERFACTUAL_ORDER.indexOf(
    normalizeTitle(title) as (typeof COUNTERFACTUAL_ORDER)[number],
  );
  return rank === -1 ? COUNTERFACTUAL_ORDER.length + alphabeticalIndex : rank;
}

function collectionDescription(body?: string) {
  return body
    ?.replace(
      /^\s*Part of the datacounterfactuals\.org reading lists\.\s*/i,
      "",
    )
    .trim();
}

function paperTitle(paper: (typeof collections)[number]["papers"][number]) {
  return PAPER_TITLE_REPAIRS[paper.citation_key] || paper.title;
}

function isOpenReviewUrl(url?: string) {
  return Boolean(url && new URL(url).hostname.endsWith("openreview.net"));
}

function scholarSearch(title: string) {
  return `https://scholar.google.com/scholar?q=${encodeURIComponent(title)}`;
}

function paperHref(
  paper: (typeof collections)[number]["papers"][number],
  displayTitle: string,
) {
  if (paper.url && !isOpenReviewUrl(paper.url)) return paper.url;
  if (paper.doi) return `https://doi.org/${paper.doi}`;
  if (paper.semantic_scholar_url) return paper.semantic_scholar_url;
  if (paper.google_scholar_url) return paper.google_scholar_url;
  if (paper.url && isOpenReviewUrl(paper.url)) return scholarSearch(displayTitle);
  return undefined;
}

function paperMeta(paper: (typeof collections)[number]["papers"][number]) {
  const authors =
    paper.authors?.length > 2
      ? `${paper.authors[0]} et al.`
      : paper.authors?.join(" & ");
  const venue = paper.venue || paper.booktitle || paper.journal;
  return [authors, venue, paper.year].filter(Boolean).join(" · ");
}
---

<Site
  title="Reading Map"
  description="A minimal, live projection of the Data Counterfactuals research collections maintained in Semble."
  bodyClass="reading-body"
>
  <article class="reading-page">
    <header class="reading-hero">
      <div>
        <h1>Reading Map</h1>
      </div>
      <div class="reading-intro">
        <p>
          A compact map of research areas connected to data counterfactuals.
          Collection membership, ordering notes, and paper metadata are maintained
          in Semble.
        </p>
        <div>
          <a href={SITE_LINKS.semble}>Open in Semble ↗</a>
          {formattedDate && <span>Updated {formattedDate}</span>}
        </div>
      </div>
    </header>

    <nav class="collection-index" aria-label="Collection index">
      <div class="collection-index-controls">
        <p>Jump to an area</p>
        <label for="collection-order">Order collections</label>
        <select id="collection-order" name="collection-order">
          <option value="alphabetical">Alphabetical</option>
          <option value="counterfactual">Closest to the framing</option>
        </select>
      </div>
      <ol data-collection-index>
        {collections.map((collection, index) => (
          <li
            data-alpha-order={index}
            data-counterfactual-order={counterfactualRank(collection.title, index)}
          >
            <span class="collection-index-number">
              {String(index + 1).padStart(2, "0")}
            </span>
            <a href={`#${collection.slug}`}>{collection.title}</a>
          </li>
        ))}
      </ol>
    </nav>

    <div class="collection-stack" data-collection-stack>
      {collections.map((collection, index) => {
        const preview = collection.papers.slice(0, 3);
        const remaining = collection.papers.slice(3);
        const description = collectionDescription(collection.body);
        return (
          <section
            class="reading-collection"
            id={collection.slug}
            data-alpha-order={index}
            data-counterfactual-order={counterfactualRank(collection.title, index)}
          >
            <div class="collection-number" aria-hidden="true">
              {String(index + 1).padStart(2, "0")}
            </div>
            <div class="collection-copy">
              <div class="collection-title-row">
                <h2>{collection.title}</h2>
                <span>
                  {collection.papers.length}{" "}
                  {collection.papers.length === 1 ? "paper" : "papers"}
                </span>
              </div>

              {description && <p class="collection-note">{description}</p>}

              {collection.papers.length ? (
                <>
                  <ol class="paper-list">
                    {preview.map((paper) => {
                      const title = paperTitle(paper);
                      const href = paperHref(paper, title);
                      return (
                        <li>
                          <span class="paper-rule" aria-hidden="true" />
                          <div>
                            {href ? (
                              <a href={href}>{title}</a>
                            ) : (
                              <span class="paper-title">{title}</span>
                            )}
                            <small>{paperMeta(paper)}</small>
                          </div>
                        </li>
                      );
                    })}
                  </ol>

                  {remaining.length > 0 && (
                    <details class="remaining-papers">
                      <summary>
                        Show {remaining.length} more{" "}
                        {remaining.length === 1 ? "paper" : "papers"}
                      </summary>
                      <ol class="paper-list">
                        {remaining.map((paper) => {
                          const title = paperTitle(paper);
                          const href = paperHref(paper, title);
                          return (
                            <li>
                              <span class="paper-rule" aria-hidden="true" />
                              <div>
                                {href ? (
                                  <a href={href}>{title}</a>
                                ) : (
                                  <span class="paper-title">{title}</span>
                                )}
                                <small>{paperMeta(paper)}</small>
                              </div>
                            </li>
                          );
                        })}
                      </ol>
                    </details>
                  )}
                </>
              ) : (
                <p class="empty-collection">No papers in this collection yet.</p>
              )}
            </div>
          </section>
        );
      })}
    </div>

    <aside class="reading-footer-note">
      <p>A list of starting points, not exhaustive.</p>
      <a href="/">Return to the Counterfactual Lab →</a>
    </aside>
  </article>
</Site>

<script is:inline>
  const orderSelect = document.querySelector("#collection-order");
  const collectionIndex = document.querySelector("[data-collection-index]");
  const collectionStack = document.querySelector("[data-collection-stack]");

  function reorderCollections(order) {
    const orderKey =
      order === "counterfactual" ? "counterfactualOrder" : "alphaOrder";

    [collectionIndex, collectionStack].forEach((container) => {
      if (!container) return;

      [...container.children]
        .sort(
          (left, right) =>
            Number(left.dataset[orderKey]) - Number(right.dataset[orderKey]),
        )
        .forEach((item, index) => {
          const number = item.querySelector(
            ".collection-index-number, .collection-number",
          );
          if (number) number.textContent = String(index + 1).padStart(2, "0");
          container.append(item);
        });
    });
  }

  orderSelect?.addEventListener("change", (event) => {
    reorderCollections(event.currentTarget.value);
  });
</script>

<style>
  .reading-page {
    width: min(calc(100% - 40px), 1180px);
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 7rem) 0 0;
  }

  .reading-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: clamp(2rem, 8vw, 8rem);
    align-items: end;
    padding-bottom: clamp(2.5rem, 6vw, 5rem);
    border-bottom: 1px solid var(--line-strong);
  }

  .reading-hero h1 {
    margin: 0;
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    font-weight: 500;
    line-height: 0.86;
    letter-spacing: -0.065em;
  }

  .reading-intro > p {
    margin: 0;
    color: #abc0b6;
    font-size: 1rem;
    line-height: 1.75;
  }

  .reading-intro > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    color: var(--faint);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .reading-intro a {
    color: var(--mint);
    text-decoration: none;
  }

  .collection-index {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--line-strong);
  }

  .collection-index-controls {
    display: grid;
    align-content: start;
    gap: 0.65rem;
  }

  .collection-index-controls p,
  .collection-index-controls label {
    margin: 0;
    color: var(--faint);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .collection-index-controls label {
    margin-top: 0.35rem;
    color: var(--muted);
    font-size: 0.58rem;
  }

  .collection-index-controls select {
    width: 100%;
    padding: 0.48rem 1.6rem 0.48rem 0.55rem;
    color: var(--ink);
    background: var(--ground-raised);
    border: 1px solid var(--line-strong);
    border-radius: 0.25rem;
    font-size: 0.66rem;
  }

  .collection-index ol {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem 1.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .collection-index li {
    min-width: 0;
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 0.5rem;
  }

  .collection-index li span {
    color: #536a60;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.58rem;
  }

  .collection-index a {
    overflow: hidden;
    color: var(--muted);
    font-size: 0.75rem;
    text-overflow: ellipsis;
    text-decoration: none;
    white-space: nowrap;
  }

  .collection-index a:hover {
    color: var(--ink);
  }

  .collection-stack {
    border-bottom: 1px solid var(--line-strong);
  }

  .reading-collection {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
    padding: clamp(2.4rem, 6vw, 5rem) 0;
    scroll-margin-top: 2rem;
    border-top: 1px solid var(--line-strong);
  }

  .reading-collection:first-child {
    border-top: 0;
  }

  .collection-number {
    color: #314a3e;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    font-weight: 300;
    line-height: 1;
  }

  .collection-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .collection-title-row h2 {
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3.8rem);
    font-weight: 520;
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .collection-title-row > span {
    flex: none;
    color: var(--faint);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
  }

  .collection-note {
    max-width: 720px;
    margin: 1rem 0 0;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.65;
    white-space: pre-line;
  }

  .paper-list {
    display: grid;
    gap: 0;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .paper-list li {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 0.7rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
  }

  .paper-rule {
    width: 16px;
    height: 1px;
    margin-top: 0.62rem;
    background: var(--coral);
  }

  .paper-list li > div {
    display: grid;
    gap: 0.3rem;
  }

  .paper-list a,
  .paper-title {
    color: #d9e7e1;
    font-size: 0.9rem;
    font-weight: 590;
    line-height: 1.4;
    text-decoration: none;
  }

  .paper-list a:hover {
    color: var(--mint-strong);
  }

  .paper-list small {
    color: var(--faint);
    font-size: 0.66rem;
    line-height: 1.45;
  }

  .remaining-papers {
    margin-top: 0.7rem;
  }

  .remaining-papers summary {
    width: fit-content;
    color: var(--mint);
    font-size: 0.72rem;
    font-weight: 720;
  }

  .remaining-papers .paper-list {
    margin-top: 0.7rem;
  }

  .empty-collection {
    color: var(--faint);
    font-size: 0.78rem;
  }

  .reading-footer-note {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 3rem;
    padding: 2rem 0;
  }

  .reading-footer-note p {
    max-width: 690px;
    margin: 0;
    color: var(--faint);
    font-size: 0.75rem;
    line-height: 1.6;
  }

  .reading-footer-note a {
    flex: none;
    color: var(--mint);
    font-size: 0.75rem;
    font-weight: 720;
  }

  @media (max-width: 820px) {
    .reading-page {
      width: min(calc(100% - 28px), 1180px);
      padding-top: 3.5rem;
    }

    .reading-hero {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .reading-hero h1 {
      font-size: clamp(3rem, 11vw, 4.75rem);
    }

    .collection-index,
    .reading-collection {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .collection-index ol {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .collection-index-controls select {
      width: min(100%, 18rem);
    }

    .collection-number {
      font-size: 1rem;
    }

    .reading-footer-note {
      display: grid;
      gap: 1rem;
    }
  }

  @media (max-width: 520px) {
    .collection-index ol {
      grid-template-columns: 1fr;
    }

    .collection-title-row {
      display: grid;
      gap: 0.6rem;
    }
  }
</style>
