---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import { loadPaperCollections, loadPapersForCollection, getPriority } from "../lib/content-loader";
import { getRequiredPageEntry, getSection, renderMarkdownBlocks, splitMarkdownSections } from "../lib/page-content";

const collections = await loadPaperCollections();

const collectionsWithPapers = await Promise.all(
  collections.map(async (collection) => ({
    ...collection,
    papers: await loadPapersForCollection(collection),
  }))
);

const totalPapers = collectionsWithPapers.reduce((sum, collection) => sum + collection.papers.length, 0);
const slugify = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
const featuredCollectionSlugs = new Set([
  "collective-action",
  "influence",
  "semivalues",
  "scaling-laws",
]);
const isFeaturedCollection = (title: string) =>
  featuredCollectionSlugs.has(slugify(title.replace(/^dc:\s*/i, "")));
const page = await getRequiredPageEntry("collections");
const sections = splitMarkdownSections(page.body);
const introSection = getSection(sections, "start-broad-then-follow-the-thread-you-need");
const headerNote = page.data.notes?.header;
const sectionNote = page.data.notes?.section;
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style>
    .collections-page {
      gap: 2.8rem;
    }
    .collections-page .page-header {
      margin-bottom: 0;
    }
    .collection-jumps {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
    }
    .collection-jumps li {
      padding: 0;
      border-top: 0;
    }
    .collection-jumps a {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.93rem;
      text-decoration: none;
      border-bottom: 1px solid transparent;
    }
    .collection-jumps a:hover {
      color: var(--fg);
      border-color: rgba(177, 79, 31, 0.24);
    }
    .collection-stack {
      display: grid;
      gap: 1.2rem;
    }
    .collection-section {
      scroll-margin-top: 6rem;
    }
    .collection-heading {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.8rem;
    }
    .collection-summary {
      margin: 1rem 0 0;
      max-width: var(--measure);
      color: var(--muted);
      line-height: 1.82;
      font-size: 1.03rem;
    }
    .collection-flags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.55rem;
    }
    .paper-list {
      list-style: none;
      padding: 0;
      margin: 1.25rem 0 0;
      display: grid;
      gap: 0;
    }
    .paper-item {
      padding: 1rem 0;
      border-top: 1px solid var(--border);
    }
    .paper-item:first-child {
      padding-top: 0;
      border-top: 0;
    }
    .paper-title-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      align-items: center;
    }
    .paper-title {
      color: var(--fg);
      font-family: var(--font-display);
      font-size: 1.16rem;
      line-height: 1.2;
      text-decoration: none;
    }
    .paper-title:hover {
      color: var(--ring-thick);
    }
    .paper-meta {
      margin-top: 0.25rem;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.93rem;
      line-height: 1.65;
    }
    .paper-link {
      display: inline-block;
      margin-top: 0.45rem;
      font-family: var(--font-ui);
      font-size: 0.92rem;
      font-weight: 700;
      text-decoration: none;
    }
  </style>

  <Nav />

  <main class="page essay-page collections-page">
    <header class="essay-header page-header">
      <div>
        {page.data.eyebrow && <span class="page-eyebrow">{page.data.eyebrow}</span>}
        <h1 class="page-title">{page.data.title}</h1>
        {page.data.lede && <p class="page-lede">{page.data.lede}</p>}
        <div class="page-meta">
          <span class="pill">{collectionsWithPapers.length} collections</span>
          <span class="pill">{totalPapers} linked papers</span>
        </div>
      </div>

      <aside class="essay-side">
        {headerNote?.label && <p class="note-label">{headerNote.label}</p>}
        {renderMarkdownBlocks(headerNote?.body ?? []).map((html) => (
          <div set:html={html}></div>
        ))}
        <ul class="collection-jumps">
          {collectionsWithPapers.map((collection) => (
            <li><a href={`#${slugify(collection.title)}`}>{collection.title}</a></li>
          ))}
        </ul>
      </aside>
    </header>

    <section class="essay-section">
      <div class="essay-main">
        <h2>{introSection.title}</h2>
        <div set:html={introSection.html}></div>
      </div>

      <aside class="essay-side">
        {sectionNote?.label && <p class="note-label">{sectionNote.label}</p>}
        {renderMarkdownBlocks(sectionNote?.body ?? []).map((html) => (
          <div set:html={html}></div>
        ))}
      </aside>
    </section>

    <div class="collection-stack">
      {collectionsWithPapers.map((collection) => (
        <section class="section-card collection-section" id={slugify(collection.title)}>
          <div class="collection-heading">
            <div>
              <p class="section-kicker">Collection</p>
              <h2 class="section-title">{collection.title}</h2>
              {isFeaturedCollection(collection.title) && (
                <div class="collection-flags">
                  <span class="pill">Most directly connected</span>
                </div>
              )}
            </div>
            <span class="pill">{collection.papers.length} papers</span>
          </div>

          {collection.body && <p class="collection-summary">{collection.body}</p>}

          {collection.papers.length ? (
            <ul class="paper-list">
              {collection.papers.map((paper) => {
                const priority = getPriority(paper);
                const isPriority = priority !== Infinity;
                const priorityLabel = priority === 1 ? "Start here" : `Priority ${priority}`;

                return (
                  <li class="paper-item">
                    <div class="paper-title-row">
                      {paper.url ? (
                        <a href={paper.url} target="_blank" rel="noreferrer noopener" class="paper-title">
                          {paper.title}
                        </a>
                      ) : (
                        <span class="paper-title">{paper.title}</span>
                      )}
                      {isPriority && <span class="pill">{priorityLabel}</span>}
                    </div>
                    {paper.authors?.length ? (
                      <div class="paper-meta">{paper.authors.join(", ")}</div>
                    ) : null}
                    <div class="paper-meta">
                      {paper.venue ? `${paper.venue}${paper.year ? ` (${paper.year})` : ""}` : paper.year}
                    </div>
                    {paper.url && (
                      <a href={paper.url} target="_blank" rel="noreferrer noopener" class="paper-link">
                        Read paper
                      </a>
                    )}
                  </li>
                );
              })}
            </ul>
          ) : (
            <div class="empty-state">This collection has not been populated yet.</div>
          )}
        </section>
      ))}
    </div>
  </main>
</Layout>
