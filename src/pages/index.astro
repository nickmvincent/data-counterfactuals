---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import MiniGrid from "../components/MiniGrid.jsx";
import { getRequiredPageEntry, splitMarkdownDocument } from "../lib/page-content";
import { getPublicMemoBySlug, LAUNCH_MEMO_SLUG } from "../lib/memos";

const page = await getRequiredPageEntry("index");
const homeMemo = await getPublicMemoBySlug(LAUNCH_MEMO_SLUG);

if (!homeMemo) {
  throw new Error(`Missing homepage memo '${LAUNCH_MEMO_SLUG}'.`);
}

const homeExcerpt = splitMarkdownDocument(homeMemo.body);
const featuredSections = homeExcerpt.sections.slice(0, homeMemo.data.homepageSections ?? 3);
const introHtml = homeExcerpt.leadHtml;
const readingPaths = page.data.reading_paths ?? [];
const readingPathByHref = Object.fromEntries(readingPaths.map((path) => [path.href, path]));
const quickStartPaths = [
  readingPathByHref["/grid"],
  readingPathByHref["/memo/data-counterfactuals"],
  readingPathByHref["/glossary"],
].filter(Boolean);
const figures = page.data.figures ?? {};
const leaveOneOutFigureSectionIds = new Set([
  "a-small-example",
  "the-smallest-useful-example",
  "the-smallest-useful-move",
  "what-is-a-data-counterfactual",
]);
const gridFigureSectionIds = new Set([
  "the-grid-view",
  "a-grid-for-seeing-the-space",
  "why-the-grid-visualization-metaphor-is-useful",
]);
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style is:global>
    body:has(.start-page) {
      background: linear-gradient(180deg, #fbf8f2 0%, #f4ede3 56%, #eee4d6 100%);
    }
    body:has(.start-page) .top-nav {
      background: rgba(251, 247, 240, 0.84);
      border-bottom-color: rgba(92, 72, 52, 0.08);
      backdrop-filter: blur(10px);
    }
    .start-page {
      width: min(calc(100% - 2rem), calc(var(--measure) + 8rem));
      display: grid;
      gap: clamp(3rem, 5vw, 4.4rem);
      padding-top: clamp(2rem, 4vw, 3.4rem);
    }
    .start-intro,
    .start-section {
      width: min(100%, var(--measure));
      margin-inline: auto;
    }
    .start-intro {
      display: grid;
      gap: 1.15rem;
      margin-bottom: 0;
    }
    .start-intro .page-eyebrow {
      color: rgba(101, 90, 79, 0.86);
    }
    .start-intro .page-title {
      max-width: 11ch;
      font-size: clamp(2.55rem, 5.6vw, 4.3rem);
      line-height: 0.98;
      letter-spacing: -0.035em;
    }
    .start-intro .page-lede {
      max-width: 40rem;
      color: rgba(32, 26, 22, 0.84);
      font-size: clamp(1.12rem, 1.5vw, 1.28rem);
      line-height: 1.84;
    }
    .start-intro .intro-block {
      max-width: 38rem;
    }
    .start-intro .intro-block p {
      margin: 0;
      color: var(--muted);
      font-size: 1.04rem;
      line-height: 1.92;
    }
    .start-intro .intro-block ul {
      margin: 0.95rem 0 0;
      padding-left: 1.3rem;
      color: var(--muted);
    }
    .start-intro .intro-block li {
      margin: 0.45rem 0;
      line-height: 1.82;
    }
    .start-utility-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
    }
    .start-utility-note {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.88rem;
      line-height: 1.6;
    }
    .quickstart-dialog {
      width: min(calc(100% - 1.5rem), 42rem);
      margin: auto;
      padding: 0;
      border: 0;
      border-radius: 28px;
      background: transparent;
      color: inherit;
      box-shadow: 0 28px 80px rgba(37, 28, 20, 0.24);
    }
    .quickstart-dialog::backdrop {
      background: rgba(34, 26, 20, 0.42);
      backdrop-filter: blur(5px);
    }
    .quickstart-shell {
      display: grid;
      gap: 1rem;
      padding: clamp(1.2rem, 2vw, 1.6rem);
      border-radius: 28px;
      border: 1px solid rgba(92, 72, 52, 0.14);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0)),
        linear-gradient(135deg, rgba(47, 107, 111, 0.08), rgba(177, 79, 31, 0.08)),
        rgba(255, 250, 243, 0.98);
    }
    .quickstart-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }
    .quickstart-kicker {
      color: var(--ring-thick);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.11em;
      text-transform: uppercase;
    }
    .quickstart-title {
      margin: 0.25rem 0 0;
      font-family: var(--font-display);
      font-size: clamp(1.7rem, 2.2vw, 2.2rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
    }
    .quickstart-copy {
      margin: 0.7rem 0 0;
      color: var(--muted);
      font-size: 0.98rem;
      line-height: 1.74;
    }
    .quickstart-close {
      flex: 0 0 auto;
    }
    .quickstart-grid {
      display: grid;
      gap: 0.8rem;
      grid-template-columns: repeat(auto-fit, minmax(11.5rem, 1fr));
    }
    .quickstart-card {
      display: grid;
      gap: 0.45rem;
      padding: 1rem;
      border-radius: 18px;
      border: 1px solid rgba(92, 72, 52, 0.12);
      background: rgba(255, 255, 255, 0.7);
      color: inherit;
      text-decoration: none;
    }
    .quickstart-card:hover,
    .quickstart-card:focus-visible {
      border-color: rgba(177, 79, 31, 0.22);
      transform: translateY(-1px);
    }
    .quickstart-card-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: 1.14rem;
      line-height: 1.18;
    }
    .quickstart-card-copy {
      margin: 0;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.9rem;
      line-height: 1.62;
    }
    .quickstart-footer {
      margin: 0;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.84rem;
      line-height: 1.6;
    }
    .start-section {
      padding-top: 2.35rem;
      border-top: 1px solid rgba(92, 72, 52, 0.14);
    }
    .start-section h2 {
      margin: 0 0 1rem;
      color: var(--fg);
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 2vw, 1.98rem);
      line-height: 1.12;
      letter-spacing: -0.02em;
    }
    .start-section p {
      margin: 0 0 1.15rem;
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.92;
    }
    .start-section p:last-child {
      margin-bottom: 0;
    }
    .start-page .essay-figure {
      margin: 1.65rem 0 0;
      padding: 1rem 0 0.15rem;
      border: 0;
      border-top: 1px solid rgba(92, 72, 52, 0.14);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }
    .start-page .note-label {
      margin-bottom: 0.55rem;
      color: rgba(101, 90, 79, 0.82);
    }
    .start-page .mini-grid-wrap {
      display: grid;
      gap: 0.75rem;
      align-items: start;
      width: 100%;
      overflow-x: auto;
      padding-bottom: 0.25rem;
    }
    .start-page .mini-grid {
      gap: 3px;
      width: max-content;
      margin-inline: 0;
    }
    .start-page .mini-corner,
    .start-page .mini-row-label,
    .start-page .mini-col-label,
    .start-page .mini-cell {
      border-radius: 10px;
    }
    .start-page .mini-corner {
      width: 58px;
      height: 42px;
      background: rgba(255, 250, 243, 0.5);
      border: 1px solid rgba(92, 72, 52, 0.12);
    }
    .start-page .mini-col-label {
      min-width: 58px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-ui);
      font-size: 0.72rem;
      color: rgba(101, 90, 79, 0.9);
      background: rgba(255, 250, 243, 0.56);
      border: 1px solid rgba(92, 72, 52, 0.12);
    }
    .start-page .mini-col-label.active {
      color: var(--fg);
      background: rgba(177, 79, 31, 0.08);
      border-color: rgba(177, 79, 31, 0.16);
    }
    .start-page .mini-row-label {
      width: 58px;
      min-height: 46px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 0.8rem;
      font-family: var(--font-ui);
      font-size: 0.72rem;
      color: rgba(101, 90, 79, 0.9);
      background: rgba(255, 250, 243, 0.56);
      border: 1px solid rgba(92, 72, 52, 0.12);
    }
    .start-page .mini-row-label.active {
      color: var(--fg);
      background: rgba(47, 107, 111, 0.08);
      border-color: rgba(47, 107, 111, 0.16);
    }
    .start-page .mini-cell {
      width: 58px;
      min-height: 46px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: default;
      position: relative;
      transition: filter 180ms ease, opacity 180ms ease;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    }
    .start-page .mini-cell:hover {
      filter: saturate(0.94);
    }
    .start-page .mini-cell.ring-highlight {
      outline: 2px solid var(--ring-thick);
      outline-offset: -3px;
    }
    .start-page .mini-cell.ring-compare {
      outline: 2px solid var(--ring-thin);
      outline-offset: -3px;
    }
    .start-page .mini-cell.selected {
      outline: 2px solid #fff;
      outline-offset: -3px;
    }
    .start-page .mini-val {
      font-family: var(--font-ui);
      font-size: 0.72rem;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    }
    .start-page .mini-caption,
    .start-page .mini-tooltip {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.85rem;
      line-height: 1.64;
    }
    .start-page .mini-tooltip {
      margin-top: 0;
      padding: 0.72rem 0.9rem;
      border-radius: 12px;
      border: 1px solid rgba(92, 72, 52, 0.12);
      background: rgba(255, 250, 243, 0.92);
      max-width: min(100%, 34rem);
    }
    .start-links {
      margin-top: 1.45rem;
    }
    .start-links a {
      font-family: var(--font-body);
      font-size: 1.08rem;
      line-height: 1.38;
    }
    .start-links a::after {
      content: " →";
      opacity: 0.45;
      font-style: normal;
    }
    .start-links p {
      font-family: var(--font-body);
      font-size: 0.98rem;
      line-height: 1.78;
    }

    @media (max-width: 780px) {
      .start-page {
        width: min(calc(100% - 1.25rem), calc(var(--measure) + 8rem));
        padding-top: 1.25rem;
        gap: 3rem;
      }
      .start-section {
        padding-top: 2rem;
      }
      .start-utility-row {
        align-items: flex-start;
      }
      .quickstart-head {
        display: grid;
      }
    }
  </style>

  <Nav />

  <main class="page start-page">
    <header class="page-header start-intro">
      {page.data.eyebrow && <span class="page-eyebrow">{page.data.eyebrow}</span>}
      <h1 class="page-title">{page.data.title}</h1>
      {page.data.lede && <p class="page-lede">{page.data.lede}</p>}
      {introHtml && <div class="intro-block" set:html={introHtml}></div>}
      {quickStartPaths.length > 0 && (
        <div class="start-utility-row">
          <button class="btn ghost" type="button" data-quickstart-open>Open quick-start guide</button>
          <span class="start-utility-note">A short chooser for where to begin, without changing the flow of the page.</span>
        </div>
      )}
    </header>

    {quickStartPaths.length > 0 && (
      <dialog class="quickstart-dialog" data-quickstart-dialog>
        <div class="quickstart-shell">
          <div class="quickstart-head">
            <div>
              <span class="quickstart-kicker">Quick start</span>
              <h2 class="quickstart-title">Pick the version of the site that matches how you want to learn it.</h2>
              <p class="quickstart-copy">If you want the shortest path in, start with the interactive grid. If you want the argument first, open the memo. If you want definitions nearby while you browse, keep the glossary handy.</p>
            </div>

            <form method="dialog" class="quickstart-close">
              <button class="btn ghost" type="submit">Close</button>
            </form>
          </div>

          <div class="quickstart-grid">
            {quickStartPaths.map((path) => (
              <a href={path.href} class="quickstart-card">
                <h3 class="quickstart-card-title">{path.title}</h3>
                {path.body && <p class="quickstart-card-copy">{path.body}</p>}
              </a>
            ))}
          </div>

          <p class="quickstart-footer">You can reopen this guide any time from the button at the top of the page.</p>
        </div>
      </dialog>
    )}

    {featuredSections.map((section, index) => {
      const showLeaveOneOutFigure = leaveOneOutFigureSectionIds.has(section.id);
      const showGridFigure = gridFigureSectionIds.has(section.id);
      const showReadingPaths = index === featuredSections.length - 1;

      return (
        <section class="start-section">
          <h2>{section.title}</h2>
          <div set:html={section.html}></div>

          {showLeaveOneOutFigure && (
            <div class="essay-figure">
              {figures.leave_one_out?.label && <p class="note-label">{figures.leave_one_out.label}</p>}
              <MiniGrid
                client:load
                rows={["ABCD", "ACD"]}
                cols={["A", "B", "C", "D"]}
                values={[
                  [0.92, 0.88, 0.85, 0.82],
                  [0.78, 0.55, 0.82, 0.8]
                ]}
                highlightRow={0}
                compareRow={1}
                interactive={false}
                caption={figures.leave_one_out?.caption}
              />
            </div>
          )}

          {showGridFigure && (
            <>
              <div class="essay-figure">
                {figures.grid?.label && <p class="note-label">{figures.grid.label}</p>}
                <MiniGrid
                  client:load
                  rows={["AB", "ABC", "ABCD", "ACD"]}
                  cols={["A", "B", "C", "D"]}
                  values={[
                    [0.85, 0.72, 0.45, 0.38],
                    [0.88, 0.8, 0.75, 0.52],
                    [0.92, 0.88, 0.85, 0.82],
                    [0.78, 0.55, 0.82, 0.8]
                  ]}
                  interactive={false}
                  caption={figures.grid?.caption}
                />
              </div>

              <div class="action-row" style="margin-top: 1.35rem;">
                <a href="/grid" class="btn">Open in Explorer</a>
              </div>
            </>
          )}

          {showReadingPaths && (
            <ul class="link-cluster start-links">
              {readingPaths.map((path) => (
                <li>
                  <a href={path.href}>{path.title}</a>
                  {path.body && <p>{path.body}</p>}
                </li>
              ))}
            </ul>
          )}
        </section>
      );
    })}
  </main>

  {quickStartPaths.length > 0 && (
    <script>
      const dialog = document.querySelector("[data-quickstart-dialog]");
      const openButton = document.querySelector("[data-quickstart-open]");

      if (dialog instanceof HTMLDialogElement && openButton instanceof HTMLButtonElement) {
        openButton.addEventListener("click", () => dialog.showModal());
        dialog.addEventListener("click", (event) => {
          const bounds = dialog.getBoundingClientRect();
          const clickedBackdrop = (
            event.clientX < bounds.left ||
            event.clientX > bounds.right ||
            event.clientY < bounds.top ||
            event.clientY > bounds.bottom
          );

          if (clickedBackdrop) {
            dialog.close();
          }
        });
      }
    </script>
  )}
</Layout>
