---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import MiniGrid from "../components/MiniGrid.jsx";
import { getRequiredPageEntry, getSection, renderMarkdownBlocks, splitMarkdownSections } from "../lib/page-content";

const page = await getRequiredPageEntry("index");
const sections = splitMarkdownSections(page.body);
const introBlocks = renderMarkdownBlocks(page.data.intro ?? []);
const coreMove = getSection(sections, "the-smallest-useful-move");
const gridSection = getSection(sections, "a-grid-for-seeing-the-space");
const connections = getSection(sections, "what-the-idea-helps-connect");
const navigation = getSection(sections, "how-to-read-the-site");
const methodFamilies = page.data.method_families ?? [];
const readingPaths = page.data.reading_paths ?? [];
const figures = page.data.figures ?? {};
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style is:global>
    body:has(.start-page) {
      background: linear-gradient(180deg, #fbf8f2 0%, #f4ede3 56%, #eee4d6 100%);
    }
    body:has(.start-page) .top-nav {
      background: rgba(251, 247, 240, 0.84);
      border-bottom-color: rgba(92, 72, 52, 0.08);
      backdrop-filter: blur(10px);
    }
    .start-page {
      width: min(calc(100% - 2rem), calc(var(--measure) + 8rem));
      display: grid;
      gap: clamp(3rem, 5vw, 4.4rem);
      padding-top: clamp(2rem, 4vw, 3.4rem);
    }
    .start-intro,
    .start-section {
      width: min(100%, var(--measure));
      margin-inline: auto;
    }
    .start-intro {
      display: grid;
      gap: 1.15rem;
      margin-bottom: 0;
    }
    .start-intro .page-eyebrow {
      color: rgba(101, 90, 79, 0.86);
    }
    .start-intro .page-title {
      max-width: 11ch;
      font-size: clamp(2.55rem, 5.6vw, 4.3rem);
      line-height: 0.98;
      letter-spacing: -0.035em;
    }
    .start-intro .page-lede {
      max-width: 40rem;
      color: rgba(32, 26, 22, 0.84);
      font-size: clamp(1.12rem, 1.5vw, 1.28rem);
      line-height: 1.84;
    }
    .start-intro .intro-block {
      max-width: 38rem;
    }
    .start-intro .intro-block p {
      margin: 0;
      color: var(--muted);
      font-size: 1.04rem;
      line-height: 1.92;
    }
    .start-section {
      padding-top: 2.35rem;
      border-top: 1px solid rgba(92, 72, 52, 0.14);
    }
    .start-section h2 {
      margin: 0 0 1rem;
      color: var(--fg);
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 2vw, 1.98rem);
      line-height: 1.12;
      letter-spacing: -0.02em;
    }
    .start-section p {
      margin: 0 0 1.15rem;
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.92;
    }
    .start-section p:last-child {
      margin-bottom: 0;
    }
    .start-page .essay-figure {
      margin: 1.65rem 0 0;
      padding: 1rem 0 0.15rem;
      border: 0;
      border-top: 1px solid rgba(92, 72, 52, 0.14);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }
    .start-page .note-label {
      margin-bottom: 0.55rem;
      color: rgba(101, 90, 79, 0.82);
    }
    .start-page .mini-grid-wrap {
      display: grid;
      gap: 0.75rem;
      align-items: start;
      width: 100%;
      overflow-x: auto;
      padding-bottom: 0.25rem;
    }
    .start-page .mini-grid {
      gap: 3px;
      width: max-content;
      margin-inline: 0;
    }
    .start-page .mini-corner,
    .start-page .mini-row-label,
    .start-page .mini-col-label,
    .start-page .mini-cell {
      border-radius: 10px;
    }
    .start-page .mini-corner {
      width: 58px;
      height: 42px;
      background: rgba(255, 250, 243, 0.5);
      border: 1px solid rgba(92, 72, 52, 0.12);
    }
    .start-page .mini-col-label {
      min-width: 58px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-ui);
      font-size: 0.72rem;
      color: rgba(101, 90, 79, 0.9);
      background: rgba(255, 250, 243, 0.56);
      border: 1px solid rgba(92, 72, 52, 0.12);
    }
    .start-page .mini-col-label.active {
      color: var(--fg);
      background: rgba(177, 79, 31, 0.08);
      border-color: rgba(177, 79, 31, 0.16);
    }
    .start-page .mini-row-label {
      width: 58px;
      min-height: 46px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 0.8rem;
      font-family: var(--font-ui);
      font-size: 0.72rem;
      color: rgba(101, 90, 79, 0.9);
      background: rgba(255, 250, 243, 0.56);
      border: 1px solid rgba(92, 72, 52, 0.12);
    }
    .start-page .mini-row-label.active {
      color: var(--fg);
      background: rgba(47, 107, 111, 0.08);
      border-color: rgba(47, 107, 111, 0.16);
    }
    .start-page .mini-cell {
      width: 58px;
      min-height: 46px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: default;
      position: relative;
      transition: filter 180ms ease, opacity 180ms ease;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    }
    .start-page .mini-cell:hover {
      filter: saturate(0.94);
    }
    .start-page .mini-cell.ring-highlight {
      outline: 2px solid var(--ring-thick);
      outline-offset: -3px;
    }
    .start-page .mini-cell.ring-compare {
      outline: 2px solid var(--ring-thin);
      outline-offset: -3px;
    }
    .start-page .mini-cell.selected {
      outline: 2px solid #fff;
      outline-offset: -3px;
    }
    .start-page .mini-val {
      font-family: var(--font-ui);
      font-size: 0.72rem;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    }
    .start-page .mini-caption,
    .start-page .mini-tooltip {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.85rem;
      line-height: 1.64;
    }
    .start-page .mini-tooltip {
      margin-top: 0;
      padding: 0.72rem 0.9rem;
      border-radius: 12px;
      border: 1px solid rgba(92, 72, 52, 0.12);
      background: rgba(255, 250, 243, 0.92);
      max-width: min(100%, 34rem);
    }
    .family-list {
      list-style: none;
      padding: 0;
      margin: 1.45rem 0 0;
      display: grid;
      gap: 0;
    }
    .family-item {
      padding: 1rem 0;
      border-top: 1px solid rgba(92, 72, 52, 0.12);
    }
    .family-item:first-child {
      padding-top: 0;
      border-top: 0;
    }
    .family-item h3 {
      margin: 0 0 0.3rem;
      font-family: var(--font-ui);
      font-size: 0.95rem;
      line-height: 1.4;
      letter-spacing: 0.02em;
      color: var(--fg);
    }
    .family-item p {
      margin: 0;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.82;
    }
    .start-links {
      margin-top: 1.45rem;
    }
    .start-links a {
      font-family: var(--font-body);
      font-size: 1.08rem;
      line-height: 1.38;
    }
    .start-links a::after {
      content: " →";
      opacity: 0.45;
      font-style: normal;
    }
    .start-links p {
      font-family: var(--font-body);
      font-size: 0.98rem;
      line-height: 1.78;
    }

    @media (max-width: 780px) {
      .start-page {
        width: min(calc(100% - 1.25rem), calc(var(--measure) + 8rem));
        padding-top: 1.25rem;
        gap: 3rem;
      }
      .start-section {
        padding-top: 2rem;
      }
    }
  </style>

  <Nav />

  <main class="page start-page">
    <header class="page-header start-intro">
      {page.data.eyebrow && <span class="page-eyebrow">{page.data.eyebrow}</span>}
      <h1 class="page-title">{page.data.title}</h1>
      {page.data.lede && <p class="page-lede">{page.data.lede}</p>}
      {introBlocks.map((html) => (
        <div class="intro-block" set:html={html}></div>
      ))}
    </header>

    <section class="start-section">
      <h2>{coreMove.title}</h2>
      <div set:html={coreMove.html}></div>

      <div class="essay-figure">
        {figures.leave_one_out?.label && <p class="note-label">{figures.leave_one_out.label}</p>}
        <MiniGrid
          client:load
          rows={["ABCD", "ACD"]}
          cols={["A", "B", "C", "D"]}
          values={[
            [0.92, 0.88, 0.85, 0.82],
            [0.78, 0.55, 0.82, 0.8]
          ]}
          highlightRow={0}
          compareRow={1}
          interactive={false}
          caption={figures.leave_one_out?.caption}
        />
      </div>
    </section>

    <section class="start-section">
      <h2>{gridSection.title}</h2>
      <div set:html={gridSection.html}></div>

      <div class="essay-figure">
        {figures.grid?.label && <p class="note-label">{figures.grid.label}</p>}
        <MiniGrid
          client:load
          rows={["AB", "ABC", "ABCD", "ACD"]}
          cols={["A", "B", "C", "D"]}
          values={[
            [0.85, 0.72, 0.45, 0.38],
            [0.88, 0.8, 0.75, 0.52],
            [0.92, 0.88, 0.85, 0.82],
            [0.78, 0.55, 0.82, 0.8]
          ]}
          interactive={false}
          caption={figures.grid?.caption}
        />
      </div>

      <div class="action-row" style="margin-top: 1.35rem;">
        <a href="/grid" class="btn">Open in Explorer</a>
        <a href="/advanced.html" class="btn secondary" target="_blank" rel="noreferrer noopener">Try the 3D view</a>
      </div>
    </section>

    <section class="start-section">
      <h2>{connections.title}</h2>
      <div set:html={connections.html}></div>

      <ul class="family-list">
        {methodFamilies.map((family) => (
          <li class="family-item">
            <h3>{family.title}</h3>
            <p>{family.body}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="start-section">
      <h2>{navigation.title}</h2>
      <div set:html={navigation.html}></div>

      <ul class="link-cluster start-links">
        {readingPaths.map((path) => (
          <li>
            <a href={path.href}>{path.title}</a>
            {path.body && <p>{path.body}</p>}
          </li>
        ))}
      </ul>
    </section>
  </main>
</Layout>
