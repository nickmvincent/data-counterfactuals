---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import MiniGrid from "../components/MiniGrid.jsx";
import { getRequiredPageEntry, getSection, renderMarkdownBlocks, splitMarkdownSections } from "../lib/page-content";

const page = await getRequiredPageEntry("index");
const sections = splitMarkdownSections(page.body);
const introBlocks = renderMarkdownBlocks(page.data.intro ?? []);
const coreMove = getSection(sections, "the-smallest-useful-move");
const gridSection = getSection(sections, "a-grid-for-seeing-the-space");
const connections = getSection(sections, "what-the-idea-helps-connect");
const navigation = getSection(sections, "how-to-read-the-site");
const methodFamilies = page.data.method_families ?? [];
const readingPaths = page.data.reading_paths ?? [];
const figures = page.data.figures ?? {};
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style is:global>
    .start-page {
      display: grid;
      gap: 2.8rem;
    }
    .start-intro,
    .start-section {
      max-width: var(--measure);
    }
    .start-intro {
      display: grid;
      gap: 1rem;
    }
    .start-intro .intro-block p {
      margin: 0;
      color: var(--muted);
      font-size: 1.02rem;
      line-height: 1.82;
    }
    .start-section h2 {
      margin: 0 0 0.9rem;
      color: var(--fg);
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 2vw, 2.2rem);
      line-height: 1.04;
      letter-spacing: -0.02em;
    }
    .start-section p {
      margin: 0 0 1.1rem;
      color: var(--muted);
      font-size: 1.04rem;
      line-height: 1.86;
    }
    .start-section p:last-child {
      margin-bottom: 0;
    }
    .start-page .mini-grid-wrap {
      display: grid;
      gap: 0.85rem;
      align-items: start;
    }
    .start-page .mini-grid {
      gap: 4px;
      width: fit-content;
    }
    .start-page .mini-corner,
    .start-page .mini-row-label,
    .start-page .mini-col-label,
    .start-page .mini-cell {
      border-radius: 14px;
    }
    .start-page .mini-corner {
      width: 58px;
      height: 42px;
      background: rgba(255, 250, 243, 0.72);
      border: 1px solid var(--border);
    }
    .start-page .mini-col-label {
      min-width: 58px;
      height: 42px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-ui);
      font-size: 0.76rem;
      color: var(--muted);
      background: rgba(255, 250, 243, 0.88);
      border: 1px solid var(--border);
    }
    .start-page .mini-col-label.active {
      color: var(--fg);
      background: rgba(177, 79, 31, 0.12);
      border-color: rgba(177, 79, 31, 0.22);
    }
    .start-page .mini-row-label {
      width: 58px;
      min-height: 46px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 0.9rem;
      font-family: var(--font-ui);
      font-size: 0.76rem;
      color: var(--muted);
      background: rgba(255, 250, 243, 0.88);
      border: 1px solid var(--border);
    }
    .start-page .mini-row-label.active {
      color: var(--fg);
      background: rgba(47, 107, 111, 0.1);
      border-color: rgba(47, 107, 111, 0.22);
    }
    .start-page .mini-cell {
      width: 58px;
      min-height: 46px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      position: relative;
      transition: transform 180ms ease, box-shadow 180ms ease;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    }
    .start-page .mini-cell:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 18px rgba(62, 45, 28, 0.12);
      z-index: 2;
    }
    .start-page .mini-cell.ring-highlight {
      outline: 2px solid var(--ring-thick);
      outline-offset: -3px;
    }
    .start-page .mini-cell.ring-compare {
      outline: 2px solid var(--ring-thin);
      outline-offset: -3px;
    }
    .start-page .mini-cell.selected {
      outline: 2px solid #fff;
      outline-offset: -3px;
    }
    .start-page .mini-val {
      font-family: var(--font-ui);
      font-size: 0.75rem;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    }
    .start-page .mini-caption,
    .start-page .mini-tooltip {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.92rem;
      line-height: 1.6;
    }
    .start-page .mini-tooltip {
      margin-top: 0;
      padding: 0.8rem 0.95rem;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(255, 250, 243, 0.8);
    }
    .family-list {
      list-style: none;
      padding: 0;
      margin: 1.25rem 0 0;
      display: grid;
      gap: 0.15rem;
    }
    .family-item {
      padding: 1rem 0;
      border-top: 1px solid var(--border);
    }
    .family-item:first-child {
      padding-top: 0;
      border-top: 0;
    }
    .family-item h3 {
      margin: 0 0 0.35rem;
      font-family: var(--font-display);
      font-size: 1.24rem;
      line-height: 1.16;
      color: var(--fg);
    }
    .family-item p {
      margin: 0;
      color: var(--muted);
    }
    .start-links {
      margin-top: 1.2rem;
    }
  </style>

  <Nav />

  <main class="page start-page">
    <header class="page-header start-intro">
      {page.data.eyebrow && <span class="page-eyebrow">{page.data.eyebrow}</span>}
      <h1 class="page-title">{page.data.title}</h1>
      {page.data.lede && <p class="page-lede">{page.data.lede}</p>}
      {introBlocks.map((html) => (
        <div class="intro-block" set:html={html}></div>
      ))}
    </header>

    <section class="start-section">
      <h2>{coreMove.title}</h2>
      <div set:html={coreMove.html}></div>

      <div class="essay-figure">
        {figures.leave_one_out?.label && <p class="note-label">{figures.leave_one_out.label}</p>}
        <MiniGrid
          client:load
          rows={["ABCD", "ACD"]}
          cols={["A", "B", "C", "D"]}
          values={[
            [0.92, 0.88, 0.85, 0.82],
            [0.78, 0.55, 0.82, 0.8]
          ]}
          highlightRow={0}
          compareRow={1}
          caption={figures.leave_one_out?.caption}
        />
      </div>
    </section>

    <section class="start-section">
      <h2>{gridSection.title}</h2>
      <div set:html={gridSection.html}></div>

      <div class="essay-figure">
        {figures.grid?.label && <p class="note-label">{figures.grid.label}</p>}
        <MiniGrid
          client:load
          rows={["AB", "ABC", "ABCD", "ACD"]}
          cols={["A", "B", "C", "D"]}
          values={[
            [0.85, 0.72, 0.45, 0.38],
            [0.88, 0.8, 0.75, 0.52],
            [0.92, 0.88, 0.85, 0.82],
            [0.78, 0.55, 0.82, 0.8]
          ]}
          caption={figures.grid?.caption}
        />
      </div>
    </section>

    <section class="start-section">
      <h2>{connections.title}</h2>
      <div set:html={connections.html}></div>

      <ul class="family-list">
        {methodFamilies.map((family) => (
          <li class="family-item">
            <h3>{family.title}</h3>
            <p>{family.body}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="start-section">
      <h2>{navigation.title}</h2>
      <div set:html={navigation.html}></div>

      <ul class="link-cluster start-links">
        {readingPaths.map((path) => (
          <li>
            <a href={path.href}>{path.title}</a>
            {path.body && <p>{path.body}</p>}
          </li>
        ))}
      </ul>
    </section>
  </main>
</Layout>
