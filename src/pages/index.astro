---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import { resolveSources } from "../lib/research-content.js";

const foundationSources = resolveSources(["koh2017", "ghorbani2019", "dwork2006", "hardt2023"]);

const audiencePaths = [
  {
    eyebrow: "For students and newcomers",
    title: "Learn the comparison",
    body: "Start with nearby data worlds, then move from intuition to methods, evidence, and claim boundaries.",
    href: "/learn",
    cta: "Follow the learning path",
  },
  {
    eyebrow: "For researchers",
    title: "Inspect the connections",
    body: "Compare the intervention, estimand, observer, reference standard, and institutional assumptions across fields.",
    href: "/research",
    cta: "Open the research map",
  },
];

const comparisonChecks = [
  { label: "Intervention", value: "Source B is removed from training." },
  { label: "Reference world", value: "The full training set is the baseline." },
  { label: "Held fixed", value: "Evaluation target and training protocol." },
  { label: "Boundary", value: "The contrast alone does not establish privacy, price, or bargaining power." },
];

const consequenceTypes = [
  {
    label: "Training world",
    title: "The training outcome may change.",
    body: "Change what the system learns from, then estimate the effect under a fixed protocol and evaluation target.",
    href: "/examples#source-removal",
  },
  {
    label: "Evaluation world",
    title: "The measurement changes.",
    body: "Keep the model fixed and change the evidence used to judge it.",
    href: "/examples#secure-holdout",
  },
  {
    label: "Governance world",
    title: "The feasible world changes.",
    body: "Change access, provenance, rights, coordination, or trust in the comparison.",
    href: "/examples#collective-withholding",
  },
];

const connectionRows = [
  {
    field: "Influence",
    comparison: "Infinitesimally reweight an example",
    extra: "An objective, differentiability regime, local approximation, and retraining validation",
  },
  {
    field: "Data Shapley",
    comparison: "Add an example across many coalitions",
    extra: "A player set, characteristic function, allocation rule, and approximation scheme",
  },
  {
    field: "Differential privacy",
    comparison: "Compare releases from adjacent datasets",
    extra: "A randomized mechanism and worst-case distributional guarantee",
  },
  {
    field: "Collective action",
    comparison: "Withhold or redirect a data source",
    extra: "Coordination, substitution, rights, incentives, and institutional response",
  },
];

const taskPaths = [
  {
    eyebrow: "For a live question",
    title: "Frame a study",
    body: "Name the data change, outcome, comparison, method family, and the claim you should not make.",
    href: "/frame",
    cta: "Build a working brief",
  },
  {
    eyebrow: "For concrete cases",
    title: "Work before abstracting",
    body: "Start from training, evaluation, governance, privacy, deletion, and adversarial examples.",
    href: "/labs",
    cta: "Open cases and labs",
  },
  {
    eyebrow: "For a class",
    title: "Teach the contrast",
    body: "Use a five-minute orientation, a fifty-minute activity, or a longer reading path.",
    href: "/teach",
    cta: "Open teaching paths",
  },
];
---

<Layout
  title="Data Counterfactuals"
  description="Compare nearby training, evaluation, and governance worlds, then identify the methods, evidence, and assumptions needed to support a conclusion."
>
  <style>
    .home-page {
      display: grid;
      gap: clamp(3.8rem, 7vw, 6.8rem);
      padding-top: clamp(2.1rem, 4vw, 3.8rem);
    }

    .home-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(19rem, 0.62fr);
      gap: clamp(2rem, 6vw, 6.5rem);
      align-items: end;
    }

    .home-hero-copy {
      display: grid;
      gap: 1.25rem;
      min-width: 0;
    }

    .home-kicker,
    .home-section-kicker,
    .home-path-eyebrow,
    .home-world-label,
    .home-consequence-label {
      margin: 0;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.055em;
      text-transform: uppercase;
    }

    .home-title {
      max-width: 11ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(3.2rem, 6.7vw, 5.9rem);
      line-height: 0.92;
      letter-spacing: -0.032em;
    }

    .home-lede {
      max-width: 43rem;
      margin: 0;
      color: var(--muted);
      font-size: clamp(1.16rem, 1.7vw, 1.42rem);
      line-height: 1.7;
    }

    .home-audience-paths {
      display: grid;
      border-top: 1px solid var(--border-strong);
    }

    .home-audience-path {
      display: grid;
      gap: 0.45rem;
      padding: 1.05rem 0;
      border-bottom: 1px solid var(--border);
      color: inherit;
      text-decoration: none;
    }

    .home-audience-path h2 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.35rem, 2.1vw, 1.8rem);
      line-height: 1.08;
    }

    .home-audience-path p {
      margin: 0;
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .home-audience-cta,
    .home-path-cta {
      color: var(--ring-thick);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: 700;
    }

    .home-audience-path:hover h2,
    .home-audience-path:focus-visible h2,
    .home-consequence:hover h3,
    .home-consequence:focus-visible h3,
    .home-path:hover h3,
    .home-path:focus-visible h3 {
      color: var(--ring-thick);
    }

    .home-audience-path:focus-visible,
    .home-consequence:focus-visible,
    .home-path:focus-visible {
      outline: var(--focus-outline);
      outline-offset: 4px;
    }

    .home-section-title {
      max-width: 15ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.7rem);
      line-height: 0.99;
      letter-spacing: -0.015em;
    }

    .home-section-copy {
      max-width: 37rem;
      margin: 0;
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.8;
    }

    .home-comparison {
      display: grid;
      grid-template-columns: minmax(17rem, 0.66fr) minmax(0, 1.34fr);
      gap: clamp(1.8rem, 5vw, 5rem);
      padding-top: 1.35rem;
      border-top: 1px solid var(--border);
    }

    .home-comparison-copy {
      display: grid;
      align-content: start;
      gap: 0.85rem;
    }

    .home-worlds {
      display: grid;
      gap: 1rem;
      min-width: 0;
    }

    .home-world-pair {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 0.7rem;
      align-items: stretch;
    }

    .home-world {
      display: grid;
      gap: 0.8rem;
      padding: clamp(1rem, 2vw, 1.35rem);
      border: 1px solid var(--border);
      background: rgba(255, 250, 243, 0.52);
    }

    .home-world h3 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.45rem, 2.4vw, 2rem);
      line-height: 1.06;
    }

    .home-world dl,
    .home-checks {
      margin: 0;
    }

    .home-world dl {
      display: grid;
      gap: 0.55rem;
    }

    .home-world dl > div {
      display: grid;
      gap: 0.12rem;
      padding-top: 0.55rem;
      border-top: 1px solid var(--border);
    }

    .home-world dt,
    .home-checks dt {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.76rem;
      font-weight: 700;
    }

    .home-world dd,
    .home-checks dd {
      margin: 0;
      color: var(--fg);
      line-height: 1.55;
    }

    .home-world-arrow {
      display: flex;
      align-items: center;
      color: var(--ring-thick);
      font-family: var(--font-ui);
      font-size: 1.3rem;
    }

    .home-contrast {
      margin: 0;
      padding: 0.8rem 1rem;
      border-left: 3px solid rgba(177, 79, 31, 0.42);
      background: rgba(177, 79, 31, 0.06);
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.87rem;
      line-height: 1.6;
    }

    .home-checks {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
    }

    .home-checks > div {
      display: grid;
      gap: 0.25rem;
      min-height: 7.5rem;
      padding: 0.9rem;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .home-consequences,
    .home-tasks {
      display: grid;
      gap: 1.35rem;
    }

    .home-consequence-grid,
    .home-task-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--border);
      background: var(--border);
    }

    .home-consequence,
    .home-path {
      min-height: 15rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding: clamp(1rem, 2.2vw, 1.45rem);
      background: #f7f1e8;
      color: inherit;
      text-decoration: none;
    }

    .home-consequence h3,
    .home-path h3 {
      max-width: 13ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.55rem, 2.6vw, 2.2rem);
      line-height: 1.04;
    }

    .home-consequence p,
    .home-path p {
      margin: 0;
      color: var(--muted);
      line-height: 1.68;
    }

    .home-path-cta {
      margin-top: auto;
    }

    .home-crosswalk {
      display: grid;
      grid-template-columns: minmax(16rem, 0.56fr) minmax(0, 1.44fr);
      gap: clamp(1.8rem, 5vw, 5rem);
      padding: 1.35rem 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .home-crosswalk-intro {
      display: grid;
      align-content: start;
      gap: 0.85rem;
    }

    .home-crosswalk-wrap {
      min-width: 0;
      overflow-x: auto;
    }

    .home-crosswalk-table {
      width: 100%;
      min-width: 42rem;
      border-collapse: collapse;
    }

    .home-crosswalk-table th,
    .home-crosswalk-table td {
      padding: 0.8rem 0.7rem;
      border-top: 1px solid var(--border);
      text-align: left;
      vertical-align: top;
    }

    .home-crosswalk-table th {
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 0.76rem;
    }

    .home-crosswalk-table td {
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.55;
    }

    .home-crosswalk-table td:first-child {
      color: var(--fg);
      font-weight: 700;
    }

    .home-evidence {
      display: grid;
      grid-template-columns: minmax(15rem, 0.58fr) minmax(0, 1.42fr);
      gap: clamp(1.5rem, 5vw, 5rem);
      padding-top: 1.35rem;
      border-top: 1px solid var(--border);
    }

    .home-evidence-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.65rem 1.2rem;
      margin: 1rem 0 0;
      padding: 0;
      list-style: none;
    }

    .home-evidence-list a {
      color: var(--fg);
      font-family: var(--font-ui);
      font-size: 0.86rem;
      line-height: 1.45;
    }

    @media (max-width: 900px) {
      .home-hero,
      .home-comparison,
      .home-crosswalk,
      .home-evidence {
        grid-template-columns: 1fr;
      }

      .home-consequence-grid,
      .home-task-grid {
        grid-template-columns: 1fr;
      }

      .home-consequence,
      .home-path {
        min-height: 0;
      }
    }

    @media (max-width: 620px) {
      .home-title {
        font-size: clamp(2.85rem, 13vw, 4rem);
      }

      .home-world-pair,
      .home-checks,
      .home-evidence-list {
        grid-template-columns: 1fr;
      }

      .home-world-arrow {
        justify-content: center;
        transform: rotate(90deg);
      }
    }
  </style>

  <Nav />

  <main class="page home-page" id="main-content" tabindex="-1">
    <header class="home-hero">
      <div class="home-hero-copy">
        <p class="home-kicker">A field guide to changing data worlds</p>
        <h1 class="home-title">Change the data. What changes downstream?</h1>
        <p class="home-lede">
          Compare nearby training, evaluation, and governance worlds—then identify the methods,
          evidence, and assumptions needed to support a conclusion.
        </p>
        <div class="action-row">
          <a class="btn" href="/frame">Frame a study</a>
        </div>
      </div>

      <nav class="home-audience-paths" aria-label="Choose an audience path">
        {audiencePaths.map((path) => (
          <a class="home-audience-path" href={path.href}>
            <span class="home-path-eyebrow">{path.eyebrow}</span>
            <h2>{path.title}</h2>
            <p>{path.body}</p>
            <span class="home-audience-cta">{path.cta} →</span>
          </a>
        ))}
      </nav>
    </header>

    <section class="home-comparison" aria-labelledby="home-comparison-title">
      <div class="home-comparison-copy">
        <p class="home-section-kicker">The common structure</p>
        <h2 class="home-section-title" id="home-comparison-title">Compare two worlds, carefully.</h2>
        <p class="home-section-copy">
          Hold most things still, change one fact about the data, and ask what happened. The useful
          object is the contrast—and whether the study held enough else fixed for that contrast to
          support the claim.
        </p>
      </div>

      <div class="home-worlds">
        <div class="home-world-pair" aria-label="Illustrative comparison between two training worlds">
          <article class="home-world">
            <p class="home-world-label">Reference world</p>
            <h3>Train on the full set</h3>
            <dl>
              <div><dt>Training</dt><dd>Sources A + B</dd></div>
              <div><dt>Evaluation</dt><dd>Held-out target H</dd></div>
              <div><dt>Illustrative score</dt><dd>0.92</dd></div>
            </dl>
          </article>

          <div class="home-world-arrow" aria-hidden="true">→</div>

          <article class="home-world">
            <p class="home-world-label">Neighboring world</p>
            <h3>Remove source B</h3>
            <dl>
              <div><dt>Training</dt><dd>Source A</dd></div>
              <div><dt>Evaluation</dt><dd>Held-out target H</dd></div>
              <div><dt>Illustrative score</dt><dd>0.83</dd></div>
            </dl>
          </article>
        </div>

        <p class="home-contrast">
          Illustrative contrast: −0.09 on the same evaluation target. This is a toy comparison, not
          an empirical result or a complete causal, privacy, economic, or governance analysis.
        </p>

        <dl class="home-checks">
          {comparisonChecks.map((check) => (
            <div><dt>{check.label}</dt><dd>{check.value}</dd></div>
          ))}
        </dl>
      </div>
    </section>

    <section class="home-consequences" aria-labelledby="home-consequences-title">
      <div>
        <p class="home-section-kicker">Three kinds of consequence</p>
        <h2 class="home-section-title" id="home-consequences-title">Ask what is actually changing.</h2>
      </div>

      <div class="home-consequence-grid">
        {consequenceTypes.map((item) => (
          <a class="home-consequence" href={item.href}>
            <span class="home-consequence-label">{item.label}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <span class="home-path-cta">See a worked case →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="home-crosswalk" aria-labelledby="home-crosswalk-title">
      <div class="home-crosswalk-intro">
        <p class="home-section-kicker">Same scaffold, different estimands</p>
        <h2 class="home-section-title" id="home-crosswalk-title">The comparison exposes the differences.</h2>
        <p class="home-section-copy">
          Neighboring data worlds appear across several fields. What changes is the object being
          estimated and the extra structure required for the comparison to mean anything.
        </p>
        <div class="action-row">
          <a class="btn secondary" href="/research">Explore the synthesis</a>
          <a class="btn ghost" href="/methods">Compare methods</a>
        </div>
      </div>

      <div class="home-crosswalk-wrap">
        <table class="home-crosswalk-table">
          <thead>
            <tr><th>Field</th><th>Nearby-world comparison</th><th>Essential extra structure</th></tr>
          </thead>
          <tbody>
            {connectionRows.map((row) => (
              <tr><td>{row.field}</td><td>{row.comparison}</td><td>{row.extra}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="home-tasks" aria-labelledby="home-tasks-title">
      <div>
        <p class="home-section-kicker">Use the field guide</p>
        <h2 class="home-section-title" id="home-tasks-title">Leave with something usable.</h2>
      </div>

      <div class="home-task-grid">
        {taskPaths.map((path) => (
          <a class="home-path" href={path.href}>
            <span class="home-path-eyebrow">{path.eyebrow}</span>
            <h3>{path.title}</h3>
            <p>{path.body}</p>
            <span class="home-path-cta">{path.cta} →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="home-evidence" aria-labelledby="home-evidence-title">
      <div>
        <p class="home-section-kicker">Evidence discipline</p>
        <h2 class="section-title" id="home-evidence-title">Start with the primary sources.</h2>
      </div>
      <div>
        <p class="home-section-copy">
          The field guide supplies orientation. These papers supply the formal definitions,
          estimands, guarantees, and institutional arguments needed to study each connection.
        </p>
        <ul class="home-evidence-list" aria-label="Foundational sources">
          {foundationSources.map((source) => (
            <li><a href={source.href} target="_blank" rel="noreferrer noopener">{source.short} ↗</a></li>
          ))}
        </ul>
      </div>
    </section>
  </main>
</Layout>
