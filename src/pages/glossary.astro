---
import { render } from "astro:content";
import MemoPage from "../components/MemoPage.astro";
import { GLOSSARY_MEMO_SLUG, getPublicMemoBySlug } from "../lib/memos";

const memo = await getPublicMemoBySlug(GLOSSARY_MEMO_SLUG);

if (!memo) {
  throw new Error(`Missing glossary memo '${GLOSSARY_MEMO_SLUG}'.`);
}

const { Content } = await render(memo);
---

<MemoPage memo={memo} Content={Content} eyebrow="Glossary" />
