---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";

const terms = [
  {
    term: "Data counterfactual",
    definition: "A \"what if\" question about training data. What would happen to model performance if we trained on different data? The grid visualization shows all possible counterfactuals: each row is a possible training set, each column is an evaluation point.",
  },
  {
    term: "Influence function",
    definition: "A technique for estimating how much a single training example affects a model's predictions, without retraining. Approximates what would happen if you removed or upweighted that point.",
  },
  {
    term: "Data Shapley",
    definition: "A method for assigning value to each training point based on its average marginal contribution across all possible subsets. Borrowed from cooperative game theory. Computationally expensive but theoretically principled.",
  },
  {
    term: "Leave-one-out",
    definition: "The simplest data counterfactual: compare performance with and without a single data point. In the grid, this means comparing two rows that differ by exactly one point.",
  },
  {
    term: "Coreset",
    definition: "A small subset of training data that approximates training on the full dataset. The goal is to find a much smaller row in the grid that lands in roughly the same performance region.",
  },
  {
    term: "Data poisoning",
    definition: "Deliberately corrupting training data to cause targeted model failures. Expands the grid dramatically; every possible perturbation creates new rows with potentially different outcomes.",
  },
  {
    term: "Backdoor attack",
    definition: "A type of data poisoning where a trigger pattern causes the model to misclassify inputs containing that trigger, while behaving normally otherwise.",
  },
  {
    term: "Data strike",
    definition: "Coordinated withholding of data by creators to reduce model performance and exert leverage over AI operators. A strategic move to a less favorable row in the grid.",
  },
  {
    term: "Data leverage",
    definition: "The power that data creators have over AI systems by virtue of controlling training data. Leverage depends on how much performance drops when data is withheld or degraded.",
  },
  {
    term: "Scaling law",
    definition: "An empirical relationship describing how model performance changes with data size, model size, or compute. In grid terms, a regression over average performance across rows grouped by size.",
  },
  {
    term: "Differential privacy",
    definition: "A mathematical framework for limiting how much any single data point can affect model outputs. It constrains how far the model can move in the grid when one point changes.",
  },
  {
    term: "Memorization",
    definition: "When a model stores training data too literally rather than learning general patterns. That can enable extraction attacks that recover private examples from model outputs.",
  },
  {
    term: "Machine unlearning",
    definition: "Efficiently updating a model as if a data point was never in the training set, moving from one row to another without full retraining.",
  },
  {
    term: "Active learning",
    definition: "Choosing which data points to label next under a limited labeling budget. In grid language, it is a strategy for deciding which rows become available for training.",
  },
  {
    term: "Data augmentation",
    definition: "Creating synthetic variations of training data such as crops, rotations, or noise. It effectively adds nearby rows to the grid.",
  },
  {
    term: "Curriculum learning",
    definition: "Training on examples in a meaningful order, often from easy to hard. It changes how you move through the grid over time, not just which row you end on.",
  },
  {
    term: "Membership inference",
    definition: "Trying to determine whether a specific example was in a model's training set by exploiting differences between seen and unseen data.",
  },
  {
    term: "Training set",
    definition: "The data used to train a model. In the grid, each row represents one possible training set.",
  },
  {
    term: "Evaluation set",
    definition: "The data used to measure model performance. In the grid, each column represents one possible evaluation point or slice.",
  },
];

const slugify = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
---

<Layout
  title="Glossary"
  description="A practical glossary for the key terms used throughout the Data Counterfactuals site."
>
  <style>
    .glossary-page {
      display: grid;
      gap: 1rem;
    }
    .glossary-tools {
      display: grid;
      gap: 1rem;
    }
    .glossary-search {
      width: 100%;
      min-height: 3rem;
      padding: 0.85rem 1rem;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(255, 250, 243, 0.84);
      color: var(--fg);
      font: inherit;
    }
    .glossary-search::placeholder {
      color: #8b7b6b;
    }
    .glossary-jumps {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
    }
    .glossary-jumps a {
      padding: 0.5rem 0.75rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(255, 250, 243, 0.82);
      color: var(--muted);
      text-decoration: none;
      font-size: 0.88rem;
    }
    .glossary-jumps a:hover {
      color: var(--fg);
      border-color: rgba(177, 79, 31, 0.24);
    }
    .glossary-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.9rem;
    }
    .glossary-item {
      padding: 1.1rem;
      border-radius: 22px;
      background: rgba(255, 250, 243, 0.78);
      border: 1px solid var(--border);
      scroll-margin-top: 6rem;
    }
    .glossary-item h2 {
      margin: 0 0 0.45rem;
      font-size: 1.08rem;
    }
    .glossary-item p {
      margin: 0;
      color: var(--muted);
      line-height: 1.75;
    }
  </style>

  <Nav />

  <main class="page glossary-page">
    <header class="page-header">
      <span class="page-eyebrow">Orientation</span>
      <h1 class="page-title">A working glossary for the site</h1>
      <p class="page-lede">
        Use this when you want a quick definition without leaving the thread of the argument.
        The explanations lean on the grid metaphor whenever it helps, but keep the wording practical.
      </p>
    </header>

    <section class="section-card glossary-tools">
      <div>
        <p class="section-kicker">Find a term fast</p>
        <h2 class="section-title">Search or jump</h2>
      </div>
      <label>
        <span class="sr-only">Search glossary terms</span>
        <input
          class="glossary-search"
          type="search"
          placeholder="Search terms like Shapley, poisoning, leverage, or privacy"
          data-glossary-search
        />
      </label>
      <div class="page-meta">
        <span class="pill" data-glossary-count>{terms.length} terms</span>
      </div>
      <nav class="glossary-jumps" aria-label="Jump to a term">
        {terms.map((term) => (
          <a href={`#${slugify(term.term)}`}>{term.term}</a>
        ))}
      </nav>
    </section>

    <section class="section-card">
      <ul class="glossary-list">
        {terms.map((term) => (
          <li
            class="glossary-item"
            id={slugify(term.term)}
            data-glossary-item
            data-search={`${term.term} ${term.definition}`.toLowerCase()}
          >
            <h2>{term.term}</h2>
            <p>{term.definition}</p>
          </li>
        ))}
      </ul>

      <div class="empty-state" data-glossary-empty hidden>No terms match that search yet.</div>
    </section>
  </main>

  <script>
    const searchInput = document.querySelector<HTMLInputElement>("[data-glossary-search]");
    const countPill = document.querySelector<HTMLElement>("[data-glossary-count]");
    const emptyState = document.querySelector<HTMLElement>("[data-glossary-empty]");
    const items = Array.from(document.querySelectorAll<HTMLElement>("[data-glossary-item]"));

    const updateGlossary = () => {
      if (!searchInput || !countPill || !emptyState) return;

      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      items.forEach((item) => {
        const haystack = item.dataset.search || "";
        const matches = !query || haystack.includes(query);
        item.hidden = !matches;
        if (matches) visibleCount += 1;
      });

      countPill.textContent = `${visibleCount} term${visibleCount === 1 ? "" : "s"}`;
      emptyState.hidden = visibleCount !== 0;
    };

    if (searchInput) {
      searchInput.addEventListener("input", updateGlossary);
      updateGlossary();
    }
  </script>
</Layout>
