---
import Layout from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import { marked } from "marked";
import { loadMemos } from "../../lib/content-loader";
import networkData from "../../data/network.json";

export async function getStaticPaths() {
  const memos = await loadMemos();
  return memos
    .filter((memo) => memo.slug !== "data-counterfactuals")
    .map((memo) => ({
      params: { slug: memo.slug },
      props: { memo, memos }
    }));
}

const { memo, memos } = Astro.props;
const memoMeta = memo ? { title: memo.title, summary: memo.summary } : { title: "Memo" };
const memoBody = memo?.body ?? "";
const memoHtml = marked.parse(memoBody);
const githubUrl = networkData.links?.github;
const wordCount = memoBody.split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.round(wordCount / 220));
const memoHref = (slug: string) => slug === "data-counterfactuals" ? "/memo" : `/memo/${slug}`;
const otherMemos = (memos ?? []).filter((otherMemo: { slug: string }) => otherMemo.slug !== memo?.slug);
---

<Layout
  title={memoMeta.title}
  description={memoMeta.summary || "An additional memo in the Data Counterfactuals project."}
>
  <style>
    .memo-page {
      gap: 2.75rem;
    }
    .memo-page .page-header {
      margin-bottom: 0;
    }
    .memo-article {
      padding-top: 0.25rem;
    }
  </style>

  <Nav />

  <main class="page essay-page memo-page">
    <header class="essay-header page-header">
      <div>
        <span class="page-eyebrow">Working memo</span>
        <h1 class="page-title">{memoMeta.title}</h1>
        {memoMeta.summary && <p class="page-lede">{memoMeta.summary}</p>}
        <div class="page-meta">
          <span class="pill">{readMinutes} minute read</span>
          <span class="pill">{wordCount} words</span>
        </div>
      </div>

      <aside class="essay-side">
        <p class="note-label">How this page fits</p>
        <p>
          This is an additional memo in the same project. The main memo introduces the broad concept; this page follows one
          narrower thread further.
        </p>
        <ul>
          <li><a href="/memo">Return to the main memo</a></li>
          <li><a href="/">Return to the overview</a></li>
          <li><a href="/collections">Browse the related literatures</a></li>
          {githubUrl && <li><a href={githubUrl}>View the source on GitHub</a></li>}
        </ul>
        {otherMemos.length > 0 && (
          <>
            <p class="note-label">Other memos</p>
            <ul>
              {otherMemos.map((otherMemo: { slug: string; title: string }) => (
                <li><a href={memoHref(otherMemo.slug)}>{otherMemo.title}</a></li>
              ))}
            </ul>
          </>
        )}
      </aside>
    </header>

    <section class="essay-section">
      <article class="essay-main prose memo-article" set:html={memoHtml}></article>

      <aside class="essay-side">
        <p class="note-label">Draft note</p>
        <p>
          This memo is meant to line up neighboring formalisms rather than settle notation. Where the literature uses different
          symbols, I have preferred a common schematic template over paper-specific typography.
        </p>
      </aside>
    </section>
  </main>
</Layout>
