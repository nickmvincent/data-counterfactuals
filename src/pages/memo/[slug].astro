---
import { render } from "astro:content";
import MemoPage from "../../components/MemoPage.astro";
import { getPublicMemoBySlug, getPublicMemos, hasDirectMemoRoute } from "../../lib/memos";

export async function getStaticPaths() {
  const memos = await getPublicMemos();

  return memos
    .filter((memo) => !hasDirectMemoRoute(memo.slug))
    .map((memo) => ({
      params: { slug: memo.slug },
    }));
}

const slug = Astro.params.slug;
if (!slug) {
  throw new Error("Missing memo slug.");
}

const memo = await getPublicMemoBySlug(slug);

if (!memo) {
  throw new Error(`Missing memo '${slug}'.`);
}

const { Content } = await render(memo);
---

<MemoPage memo={memo} Content={Content} />
