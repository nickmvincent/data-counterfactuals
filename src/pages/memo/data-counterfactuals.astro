---
import MemoPage from "../../components/MemoPage.astro";
import { LAUNCH_MEMO_SLUG, getPublicMemoBySlug } from "../../lib/memos";

const memo = await getPublicMemoBySlug(LAUNCH_MEMO_SLUG);

if (!memo) {
  throw new Error(`Missing launch memo '${LAUNCH_MEMO_SLUG}'.`);
}
---

<MemoPage memo={memo} />
