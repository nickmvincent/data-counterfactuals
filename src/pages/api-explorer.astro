---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import ApiExplorerComponent from "../components/ApiExplorer.jsx";
import { getRequiredPageEntry, splitMarkdownSections } from "../lib/page-content";

const page = await getRequiredPageEntry("api-explorer");
const sections = splitMarkdownSections(page.body);
const introSection = sections[0];
---

<Layout title={page.data.title} description={page.data.description}>
  <style is:global>
    body:has(.api-page) {
      background: #f7f1e8;
    }
    .api-page {
      display: grid;
      gap: 1.15rem;
    }
    .api-page .page-header {
      margin-bottom: 0;
      display: grid;
      grid-template-columns: minmax(18rem, 0.8fr) minmax(0, 1.2fr);
      gap: 1.25rem;
      align-items: start;
    }
    .api-read-note {
      display: grid;
      gap: 0.35rem;
      padding: 0 0 0 1rem;
      border-left: 2px solid rgba(47, 107, 111, 0.28);
      background: transparent;
      box-shadow: none;
    }
    .api-read-note-label,
    .api-shell .api-summary-label {
      color: #24566e;
      font-family: var(--font-body);
      font-size: 0.92rem;
      font-weight: 600;
      letter-spacing: 0;
      text-transform: none;
    }
    .api-read-note :where(p) {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }
    .api-signpost {
      display: grid;
      grid-template-columns: minmax(15rem, 0.7fr) minmax(0, 1.3fr);
      gap: 1rem 1.25rem;
      padding: 1rem 0;
      border-top: 1px solid rgba(92, 72, 52, 0.14);
      border-bottom: 1px solid rgba(92, 72, 52, 0.14);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }
    .api-signpost-head {
      display: grid;
      gap: 0.35rem;
    }
    .api-signpost-title {
      margin: 0;
      color: #10273d;
      font-family: var(--font-ui);
      font-size: clamp(1.08rem, 2vw, 1.4rem);
      font-weight: 650;
      line-height: 1.18;
      letter-spacing: 0;
    }
    .api-signpost-copy {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
      max-width: 70rem;
    }
    .api-signpost-grid {
      display: grid;
      gap: 0.7rem;
      grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    }
    .api-signpost-card {
      display: grid;
      grid-template-columns: 1.7rem minmax(0, 1fr);
      gap: 0.22rem 0.65rem;
      padding: 0;
      border-radius: 0;
      border: 0;
      background: transparent;
    }
    .api-signpost-number {
      width: 1.7rem;
      height: 1.7rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 4px;
      border: 1px solid rgba(47, 92, 126, 0.18);
      background: rgba(47, 92, 126, 0.08);
      color: #2f5c7e;
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 700;
      line-height: 1;
    }
    .api-signpost-card h3 {
      margin: 0;
      color: #10273d;
      font-family: var(--font-ui);
      font-size: 0.94rem;
      font-weight: 650;
      line-height: 1.35;
    }
    .api-signpost-card p {
      grid-column: 2;
      margin: 0;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.62;
    }
    .api-frame {
      padding: 0;
      background: transparent;
    }
    .api-shell {
      --api-surface: rgba(255, 250, 243, 0.72);
      --api-surface-strong: #fffaf2;
      --api-surface-soft: rgba(237, 228, 215, 0.82);
      --api-border: rgba(92, 72, 52, 0.15);
      --api-border-strong: rgba(92, 72, 52, 0.3);
      --api-fg: #10273d;
      --api-muted: #5d7083;
      --api-accent: #2f5c7e;
      --api-accent-soft: rgba(47, 92, 126, 0.1);
      --api-warning: rgba(177, 79, 31, 0.14);
      --api-radius-xl: 6px;
      --api-radius-lg: 6px;
      --api-radius-md: 4px;
      --api-radius-sm: 4px;
      font-family: var(--font-ui);
    }
    .api-shell .api-explorer,
    .api-shell .api-main-grid,
    .api-shell .api-side-rail,
    .api-shell .api-panel-card,
    .api-shell .api-panel-head,
    .api-shell .api-action-row,
    .api-shell .api-summary-grid,
    .api-shell .api-field-groups,
    .api-shell .api-field-group ul,
    .api-shell .api-notes,
    .api-shell .api-example-bank {
      display: grid;
      gap: 0.95rem;
    }
    .api-shell .api-hero-card,
    .api-shell .api-panel-card {
      padding: 1.05rem 0;
      border-radius: var(--api-radius-xl);
      border: 0;
      border-top: 1px solid var(--api-border);
      background: transparent;
      box-shadow: none;
      position: relative;
      overflow: clip;
      isolation: isolate;
    }
    .api-shell .api-hero-card {
      display: grid;
      grid-template-columns: minmax(15rem, 0.72fr) minmax(0, 1.28fr);
      gap: 0.9rem 1rem;
      align-items: start;
      padding-top: 0.95rem;
    }
    .api-shell .api-title,
    .api-shell .api-panel-title {
      margin: 0;
      color: var(--api-fg);
      font-size: clamp(1.05rem, 2vw, 1.35rem);
      line-height: 1.2;
      letter-spacing: 0;
    }
    .api-shell .api-copy,
    .api-shell .api-panel-copy,
    .api-shell .api-inline-note,
    .api-shell .api-notes p,
    .api-shell .api-field-group li span {
      margin: 0;
      color: var(--api-muted);
      line-height: 1.62;
    }
    .api-shell .api-main-grid {
      grid-template-columns: minmax(0, 1.36fr) minmax(17rem, 0.64fr);
      align-items: start;
      gap: 1.3rem;
    }
    .api-shell .api-panel-head {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
    }
    .api-shell .api-action-row {
      grid-auto-flow: column;
      grid-auto-columns: max-content;
      align-content: start;
    }
    .api-shell .api-example-bank {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.48rem;
    }
    .api-shell .api-btn,
    .api-shell .api-example-button {
      appearance: none;
      border: 1px solid var(--api-border);
      border-radius: var(--api-radius-sm);
      padding: 0.58rem 0.8rem;
      background: var(--api-surface-strong);
      color: var(--api-fg);
      font: inherit;
      font-size: 0.88rem;
      cursor: pointer;
      transition: border-color 160ms ease, box-shadow 160ms ease;
    }
    .api-shell .api-example-button {
      display: grid;
      gap: 0.18rem;
      text-align: left;
      align-content: start;
      min-height: 4.7rem;
    }
    .api-shell .api-example-title {
      font-size: 0.88rem;
      font-weight: 700;
      line-height: 1.25;
    }
    .api-shell .api-example-desc {
      color: var(--api-muted);
      font-size: 0.76rem;
      line-height: 1.42;
    }
    .api-shell .api-btn:hover,
    .api-shell .api-btn:focus-visible,
    .api-shell .api-example-button:hover,
    .api-shell .api-example-button:focus-visible {
      border-color: var(--api-border-strong);
      box-shadow: none;
    }
    .api-shell .api-btn.secondary {
      background: rgba(255, 255, 255, 0.78);
      color: var(--api-muted);
    }
    .api-shell .api-example-button[aria-pressed="true"] {
      border-color: rgba(47, 92, 126, 0.28);
      background: var(--api-accent-soft);
      color: var(--api-accent);
      font-weight: 700;
    }
    .api-shell .api-summary-grid {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      grid-column: 1 / -1;
      padding-top: 0.8rem;
      border-top: 1px solid rgba(92, 72, 52, 0.12);
    }
    .api-shell .api-summary-card {
      display: grid;
      gap: 0.28rem;
      padding: 0;
      border-radius: 0;
      border: 0;
      background: transparent;
    }
    .api-shell .api-summary-value {
      color: var(--api-fg);
      font-size: 0.98rem;
      font-weight: 650;
      line-height: 1.35;
    }
    .api-shell .api-editor-label {
      display: block;
    }
    .api-shell .api-editor,
    .api-shell .api-response {
      width: 100%;
      margin: 0;
      padding: 1rem;
      border-radius: var(--api-radius-lg);
      border: 1px solid rgba(33, 65, 95, 0.12);
      background: #fffdf8;
      color: var(--api-fg);
      font-family: "SFMono-Regular", "SF Mono", "IBM Plex Mono", "Menlo", "Consolas", monospace;
      font-size: 0.84rem;
      line-height: 1.65;
      white-space: pre;
      overflow: auto;
      box-shadow: none;
    }
    .api-shell .api-editor {
      min-height: 19rem;
      resize: vertical;
    }
    .api-shell .api-response {
      min-height: 18rem;
      max-height: 34rem;
    }
    .api-shell .api-inline-note,
    .api-shell .api-error {
      padding: 0.8rem 0.9rem;
      border-radius: var(--api-radius-md);
      border: 1px solid rgba(33, 65, 95, 0.1);
      background: rgba(255, 255, 255, 0.66);
    }
    .api-shell .api-error {
      border-color: rgba(177, 79, 31, 0.18);
      background: var(--api-warning);
      color: #7a3919;
    }
    .api-shell .api-field-group h4 {
      margin: 0;
      color: var(--api-fg);
      font-size: 0.9rem;
      font-weight: 700;
    }
    .api-shell .api-field-group ul {
      list-style: none;
      padding: 0;
      margin: 0;
      border-top: 1px solid rgba(92, 72, 52, 0.11);
    }
    .api-shell .api-field-group li {
      display: grid;
      gap: 0.22rem;
      padding: 0.7rem 0;
      border-radius: 0;
      border: 0;
      border-bottom: 1px solid rgba(92, 72, 52, 0.11);
      background: transparent;
    }
    .api-shell .api-field-group li strong {
      color: var(--api-fg);
      font-size: 0.88rem;
    }
    .api-shell .api-field-group li code,
    .api-shell .api-copy code,
    .api-shell .api-panel-copy code,
    .api-shell .api-notes code {
      width: fit-content;
      padding: 0.08rem 0.28rem;
      border-radius: 3px;
      background: rgba(47, 107, 111, 0.08);
      color: var(--api-accent);
      font-size: 0.8rem;
    }
    .api-shell .api-response-card {
      gap: 1rem;
    }
    @media (max-width: 1100px) {
      .api-shell .api-main-grid {
        grid-template-columns: 1fr;
      }
      .api-shell .api-side-rail {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 860px) {
      .api-page .page-header {
        grid-template-columns: 1fr;
      }
      .api-read-note {
        padding: 0;
        border-left: 0;
      }
      .api-signpost,
      .api-shell .api-hero-card {
        grid-template-columns: 1fr;
      }
      .api-signpost-grid {
        grid-template-columns: 1fr;
      }
      .api-shell .api-example-bank,
      .api-shell .api-side-rail {
        grid-template-columns: 1fr;
      }
      .api-shell .api-panel-head {
        grid-template-columns: 1fr;
      }
      .api-shell .api-action-row {
        grid-auto-flow: row;
        grid-auto-columns: 1fr;
      }
      .api-shell .api-btn,
      .api-shell .api-example-button {
        width: 100%;
      }
      .api-shell .api-editor,
      .api-shell .api-response {
        min-height: 20rem;
      }
    }
  </style>

  <Nav />

  <main class="page essay-page api-page" id="main-content" tabindex="-1">
    <header class="essay-header page-header">
      <div>
        <h1 class="page-title">{page.data.title}</h1>
      </div>
      {introSection && (
        <div class="api-read-note">
          <span class="api-read-note-label">{introSection.title}</span>
          <div set:html={introSection.html}></div>
        </div>
      )}
    </header>

    <section class="api-signpost" aria-label="How to use the API explorer">
      <div class="api-signpost-head">
        <h2 class="api-signpost-title">Paste state in, inspect JSON out.</h2>
        <p class="api-signpost-copy">Use the same inputs as the explorers, but type them directly.</p>
      </div>

      <div class="api-signpost-grid">
        <div class="api-signpost-card">
          <span class="api-signpost-number">1</span>
          <h3>Load an example</h3>
          <p>Start with a matrix, cell, or answer template.</p>
        </div>
        <div class="api-signpost-card">
          <span class="api-signpost-number">2</span>
          <h3>Edit the state</h3>
          <p>Change count, metric, subsets, or lens settings.</p>
        </div>
        <div class="api-signpost-card">
          <span class="api-signpost-number">3</span>
          <h3>Read the response</h3>
          <p>Check the resolved state and returned result.</p>
        </div>
      </div>
    </section>

    <section class="section-card api-frame" aria-label="API explorer">
      <div class="api-shell">
        <ApiExplorerComponent client:load />
      </div>
    </section>
  </main>
</Layout>
