---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import CourseNav from "../components/CourseNav.astro";
import { resolveSources, scenarioExamples } from "../lib/research-content.js";

const courseModuleByExample: Record<string, string> = {
  "source-removal": "02",
  "privacy-neighbor": "05",
  "collective-withholding": "06",
};
---

<Layout
  title="Examples"
  description="Concrete examples of training, evaluation, governance, privacy, unlearning, and poisoning counterfactuals."
>
  <style>
    .examples-page { display:grid; gap:3rem; padding-top:clamp(2rem,4vw,3.8rem); }
    .examples-header { max-width:52rem; margin:0; }
    .examples-title { font-size:clamp(2.7rem,5.4vw,4.9rem); letter-spacing:-.025em; }
    .examples-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); border-top:1px solid var(--border-strong); }
    .example-card { scroll-margin-top:6rem; display:grid; align-content:start; gap:1rem; padding:clamp(1.2rem,2.5vw,2rem); border-bottom:1px solid var(--border); }
    .example-card:nth-child(odd) { border-right:1px solid var(--border); padding-left:0; }
    .example-card:nth-child(even) { padding-right:0; }
    .example-eyebrow { margin:0; color:var(--ring-thin); font:700 .77rem/1.3 var(--font-ui); letter-spacing:.055em; text-transform:uppercase; }
    .example-card h2 { max-width:17ch; margin:0; font-family:var(--font-display); font-size:clamp(1.75rem,3vw,2.55rem); line-height:1.02; }
    .example-summary { margin:0; color:var(--muted); font-size:1.06rem; line-height:1.75; }
    .example-details { display:grid; margin:0; border-top:1px solid var(--border); }
    .example-details > div { display:grid; grid-template-columns:7rem minmax(0,1fr); gap:.8rem; padding:.7rem 0; border-bottom:1px solid var(--border); }
    .example-details dt { color:var(--muted); font:700 .77rem/1.5 var(--font-ui); }
    .example-details dd { margin:0; color:var(--muted); line-height:1.6; }
    .example-limit { margin:0; padding:.85rem; border-left:3px solid rgba(177,79,31,.38); background:rgba(177,79,31,.05); color:var(--muted); line-height:1.65; }
    .example-sources { display:flex; flex-wrap:wrap; gap:.35rem .75rem; margin:0; padding:0; list-style:none; }
    .example-sources a { color:var(--fg); font:600 .8rem/1.5 var(--font-ui); }
    .examples-cta { display:flex; flex-wrap:wrap; gap:.8rem; align-items:center; padding-top:1.2rem; border-top:1px solid var(--border); }
    @media (max-width:800px) { .examples-grid { grid-template-columns:1fr; } .example-card, .example-card:nth-child(odd), .example-card:nth-child(even) { padding:1.35rem 0; border-right:0; } }
    @media (max-width:520px) { .example-details > div { grid-template-columns:1fr; gap:.2rem; } }
  </style>

  <Nav />
  <main class="page examples-page" id="main-content" tabindex="-1">
    <header class="page-header examples-header">
      <h1 class="page-title examples-title">Examples before abstractions.</h1>
      <p class="page-lede">
        Each case names the move, a defensible measurement plan, and the boundary between what the
        comparison can show and what it cannot establish on its own.
      </p>
    </header>

    <div class="examples-grid">
      {scenarioExamples.map((example) => {
        const exampleSources = resolveSources(example.sourceIds);
        return (
          <article class="example-card" id={example.id}>
            <p class="example-eyebrow">{example.eyebrow}</p>
            <h2>{example.title}</h2>
            <p class="example-summary">{example.summary}</p>
            <dl class="example-details">
              <div><dt>Grid move</dt><dd>{example.move}</dd></div>
              <div><dt>Measure</dt><dd>{example.measure}</dd></div>
              <div><dt>Method</dt><dd>{example.method}</dd></div>
            </dl>
            <p class="example-limit"><strong>Do not overclaim:</strong> {example.limit}</p>
            <ul class="example-sources" aria-label={`Sources for ${example.title}`}>
              {exampleSources.map((source) => (
                <li><a href={source.href} target="_blank" rel="noreferrer noopener" title={source.title}>{source.short} ↗</a></li>
              ))}
            </ul>
            {courseModuleByExample[example.id] && (
              <CourseNav currentId={courseModuleByExample[example.id]} compact />
            )}
          </article>
        );
      })}
    </div>

    <div class="examples-cta">
      <a class="btn" href="/frame">Frame your own question</a>
      <a class="btn ghost" href="/methods">Compare method families</a>
    </div>
  </main>
</Layout>
