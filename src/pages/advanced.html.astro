---
import Nav from "../components/Nav.astro";
import AdvancedViewer from "../components/AdvancedViewer.jsx";
import Layout from "../layouts/Base.astro";
---

<Layout
  title="3D Viewer"
  description="A heavier 3D prototype for exploring training rosters, evaluation worlds, and operator reveal mechanics."
>
  <style is:global>
    .advanced-page {
      width: min(1380px, calc(100% - 1rem));
      margin: 0 auto 2rem;
      padding-top: 1rem;
    }
    .advanced-viewer-shell {
      --bg: #f7f1e8;
      --fg: #201a16;
      --muted: #655a4f;
      --card: #fffaf2;
      --border: rgba(92, 72, 52, 0.16);
      --accent: #2f6b6f;
      --accent-warm: #b14f1f;
      --accent-hot: #9f3f2d;
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
      overflow: visible;
    }
    .advanced-viewer-shell * {
      box-sizing: border-box;
    }
    .advanced-viewer-shell .wrap {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0;
      color: var(--fg);
    }
    .advanced-viewer-shell a {
      color: var(--accent);
    }
    .advanced-viewer-shell header {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-start;
      gap: 16px;
      justify-content: space-between;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border);
    }
    .advanced-viewer-shell h1 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(2rem, 3.4vw, 3rem);
      line-height: 1.04;
      color: var(--fg);
    }
    .advanced-viewer-shell h2 {
      margin: 0 0 8px;
      font-family: var(--font-display);
      font-size: 1.28rem;
      line-height: 1.18;
      color: var(--fg);
    }
    .advanced-viewer-shell h3 {
      margin: 0 0 6px;
      font-size: 16px;
      color: var(--fg);
    }
    .advanced-viewer-shell p {
      line-height: 1.5;
      margin: 6px 0;
      color: var(--fg);
    }
    .advanced-viewer-shell strong {
      color: var(--fg);
    }
    .advanced-viewer-shell .lede {
      color: var(--muted);
      max-width: 62ch;
      line-height: 1.72;
      font-size: 1.05rem;
    }
    .advanced-viewer-shell .advanced-meta {
      display: grid;
      gap: 0.3rem;
      justify-items: end;
      color: var(--muted);
    }
    .advanced-viewer-shell .pill {
      display: inline;
      gap: 6px;
      padding: 0;
      border-radius: 0;
      background: transparent;
      border: 0;
      font-size: 13px;
      color: var(--muted);
    }
    .advanced-viewer-shell .advanced-meta .pill + .pill::before {
      content: "/";
      margin-right: 0.5rem;
      color: rgba(101, 90, 79, 0.52);
    }
    .advanced-viewer-shell .layout {
      display: grid;
      grid-template-columns: minmax(17rem, 20rem) minmax(0, 1fr);
      gap: clamp(1rem, 2.2vw, 1.7rem);
      margin-top: 1.1rem;
      align-items: start;
    }
    .advanced-viewer-shell .advanced-controls,
    .advanced-viewer-shell .advanced-figures {
      display: grid;
      gap: 0;
      min-width: 0;
    }
    .advanced-viewer-shell .board-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 14px;
    }
    .advanced-viewer-shell .card {
      background: rgba(255, 250, 243, 0.72);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 15px;
      box-shadow: none;
      margin-bottom: 14px;
    }
    .advanced-viewer-shell .advanced-controls .card {
      padding: 0.95rem 0;
      margin: 0;
      border-width: 1px 0 0;
      border-radius: 0;
      background: transparent;
    }
    .advanced-viewer-shell .advanced-controls .card:first-child {
      border-top: 0;
      padding-top: 0;
    }
    .advanced-viewer-shell .advanced-figures > .card,
    .advanced-viewer-shell .board-grid .card {
      background: #fffaf2;
    }
    .advanced-viewer-shell .board-grid .card {
      border-color: rgba(47, 107, 111, 0.24);
      border-top: 2px solid rgba(47, 107, 111, 0.32);
    }
    .advanced-viewer-shell .ctrl-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }
    .advanced-viewer-shell .btn {
      border: 1px solid var(--border);
      background: rgba(255, 250, 243, 0.72);
      color: var(--fg);
      border-radius: 4px;
      padding: 6px 12px;
      cursor: pointer;
      font-size: 13px;
      transition: background 0.15s ease;
    }
    .advanced-viewer-shell .btn:hover:not(:disabled) {
      background: rgba(177, 79, 31, 0.08);
    }
    .advanced-viewer-shell .btn[aria-pressed="true"] {
      outline: 2px solid var(--accent);
      outline-offset: 1px;
      background: rgba(47, 107, 111, 0.08);
    }
    .advanced-viewer-shell .btn:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }
    .advanced-viewer-shell select,
    .advanced-viewer-shell input {
      font: inherit;
      border-radius: 4px;
      border: 1px solid var(--border);
      background: var(--surface-strong);
      color: var(--fg);
    }
    .advanced-viewer-shell .metrics-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 8px;
      margin-top: 10px;
    }
    .advanced-viewer-shell .metric-pill {
      padding: 10px;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: transparent;
    }
    .advanced-viewer-shell .metric-pill span {
      display: block;
      font-size: 11px;
      color: var(--muted);
      text-transform: none;
      letter-spacing: 0;
    }
    .advanced-viewer-shell .metric-pill strong {
      font-size: 18px;
    }
    .advanced-viewer-shell table.confusion {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      margin-top: 8px;
    }
    .advanced-viewer-shell table.confusion th,
    .advanced-viewer-shell table.confusion td {
      border: 1px solid var(--border);
      padding: 6px;
      text-align: center;
    }
    .advanced-viewer-shell .scene-shell {
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
      background: #f1ece3;
      min-height: 420px;
    }
    .advanced-viewer-shell .scene-shell canvas {
      width: 100%;
      height: 100%;
      display: block;
    }
    .advanced-viewer-shell .scatter-card {
      margin-top: 14px;
    }
    .advanced-viewer-shell .scatter-card canvas {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: #f1ece3;
    }
    .advanced-viewer-shell .scatter-title {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 4px;
    }
    .advanced-viewer-shell .legend {
      font-size: 12px;
      color: var(--muted);
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 6px;
    }
    .advanced-viewer-shell .legend span {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .advanced-viewer-shell .legend i {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
    }
    .advanced-viewer-shell .log {
      font-size: 13px;
      color: var(--muted);
      margin-top: 8px;
      line-height: 1.5;
    }
    .advanced-viewer-shell .row-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }
    .advanced-viewer-shell .row-badge {
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 8px 10px;
      font-size: 13px;
      display: flex;
      flex-direction: column;
      gap: 2px;
      background: transparent;
      min-width: 140px;
    }
    .advanced-viewer-shell .row-badge.revealed {
      border-color: rgba(47, 107, 111, 0.34);
      background: rgba(47, 107, 111, 0.06);
    }
    .advanced-viewer-shell .row-badge header {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
    }
    .advanced-viewer-shell .row-badge button {
      font-size: 11px;
      padding: 4px 8px;
      border-radius: 4px;
    }
    .advanced-viewer-shell .operator-log {
      font-size: 13px;
      color: var(--muted);
      max-height: 140px;
      overflow: auto;
      margin-top: 10px;
      padding-left: 18px;
    }
    .advanced-viewer-shell .board-note {
      font-size: 12px;
      color: var(--muted);
      margin-top: 6px;
    }
    @media (max-width: 1020px) {
      .advanced-page {
        width: min(100%, calc(100% - 0.5rem));
      }
      .advanced-viewer-shell {
        border-radius: 6px;
      }
      .advanced-viewer-shell .layout {
        grid-template-columns: 1fr;
      }
      .advanced-viewer-shell .advanced-meta {
        justify-items: start;
      }
    }
  </style>

  <Nav />

  <main class="advanced-page" id="main-content" tabindex="-1">
    <section class="advanced-viewer-shell">
      <AdvancedViewer client:load />
    </section>
  </main>
</Layout>
