---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Explorer from "../components/Explorer.jsx";
import { getRequiredPageEntry, getSection, renderMarkdownBlocks, splitMarkdownSections } from "../lib/page-content";

const page = await getRequiredPageEntry("grid");
const sections = splitMarkdownSections(page.body);
const introSection = getSection(sections, "how-to-read-the-toy");
const quickTips = page.data.quick_tips ?? [];
const companionLinks = page.data.companion_links ?? [];
const headerNote = page.data.notes?.header;
const companionNote = page.data.notes?.companions;
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style is:global>
    .explorer-page {
      display: grid;
      gap: 2.7rem;
    }
    .explorer-page .page-header {
      margin-bottom: 0;
    }
    .tip-list {
      margin: 1rem 0 0;
      padding-left: 1.2rem;
      display: grid;
      gap: 0.65rem;
    }
    .tip-list li {
      padding: 0;
      color: var(--muted);
      line-height: 1.82;
    }
    .explorer-link-list {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
    }
    .explorer-frame {
      padding: 0.35rem;
      background:
        linear-gradient(180deg, rgba(34, 29, 25, 0.08), rgba(34, 29, 25, 0.02)),
        rgba(255, 250, 243, 0.56);
    }
    .explorer-shell {
      --explorer-bg: #181516;
      --explorer-panel: #121519;
      --explorer-card: #1b2027;
      --explorer-card-soft: #232833;
      --explorer-border: #313948;
      --explorer-fg: #f6f0e8;
      --explorer-muted: #b8aea5;
      --ring-thin: #efb463;
      --ring-thick: #68c6c1;
      --ring-select: #fffaf0;
      --grid-axis-w: 74px;
      --grid-cell-w: 46px;
    }
    .explorer-shell .wrap {
      max-width: 1250px;
      margin: 0 auto;
      padding: 16px;
    }
    .explorer-shell .section {
      margin: 14px auto;
    }
    .explorer-shell .lede {
      color: var(--explorer-muted);
      margin: 6px 0 16px;
      max-width: 70ch;
    }
    .explorer-shell .card {
      background: var(--explorer-card);
      border: 1px solid var(--explorer-border);
      border-radius: 18px;
      padding: 12px;
      margin-bottom: 12px;
      color: var(--explorer-fg);
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
    }
    .explorer-shell .row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 12px;
    }
    .explorer-shell .ctrl {
      display: flex;
      align-items: center;
      gap: 8px;
      margin: 6px 0 10px;
      flex-wrap: wrap;
    }
    .explorer-shell .btn {
      border: 1px solid var(--explorer-border);
      background: #202632;
      color: var(--explorer-fg);
      padding: 6px 10px;
      border-radius: 10px;
      cursor: pointer;
      font-size: 12px;
      box-shadow: none;
      min-height: auto;
    }
    .explorer-shell .btn[aria-pressed="true"] {
      outline: 2px solid rgba(104, 198, 193, 0.55);
    }
    .explorer-shell .btn.ghost {
      background: transparent;
    }
    .explorer-shell input[type="range"],
    .explorer-shell select,
    .explorer-shell input[type="checkbox"] {
      background: #1a1f28;
      color: var(--explorer-fg);
      border: 1px solid var(--explorer-border);
      border-radius: 10px;
      padding: 6px 10px;
    }
    .explorer-shell .grid-wrap {
      overflow: auto;
      border: 1px solid var(--explorer-border);
      border-radius: 16px;
      background: #0e1218;
      max-width: 100%;
      scrollbar-gutter: stable both-edges;
    }
    .explorer-shell .rl,
    .explorer-shell .cl,
    .explorer-shell .cell {
      border-bottom: 1px solid #2d3342;
      border-right: 1px solid #2d3342;
    }
    .explorer-shell .rl {
      width: var(--grid-axis-w);
      min-width: var(--grid-axis-w);
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 6px;
      font-size: 11px;
      cursor: pointer;
      position: sticky;
      left: 0;
      background: var(--explorer-card);
      z-index: 2;
      transition: background 0.2s ease, color 0.2s ease;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .explorer-shell .cl {
      width: var(--grid-cell-w);
      min-width: var(--grid-cell-w);
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      cursor: pointer;
      position: sticky;
      top: 0;
      background: var(--explorer-card);
      z-index: 3;
      transition: background 0.2s ease, color 0.2s ease;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      padding: 0 4px;
      font-variant-numeric: tabular-nums;
    }
    .explorer-shell .cell {
      width: var(--grid-cell-w);
      min-width: var(--grid-cell-w);
      height: 36px;
      position: relative;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .explorer-shell .sel {
      outline: 2px solid var(--ring-select);
      outline-offset: -2px;
      box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.4) inset;
    }
    .explorer-shell .num {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 700;
      text-shadow: 0 1px 1px rgba(0, 0, 0, 0.6);
    }
    .explorer-shell .cell-emph {
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.2) inset, 0 0 0 1px rgba(0, 0, 0, 0.25);
    }
    .explorer-shell .cell-edited {
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.2) inset,
        0 0 0 1px rgba(0, 0, 0, 0.25),
        0 0 0 1px rgba(255, 118, 98, 0.35);
    }
    .explorer-shell .ring {
      position: absolute;
      inset: 2px;
      outline: 2px solid var(--ring-thin);
      outline-offset: -2px;
      border-radius: 5px;
      box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.45) inset;
    }
    .explorer-shell .ring-thin {
      outline-color: var(--ring-thin);
      box-shadow: 0 0 0 1px rgba(239, 180, 99, 0.35), 0 0 0 2px rgba(0, 0, 0, 0.45) inset;
    }
    .explorer-shell .ring-thick {
      inset: 4px;
      outline-color: var(--ring-thick);
      box-shadow: 0 0 0 2px rgba(104, 198, 193, 0.35), 0 0 0 2px rgba(0, 0, 0, 0.45) inset;
    }
    .explorer-shell .edit-flag {
      position: absolute;
      top: 0;
      right: 0;
      width: 0;
      height: 0;
      border-top: 12px solid #ff7662;
      border-left: 12px solid transparent;
      filter: drop-shadow(0 0 3px rgba(255, 118, 98, 0.45));
      pointer-events: none;
    }
    .explorer-shell .cell-pulse::after {
      content: "";
      position: absolute;
      inset: -6px;
      border: 2px solid var(--ring-thick);
      border-radius: 8px;
      opacity: 0;
      animation: pulseCell 0.8s ease-out;
      pointer-events: none;
    }
    @keyframes pulseCell {
      0% { opacity: 0.8; transform: scale(0.9); }
      50% { opacity: 0.4; transform: scale(1.05); }
      100% { opacity: 0; transform: scale(1.12); }
    }
    .explorer-shell .axis-active {
      background: #232a33;
      color: #fff;
    }
    .explorer-shell details {
      background: var(--explorer-panel);
      border: 1px solid var(--explorer-border);
      border-radius: 12px;
      padding: 10px 12px;
    }
    .explorer-shell details + details {
      margin-top: 8px;
    }
    .explorer-shell code {
      background: #0d1116;
      border: 1px solid var(--explorer-border);
      padding: 2px 5px;
      border-radius: 6px;
    }
    .explorer-shell table.small {
      border-collapse: collapse;
      width: 100%;
      font-size: 12px;
    }
    .explorer-shell table.small th,
    .explorer-shell table.small td {
      border: 1px solid #2d3342;
      padding: 4px 6px;
      text-align: right;
    }
    .explorer-shell table.small th:first-child,
    .explorer-shell table.small td:first-child {
      text-align: left;
    }
    .explorer-shell .pill {
      display: inline-block;
      padding: 2px 8px;
      border: 1px solid var(--explorer-border);
      border-radius: 999px;
      font-size: 11px;
      color: var(--explorer-muted);
      background: transparent;
    }
    .explorer-shell .spark {
      width: 260px;
      height: 50px;
      display: block;
    }
    .explorer-shell .blog {
      line-height: 1.6;
    }
    .explorer-shell .blog h2 {
      margin: 0 0 10px;
    }
    .explorer-shell .blog p {
      margin: 10px 0;
    }
    .explorer-shell .blog ul {
      padding-left: 20px;
      margin: 10px 0 10px 18px;
      color: var(--explorer-muted);
    }
    .explorer-shell .blog li {
      margin-bottom: 6px;
    }
    .explorer-shell .controls-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 8px;
    }
    .explorer-shell .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 12px;
    }
    .explorer-shell .summary-card {
      margin-bottom: 0;
    }
    .explorer-shell .summary-kicker {
      display: inline-block;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ring-thick);
    }
    .explorer-shell .mental-strip {
      display: grid;
      gap: 8px;
      margin-top: 12px;
    }
    .explorer-shell .mental-step {
      display: grid;
      grid-template-columns: 28px minmax(0, 1fr);
      gap: 10px;
      padding: 10px 12px;
      border-radius: 14px;
      background: var(--explorer-panel);
      border: 1px solid var(--explorer-border);
    }
    .explorer-shell .step-num {
      width: 28px;
      height: 28px;
      border-radius: 999px;
      border: 1px solid rgba(104, 198, 193, 0.45);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      color: #d8faf7;
      background: rgba(104, 198, 193, 0.14);
    }
    .explorer-shell .step-title {
      font-size: 12px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--explorer-muted);
    }
    .explorer-shell .step-value {
      margin-top: 3px;
      font-size: 17px;
      font-weight: 700;
      color: var(--explorer-fg);
    }
    .explorer-shell .step-detail {
      margin-top: 4px;
      font-size: 12px;
      line-height: 1.5;
      color: var(--explorer-muted);
    }
    .explorer-shell .status-banner {
      margin-top: 12px;
      padding: 10px 12px;
      border-radius: 14px;
      background: linear-gradient(180deg, rgba(104, 198, 193, 0.12), rgba(104, 198, 193, 0.05));
      border: 1px solid rgba(104, 198, 193, 0.32);
      color: var(--explorer-fg);
      line-height: 1.55;
      font-size: 13px;
    }
    .explorer-shell .answer-block {
      display: flex;
      align-items: baseline;
      gap: 10px;
      flex-wrap: wrap;
      margin: 10px 0 0;
    }
    .explorer-shell .answer-number {
      font-size: 28px;
      line-height: 1;
      font-weight: 700;
      color: #fff7eb;
    }
    .explorer-shell .summary-inline {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 10px;
    }
    .explorer-shell .ctrl-block {
      background: var(--explorer-panel);
      border: 1px solid var(--explorer-border);
      border-radius: 12px;
      padding: 8px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .explorer-shell .ctrl-title {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--explorer-muted);
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .explorer-shell .ctrl-content {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      align-items: center;
    }
    .explorer-shell .ctrl-content select,
    .explorer-shell .ctrl-content input[type="range"],
    .explorer-shell .ctrl-content input[type="checkbox"] {
      flex: 1;
    }
    .explorer-shell .ctrl-note {
      font-size: 10px;
      color: var(--explorer-muted);
    }
    .explorer-shell .tutorials {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 8px;
    }
    .explorer-shell .tutorial-btn {
      border: 1px solid var(--explorer-border);
      background: #1a2028;
      color: var(--explorer-fg);
      text-align: left;
      padding: 8px 10px;
      border-radius: 12px;
      cursor: pointer;
      font-size: 13px;
      line-height: 1.3;
    }
    .explorer-shell .tutorial-btn.active {
      border-color: var(--ring-thick);
      box-shadow: 0 0 0 1px var(--ring-thick) inset;
      background: #1f2d34;
    }
    .explorer-shell .tutorial-title {
      font-weight: 600;
      display: block;
    }
    .explorer-shell .tutorial-desc {
      display: block;
      font-size: 12px;
      color: var(--explorer-muted);
      margin-top: 2px;
    }
    .explorer-shell .tutorial-note {
      margin-top: 10px;
      font-size: 13px;
      color: var(--explorer-muted);
      background: var(--explorer-panel);
      border: 1px solid var(--explorer-border);
      border-radius: 12px;
      padding: 10px 12px;
      line-height: 1.5;
    }
    .explorer-shell .info-tip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 16px;
      height: 16px;
      border: 1px solid var(--explorer-border);
      border-radius: 50%;
      font-size: 11px;
      color: var(--explorer-muted);
      cursor: help;
    }
    .explorer-shell .btn.mini {
      padding: 4px 8px;
      font-size: 11px;
    }
    .explorer-shell .layout-shell {
      display: grid;
      grid-template-columns: var(--layout-cols, 320px minmax(420px, 1fr) 320px);
      gap: 14px;
      align-items: start;
    }
    .explorer-shell .side-panel {
      display: flex;
      flex-direction: column;
      gap: 14px;
      transition: width 0.22s ease, opacity 0.22s ease;
      min-width: 0;
    }
    .explorer-shell .side-panel.closed {
      width: 0;
      opacity: 0;
      pointer-events: none;
    }
    .explorer-shell .side-panel .card {
      background: var(--explorer-card-soft);
    }
    .explorer-shell .grid-center {
      display: flex;
      flex-direction: column;
      gap: 12px;
      position: relative;
    }
    .explorer-shell .panel-toggles {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
    }
    .explorer-shell .edge-toggle {
      font-size: 12px;
      border: 1px dashed var(--explorer-border);
      background: var(--explorer-panel);
      color: var(--explorer-muted);
      border-radius: 10px;
      padding: 6px 10px;
      cursor: pointer;
    }
    .explorer-shell .col-stack > .card + .card {
      margin-top: 14px;
    }
    .explorer-shell .preset-flash {
      animation: presetFlash 0.8s ease;
    }
    @keyframes presetFlash {
      0% { box-shadow: 0 0 0 0 rgba(104, 198, 193, 0.35); }
      50% { box-shadow: 0 0 0 14px rgba(104, 198, 193, 0.12); }
      100% { box-shadow: 0 0 0 0 rgba(104, 198, 193, 0); }
    }
    .explorer-shell .computed-flash {
      animation: computedFlash 0.9s ease;
    }
    @keyframes computedFlash {
      0% { box-shadow: 0 0 0 0 rgba(239, 180, 99, 0.18); }
      40% { box-shadow: 0 0 0 12px rgba(239, 180, 99, 0.12); }
      100% { box-shadow: 0 0 0 0 rgba(239, 180, 99, 0); }
    }
    .explorer-shell .json-block {
      background: #0d1116;
      border: 1px solid var(--explorer-border);
      border-radius: 10px;
      padding: 8px;
      font-family: "SFMono-Regular", Consolas, Menlo, monospace;
      font-size: 12px;
      color: var(--explorer-muted);
      overflow: auto;
      line-height: 1.35;
    }
    .explorer-shell .guide-details summary {
      cursor: pointer;
      font-weight: 600;
      font-size: 14px;
    }
    .explorer-shell .distill-shell {
      display: grid;
      gap: 18px;
    }
    .explorer-shell .story-intro {
      background:
        linear-gradient(180deg, rgba(39, 46, 57, 0.92), rgba(22, 26, 32, 0.94)),
        var(--explorer-card);
      border: 1px solid rgba(104, 198, 193, 0.18);
      border-radius: 24px;
      padding: 18px;
      box-shadow: 0 22px 48px rgba(0, 0, 0, 0.25);
    }
    .explorer-shell .story-intro-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(20rem, 0.85fr);
      gap: 18px;
      align-items: start;
    }
    .explorer-shell .intro-title {
      margin: 6px 0 0;
      font-size: clamp(1.7rem, 2.4vw, 2.4rem);
      line-height: 1.08;
      letter-spacing: -0.03em;
      color: var(--explorer-fg);
    }
    .explorer-shell .intro-panel {
      display: grid;
      gap: 10px;
      align-content: start;
    }
    .explorer-shell .intro-panel-head {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 10px;
    }
    .explorer-shell .distill-layout {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 0.8fr);
      gap: 18px;
      align-items: start;
    }
    .explorer-shell .stage-column {
      position: relative;
      min-width: 0;
    }
    .explorer-shell .stage-frame {
      position: sticky;
      top: 1rem;
      display: grid;
      gap: 14px;
      padding: 18px;
      background:
        radial-gradient(circle at top left, rgba(104, 198, 193, 0.08), transparent 28%),
        linear-gradient(180deg, rgba(25, 29, 36, 0.98), rgba(14, 17, 24, 0.98));
      border: 1px solid rgba(104, 198, 193, 0.22);
      border-radius: 24px;
      box-shadow: 0 24px 52px rgba(0, 0, 0, 0.28);
    }
    .explorer-shell .stage-head {
      display: grid;
      gap: 10px;
    }
    .explorer-shell .stage-head-row {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 10px;
      flex-wrap: wrap;
    }
    .explorer-shell .stage-title {
      margin: 4px 0 0;
      font-size: clamp(1.35rem, 2vw, 1.9rem);
      line-height: 1.12;
      letter-spacing: -0.03em;
    }
    .explorer-shell .stage-copy {
      margin: 0;
      color: #efe7dc;
      font-size: 1rem;
      line-height: 1.6;
    }
    .explorer-shell .analysis-switcher {
      display: grid;
      gap: 12px;
      padding: 12px;
      border-radius: 18px;
      background: rgba(18, 21, 25, 0.88);
      border: 1px solid var(--explorer-border);
    }
    .explorer-shell .focus-panel {
      display: grid;
      gap: 8px;
    }
    .explorer-shell .focus-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .explorer-shell .stage-summary-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }
    .explorer-shell .stage-summary {
      display: grid;
      gap: 6px;
      padding: 12px;
      border-radius: 18px;
      border: 1px solid var(--explorer-border);
      background: rgba(19, 24, 31, 0.92);
    }
    .explorer-shell .stage-summary.primary {
      background: linear-gradient(180deg, rgba(104, 198, 193, 0.16), rgba(104, 198, 193, 0.05));
    }
    .explorer-shell .stage-summary.accent {
      background: linear-gradient(180deg, rgba(239, 180, 99, 0.16), rgba(239, 180, 99, 0.05));
    }
    .explorer-shell .stage-summary.quiet {
      background: rgba(28, 33, 42, 0.95);
    }
    .explorer-shell .stage-summary-label {
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--explorer-muted);
    }
    .explorer-shell .stage-summary-value {
      font-size: clamp(1.35rem, 2vw, 2rem);
      font-weight: 700;
      line-height: 1;
      color: #fff7eb;
    }
    .explorer-shell .stage-summary-note {
      font-size: 12px;
      line-height: 1.55;
      color: var(--explorer-muted);
    }
    .explorer-shell .grid-card,
    .explorer-shell .analysis-card {
      display: grid;
      gap: 12px;
      padding: 14px;
      border-radius: 20px;
      background: rgba(19, 24, 31, 0.94);
      border: 1px solid var(--explorer-border);
    }
    .explorer-shell .grid-card-head,
    .explorer-shell .analysis-head {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 10px;
      flex-wrap: wrap;
    }
    .explorer-shell .grid-card-title {
      margin: 4px 0 0;
      font-size: 1.1rem;
      line-height: 1.2;
    }
    .explorer-shell .grid-card-copy,
    .explorer-shell .analysis-copy {
      color: var(--explorer-muted);
      font-size: 13px;
      line-height: 1.6;
      margin: 0;
    }
    .explorer-shell .grid-meta-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      align-items: center;
    }
    .explorer-shell .stage-grid {
      max-height: min(48vh, 38rem);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    }
    .explorer-shell .comparison-legend {
      display: grid;
      gap: 4px;
      color: var(--explorer-muted);
      font-size: 12px;
      line-height: 1.6;
    }
    .explorer-shell .equation-block {
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid rgba(239, 180, 99, 0.22);
      background: linear-gradient(180deg, rgba(239, 180, 99, 0.1), rgba(239, 180, 99, 0.04));
      color: #fff1d4;
      font-size: 12px;
      line-height: 1.55;
    }
    .explorer-shell .story-column {
      display: grid;
      gap: 14px;
      min-width: 0;
    }
    .explorer-shell .story-section {
      display: grid;
      grid-template-columns: 40px minmax(0, 1fr);
      gap: 14px;
      padding: 16px;
      border-radius: 22px;
      background: linear-gradient(180deg, rgba(29, 34, 42, 0.92), rgba(18, 22, 29, 0.96));
      border: 1px solid rgba(104, 198, 193, 0.12);
      box-shadow: 0 18px 38px rgba(0, 0, 0, 0.2);
    }
    .explorer-shell .story-section-single {
      grid-template-columns: 1fr;
    }
    .explorer-shell .story-index {
      width: 36px;
      height: 36px;
      border-radius: 999px;
      border: 1px solid rgba(104, 198, 193, 0.3);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(104, 198, 193, 0.12);
      color: #d8faf7;
      font-size: 12px;
      font-weight: 600;
    }
    .explorer-shell .story-content {
      display: grid;
      gap: 12px;
      min-width: 0;
    }
    .explorer-shell .story-eyebrow {
      display: inline-block;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ring-thick);
      margin-bottom: 6px;
    }
    .explorer-shell .story-content h3 {
      margin: 0;
      font-size: 1.28rem;
      line-height: 1.18;
      letter-spacing: -0.02em;
    }
    .explorer-shell .story-copy {
      margin: 0;
      color: var(--explorer-muted);
      line-height: 1.75;
    }
    .explorer-shell .story-note {
      padding: 10px 12px;
      border-radius: 14px;
      background: rgba(104, 198, 193, 0.08);
      border: 1px solid rgba(104, 198, 193, 0.16);
      color: var(--explorer-fg);
      font-size: 13px;
      line-height: 1.6;
    }
    .explorer-shell .faq-stack {
      display: grid;
      gap: 8px;
    }
    @media (max-width: 980px) {
      .explorer-shell .story-intro-grid,
      .explorer-shell .distill-layout {
        grid-template-columns: 1fr;
      }
      .explorer-shell .stage-frame {
        position: static;
      }
      .explorer-shell .stage-summary-grid {
        grid-template-columns: 1fr;
      }
      .explorer-shell .story-section {
        grid-template-columns: 1fr;
      }
      .explorer-shell .story-index {
        display: none;
      }
      .explorer-shell .layout-shell {
        grid-template-columns: 1fr !important;
      }
      .explorer-shell .side-panel,
      .explorer-shell .side-panel.closed {
        width: 100%;
        opacity: 1;
        pointer-events: auto;
      }
      .explorer-shell .panel-toggles {
        justify-content: flex-end;
      }
    }
    @media (max-width: 720px) {
      .explorer-shell {
        --grid-axis-w: 68px;
        --grid-cell-w: 42px;
      }
      .explorer-shell .wrap {
        padding: 12px;
      }
      .explorer-shell .story-intro,
      .explorer-shell .stage-frame,
      .explorer-shell .story-section {
        border-radius: 20px;
      }
      .explorer-shell .stage-grid {
        max-height: 22rem;
      }
    }
  </style>

  <Nav />

  <main class="page essay-page explorer-page">
    <header class="essay-header page-header">
      <div>
        {page.data.eyebrow && <span class="page-eyebrow">{page.data.eyebrow}</span>}
        <h1 class="page-title">{page.data.title}</h1>
        {page.data.lede && <p class="page-lede">{page.data.lede}</p>}
        <div class="page-meta">
          <span class="pill">Rows are training worlds</span>
          <span class="pill">Columns are evaluation slices</span>
          <span class="pill">Guided examples are built in</span>
        </div>
      </div>

      <aside class="essay-side">
        {headerNote?.label && <p class="note-label">{headerNote.label}</p>}
        {renderMarkdownBlocks(headerNote?.body ?? []).map((html) => (
          <div set:html={html}></div>
        ))}
      </aside>
    </header>

    <section class="essay-section">
      <div class="essay-main">
        <h2>{introSection.title}</h2>
        <div set:html={introSection.html}></div>
        <ul class="tip-list">
          {quickTips.map((tip) => (
            <li>{tip}</li>
          ))}
        </ul>
      </div>

      <aside class="essay-side">
        {companionNote?.label && <p class="note-label">{companionNote.label}</p>}
        {renderMarkdownBlocks(companionNote?.body ?? []).map((html) => (
          <div set:html={html}></div>
        ))}
        <ul class="explorer-link-list">
          {companionLinks.map((link) => (
            <li><a href={link.href}>{link.title}</a></li>
          ))}
        </ul>
      </aside>
    </section>

    <section class="section-card explorer-frame" id="explore" aria-label="Explore">
      <div class="explorer-shell">
        <Explorer client:load />
      </div>
    </section>
  </main>
</Layout>
