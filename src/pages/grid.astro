      background: linear-gradient(180deg, rgba(47, 92, 126, 0.05), rgba(47, 92, 126, 0.02));
    }
    .explorer-shell .dock-footer-label {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .dock-footer-copy {
      color: var(--explorer-fg);
      font-size: 0.82rem;
      line-height: 1.58;
    }
    .explorer-shell .guide-item {
      display: grid;
      grid-template-columns: 2rem minmax(0, 1fr);
      gap: 0.75rem;
      align-items: start;
      padding: 0.9rem;
      border-radius: var(--explorer-radius-md);
      border: 1px solid rgba(33, 65, 95, 0.1);
      background: rgba(255, 255, 255, 0.6);
    }
    .explorer-shell .guide-item-label {
      color: var(--explorer-stage-muted);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .guide-item-value {
      margin-top: 0.25rem;
      color: var(--explorer-fg);
      font-size: 1.02rem;
      line-height: 1.3;
    }
    .explorer-shell .guide-item-note {
      margin-top: 0.28rem;
      color: var(--explorer-stage-muted);
      font-size: 0.82rem;
      line-height: 1.58;
    }
    .explorer-shell .spark-wrap {
      padding: 0.7rem 0.8rem;
      border-radius: var(--explorer-radius-md);
      border: 1px solid rgba(33, 65, 95, 0.1);
      background: rgba(255, 255, 255, 0.56);
      overflow-x: auto;
    }
    .explorer-shell .spark {
      width: 260px;
      height: 50px;
      display: block;
    }
    .explorer-shell .inspector-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
      gap: 1rem;
    }
    .explorer-shell table.small {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    .explorer-shell table.small th,
    .explorer-shell table.small td {
      border: 1px solid rgba(33, 65, 95, 0.1);
      padding: 0.42rem 0.52rem;
      text-align: right;
    }
    .explorer-shell table.small th:first-child,
    .explorer-shell table.small td:first-child {
      text-align: left;
    }
    .explorer-shell .preset-flash {
      animation: presetFlash 0.8s ease;
    }
    @keyframes presetFlash {
      0% { box-shadow: 0 0 0 0 rgba(45, 115, 133, 0.28); }
      50% { box-shadow: 0 0 0 16px rgba(45, 115, 133, 0.1); }
      100% { box-shadow: 0 0 0 0 rgba(45, 115, 133, 0); }
    }
    .explorer-shell .computed-flash {
      animation: computedFlash 0.9s ease;
    }
    @keyframes computedFlash {
      0% { box-shadow: 0 0 0 0 rgba(191, 134, 66, 0.2); }
      40% { box-shadow: 0 0 0 12px rgba(191, 134, 66, 0.12); }
      100% { box-shadow: 0 0 0 0 rgba(191, 134, 66, 0); }
    }
    @media (max-width: 1080px) {
      .explorer-page .page-header,
      .explorer-shell .inspector-grid,
      .explorer-shell .workspace-main {
        grid-template-columns: 1fr;
      }
      .explorer-signpost-steps,
      .explorer-scenario-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .explorer-shell .control-column {
        position: static;
        order: -1;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .explorer-shell .cell-pulse::after,
      .explorer-shell .preset-flash,
      .explorer-shell .computed-flash {
        animation: none;
      }
      .explorer-shell .cell,
      .explorer-shell .btn {
        transition: none;
      }
    }
    .explorer-mobile-notice {
      display: none;
    }
    @media (max-width: 720px) {
      .explorer-mobile-notice {
        display: block;
        padding: 0.85rem 1rem;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: rgba(255, 250, 243, 0.84);
        color: var(--muted);
        font-family: var(--font-ui);
        font-size: 0.88rem;
        line-height: 1.6;
        margin-bottom: 0.75rem;
      }
      .explorer-signpost-steps,
      .explorer-scenario-grid {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 480px) {
      .explorer-shell {
        --grid-axis-w: 72px;
        --grid-cell-w: 40px;
      }
    }
    @media (max-width: 720px) {
      .explorer-shell {
        --grid-axis-w: 88px;
        --grid-cell-w: 52px;
      }
      .explorer-shell .hero-card,
      .explorer-shell .panel-card,
      .explorer-shell .support-card,
      .explorer-shell .workspace-toolbar,
      .explorer-shell .stage-panel,
      .explorer-shell .grid-card,
      .explorer-shell .analysis-card {
        padding: 0.95rem;
        border-radius: var(--explorer-radius-lg);
      }
      .explorer-shell .control-grid,
      .explorer-shell .toolbar-grid,
      .explorer-shell .scene-fact-grid,
      .explorer-shell .stage-summary-grid {
        grid-template-columns: 1fr;
      }
      .explorer-shell .stage-grid {
        max-height: min(60vh, 24rem);
      }
    }
  </style>

  <Nav />

  <main class="page essay-page explorer-page">
    <header class="essay-header page-header">
      <div>
        {page.data.eyebrow && <span class="page-eyebrow">{page.data.eyebrow}</span>}
        <h1 class="page-title">{page.data.title}</h1>
      </div>
      <div class="grid-read-note">
        <span class="grid-read-note-label">{introSection.title}</span>
        <div set:html={introSection.html}></div>
      </div>
    </header>

    <p class="explorer-mobile-notice">The explorer works best on a wider screen. On a phone, scroll the grid horizontally to see all columns — or view on a larger device for the full experience.</p>

    <section class="explorer-page-signpost" aria-label="How to use the grid explorer">
      <div class="explorer-page-signpost-head">
        <span class="explorer-page-signpost-kicker">How to use this page</span>
        <h2 class="explorer-page-signpost-title">Below you'll choose what you're exploring, read the grid itself, check the current reading, and then tune the mode controls.</h2>
        <p class="explorer-page-signpost-copy">The whole page is organized around one selected train/eval pair. The top controls choose the counterfactual lens, the grid anchors a location in the space, and the sticky right rail keeps the explanation and controls beside that same selection.</p>
      </div>

      <div class="explorer-signpost-steps">
        <div class="explorer-signpost-step">
          <span class="explorer-signpost-step-number">1</span>
          <h3 class="explorer-signpost-step-title">Choose what you're exploring</h3>
          <p class="explorer-signpost-step-copy">Use the question family, cell score, example scenes, and display controls to decide what kind of counterfactual you want to ask.</p>
        </div>
        <div class="explorer-signpost-step">
          <span class="explorer-signpost-step-number">2</span>
          <h3 class="explorer-signpost-step-title">Read the grid</h3>
          <p class="explorer-signpost-step-copy">Click a row, column, or cell to anchor one training world and one evaluation slice. That shared selection drives the rest of the interface.</p>
        </div>
        <div class="explorer-signpost-step">
          <span class="explorer-signpost-step-number">3</span>
          <h3 class="explorer-signpost-step-title">Check the current reading</h3>
          <p class="explorer-signpost-step-copy">The sticky sidebar translates the selected train/eval pair into the headline question and shows the exact statistic the current mode is computing.</p>
        </div>
        <div class="explorer-signpost-step">
          <span class="explorer-signpost-step-number">4</span>
          <h3 class="explorer-signpost-step-title">Tune the mode controls</h3>
          <p class="explorer-signpost-step-copy">Adjust focus points, coalition choices, privacy or unlearning thresholds, attack toggles, or scaling buckets without losing your place in the grid.</p>
        </div>
      </div>

      <details class="explorer-scenario-drawer">
        <summary>Exactly what kind of scenario are we exploring here?</summary>
        <div class="explorer-scenario-grid">
          <div class="explorer-scenario-card">
            <h3>One model builder, one tiny data universe</h3>
            <p>Imagine someone training a model from a small menu of possible data items or data slices named A, B, C, D, and so on. Each row in the grid stands for one possible training world: one subset of that tiny universe that the model could have been trained on.</p>
          </div>
          <div class="explorer-scenario-card">
            <h3>Columns are evaluation questions</h3>
            <p>Each column stands for one evaluation slice from that same universe. So a single cell means: train on the row subset, then evaluate on the column subset. The score is either a structural proxy such as overlap or a tiny toy accuracy calculation, depending on which score rule you selected above.</p>
          </div>
          <div class="explorer-scenario-card">
            <h3>The modes are different counterfactual questions</h3>
            <p>Explore mode reads one cell directly. Leave-one-out and group leave-one-out compare nearby rows. Shapley-style modes average many local row comparisons. Scaling averages across rows of the same size. DP, unlearning, and poison reinterpret the same space through privacy, deletion, or attack lenses.</p>
          </div>
          <div class="explorer-scenario-card">
            <h3>This is a teaching model, not a literal training pipeline</h3>
            <p>Real systems cannot enumerate every possible training set and evaluation slice like this. The toy makes the geometry visible so you can see exactly which worlds are being compared and why. If you prefer to think in nodes and edges instead of rows and columns, the graph page shows the same scenario as a subset lattice.</p>
          </div>
        </div>
      </details>
    </section>

    <section class="section-card explorer-frame" id="explore" aria-label="Explore">
      <div class="explorer-shell">
        <Explorer client:load />
      </div>
    </section>
  </main>
</Layout>
