---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Explorer from "../components/Explorer.jsx";
import { getRequiredPageEntry, getSection, renderMarkdownBlocks, splitMarkdownSections } from "../lib/page-content";

const page = await getRequiredPageEntry("grid");
const sections = splitMarkdownSections(page.body);
const introSection = getSection(sections, "how-to-read-the-toy");
const quickTips: string[] = page.data.quick_tips ?? [];
const companionLinks: Array<{ title: string; href: string }> = page.data.companion_links ?? [];
const headerNote = page.data.notes?.header;
const companionNote = page.data.notes?.companions;
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style is:global>
    .explorer-page {
      display: grid;
      gap: 2.7rem;
    }
    .explorer-page .page-header {
      margin-bottom: 0;
    }
    .tip-list {
      margin: 1rem 0 0;
      padding-left: 1.2rem;
      display: grid;
      gap: 0.65rem;
    }
    .tip-list li {
      padding: 0;
      color: var(--muted);
      line-height: 1.82;
    }
    .explorer-link-list {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
      display: grid;
      gap: 0.55rem;
    }
    .explorer-frame {
      padding: 0.35rem;
      background:
        linear-gradient(180deg, rgba(34, 29, 25, 0.08), rgba(34, 29, 25, 0.02)),
        rgba(255, 250, 243, 0.56);
    }
    .explorer-shell {
      --explorer-surface: rgba(247, 242, 235, 0.96);
      --explorer-surface-strong: rgba(255, 253, 249, 0.98);
      --explorer-surface-soft: rgba(237, 227, 214, 0.78);
      --explorer-border: rgba(92, 72, 52, 0.14);
      --explorer-border-strong: rgba(92, 72, 52, 0.24);
      --explorer-fg: #231d18;
      --explorer-muted: #6f6154;
      --explorer-accent: #a44a1d;
      --explorer-accent-soft: rgba(164, 74, 29, 0.11);
      --explorer-stage-fg: #231d18;
      --explorer-stage-muted: #726456;
      --ring-thin: #efb463;
      --ring-thick: #68c6c1;
      --ring-select: #fffdf7;
      --grid-surface: #f7f2ea;
      --grid-surface-soft: #ece3d5;
      --grid-axis-w: 80px;
      --grid-cell-w: 48px;
    }
    .explorer-shell .workspace-shell {
      display: grid;
      gap: clamp(1.25rem, 2.2vw, 2rem);
      max-width: 1180px;
      margin: 0 auto;
    }
    .explorer-shell .workspace-header {
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) minmax(20rem, 0.82fr);
      gap: clamp(1rem, 2vw, 1.6rem);
      padding: clamp(1.25rem, 2vw, 1.7rem);
      border-radius: 26px;
      border: 1px solid var(--explorer-border-strong);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 18%),
        radial-gradient(circle at top right, rgba(164, 74, 29, 0.08), transparent 30%),
        linear-gradient(180deg, rgba(247, 242, 235, 0.98), rgba(238, 229, 216, 0.96));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 22px 42px rgba(88, 64, 42, 0.08);
    }
    .explorer-shell .header-main,
    .explorer-shell .preset-dock,
    .explorer-shell .control-column,
    .explorer-shell .workspace-main {
      display: grid;
      gap: 1rem;
      min-width: 0;
    }
    .explorer-shell .header-main {
      align-content: start;
    }
    .explorer-shell .header-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      flex-wrap: wrap;
    }
    .explorer-shell .header-command {
      display: grid;
      gap: 0.45rem;
      padding: 1rem 1.05rem;
      border-radius: 16px;
      border: 1px solid rgba(92, 72, 52, 0.12);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0)),
        rgba(255, 252, 248, 0.74);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
    }
    .explorer-shell .header-command-label,
    .explorer-shell .header-status-label {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .header-command-line {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: clamp(1rem, 1.8vw, 1.35rem);
      font-weight: 650;
      line-height: 1.28;
      letter-spacing: -0.03em;
    }
    .explorer-shell .header-command-trace {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      line-height: 1.55;
    }
    .explorer-shell .header-status-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 0.7rem;
    }
    .explorer-shell .header-status {
      display: grid;
      gap: 0.22rem;
      padding: 0.88rem 0.92rem;
      border-radius: 14px;
      border: 1px solid rgba(92, 72, 52, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
        rgba(255, 252, 247, 0.7);
    }
    .explorer-shell .header-status-accent {
      background:
        linear-gradient(180deg, rgba(239, 180, 99, 0.18), rgba(239, 180, 99, 0.04)),
        rgba(255, 250, 240, 0.78);
      border-color: rgba(239, 180, 99, 0.24);
    }
    .explorer-shell .header-status-value {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.96rem;
      font-weight: 650;
      line-height: 1.3;
    }
    .explorer-shell .summary-kicker {
      display: inline-block;
      color: var(--explorer-accent);
      font-family: var(--font-ui);
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .card-title,
    .explorer-shell .panel-title,
    .explorer-shell .stage-title,
    .explorer-shell .grid-card-title {
      font-family: var(--font-ui);
      font-weight: 650;
    }
    .explorer-shell .hero-card,
    .explorer-shell .panel-card,
    .explorer-shell .support-card {
      display: grid;
      gap: 0.9rem;
      padding: 1.1rem;
      border-radius: 20px;
      border: 1px solid var(--explorer-border);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0)),
        var(--explorer-surface);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 14px 26px rgba(88, 64, 42, 0.06);
    }
    .explorer-shell .preset-card {
      align-content: start;
      min-height: 100%;
    }
    .explorer-shell .preset-card-head {
      align-items: center;
    }
    .explorer-shell .card-head,
    .explorer-shell .panel-head,
    .explorer-shell .grid-card-head,
    .explorer-shell .analysis-head,
    .explorer-shell .stage-head {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.8rem;
    }
    .explorer-shell .card-title,
    .explorer-shell .panel-title,
    .explorer-shell .grid-card-title {
      margin: 0.2rem 0 0;
      font-size: 1.08rem;
      line-height: 1.16;
      letter-spacing: -0.03em;
    }
    .explorer-shell .panel-copy,
    .explorer-shell .grid-card-copy,
    .explorer-shell .analysis-copy {
      margin: 0;
      color: var(--explorer-muted);
      font-size: 0.87rem;
      line-height: 1.62;
    }
    .explorer-shell .status-banner,
    .explorer-shell .inline-note,
    .explorer-shell .story-note {
      padding: 0.85rem 1rem;
      border-radius: 14px;
      border: 1px solid rgba(164, 74, 29, 0.14);
      background: linear-gradient(180deg, rgba(164, 74, 29, 0.07), rgba(164, 74, 29, 0.03));
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.84rem;
      line-height: 1.55;
    }
    .explorer-shell .summary-inline,
    .explorer-shell .segmented-row,
    .explorer-shell .mode-toggle,
    .explorer-shell .grid-meta-strip,
    .explorer-shell .export-actions,
    .explorer-shell .focus-chip-row,
    .explorer-shell .question-button-row,
    .explorer-shell .slider-row,
    .explorer-shell .checkbox-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.55rem;
      min-width: 0;
    }
    .explorer-shell .pill {
      display: inline-block;
      padding: 0.28rem 0.65rem;
      border: 1px solid rgba(92, 72, 52, 0.12);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.72);
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.71rem;
    }
    .explorer-shell .btn {
      border: 1px solid var(--explorer-border);
      background: var(--explorer-surface-strong);
      color: var(--explorer-fg);
      padding: 0.58rem 0.84rem;
      border-radius: 12px;
      cursor: pointer;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      line-height: 1.2;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, box-shadow 160ms ease;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }
    .explorer-shell .btn:hover,
    .explorer-shell .btn:focus-visible,
    .explorer-shell .tutorial-btn:hover,
    .explorer-shell .tutorial-btn:focus-visible {
      transform: translateY(-1px);
      border-color: rgba(164, 74, 29, 0.28);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.72),
        0 10px 18px rgba(88, 64, 42, 0.08);
    }
    .explorer-shell .btn[aria-pressed="true"] {
      border-color: rgba(164, 74, 29, 0.34);
      background: var(--explorer-accent-soft);
      box-shadow: inset 0 0 0 1px rgba(177, 79, 31, 0.14);
    }
    .explorer-shell .btn.ghost {
      background: transparent;
    }
    .explorer-shell .btn.mini {
      padding: 0.48rem 0.74rem;
      font-size: 0.76rem;
    }
    .explorer-shell input[type="range"],
    .explorer-shell select,
    .explorer-shell input[type="checkbox"] {
      background: var(--explorer-surface-strong);
      color: var(--explorer-fg);
      border: 1px solid var(--explorer-border);
      border-radius: 12px;
      padding: 0.68rem 0.86rem;
      font: inherit;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
    }
    .explorer-shell .slider-row input[type="range"] {
      flex: 1 1 11rem;
      min-width: 8rem;
    }
    .explorer-shell .checkbox-row {
      color: var(--explorer-fg);
      font-size: 0.88rem;
    }
    .explorer-shell .checkbox-row input[type="checkbox"] {
      width: auto;
      padding: 0;
    }
    .explorer-shell .tutorials {
      display: grid;
      gap: 0.65rem;
    }
    .explorer-shell .tutorial-btn {
      border: 1px solid var(--explorer-border);
      background: rgba(255, 255, 255, 0.76);
      color: var(--explorer-fg);
      text-align: left;
      padding: 0.85rem 0.95rem;
      border-radius: 14px;
      cursor: pointer;
      font-size: 0.84rem;
      line-height: 1.35;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    }
    .explorer-shell .tutorial-btn.active {
      border-color: rgba(177, 79, 31, 0.34);
      box-shadow: inset 0 0 0 1px rgba(177, 79, 31, 0.18);
      background: rgba(177, 79, 31, 0.08);
    }
    .explorer-shell .tutorial-title {
      display: block;
      font-weight: 600;
    }
    .explorer-shell .tutorial-desc {
      display: block;
      margin-top: 0.2rem;
      color: var(--explorer-muted);
      font-size: 0.82rem;
    }
    .explorer-shell .tutorial-note {
      padding: 0.9rem 1rem;
      border-radius: 14px;
      border: 1px solid var(--explorer-border);
      background: rgba(255, 255, 255, 0.7);
      color: var(--explorer-muted);
      font-size: 0.82rem;
      line-height: 1.6;
    }
    .explorer-shell .workspace-layout {
      display: grid;
      grid-template-columns: minmax(18rem, 23rem) minmax(0, 1fr);
      gap: clamp(1rem, 2vw, 1.6rem);
      align-items: start;
      padding: 1rem;
      border-radius: 28px;
      border: 1px solid var(--explorer-border-strong);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.58), rgba(255, 255, 255, 0) 15%),
        linear-gradient(180deg, rgba(243, 236, 227, 0.98), rgba(235, 226, 212, 0.98));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.78),
        0 28px 50px rgba(88, 64, 42, 0.09);
    }
    .explorer-shell .control-column {
      align-content: start;
    }
    .explorer-shell .workspace-toolbar {
      display: grid;
      gap: 0.8rem;
      padding: 0.95rem 1rem;
      border-radius: 20px;
      border: 1px solid var(--explorer-border);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
        var(--explorer-surface);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.8),
        0 14px 26px rgba(88, 64, 42, 0.06);
    }
    .explorer-shell .toolbar-bar {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      flex-wrap: wrap;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid rgba(92, 72, 52, 0.1);
    }
    .explorer-shell .toolbar-lights {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
    }
    .explorer-shell .toolbar-lights span {
      width: 0.7rem;
      height: 0.7rem;
      border-radius: 999px;
      display: inline-block;
      border: 1px solid rgba(92, 72, 52, 0.14);
    }
    .explorer-shell .toolbar-lights span:nth-child(1) {
      background: #f5c26a;
    }
    .explorer-shell .toolbar-lights span:nth-child(2) {
      background: #d9b76e;
    }
    .explorer-shell .toolbar-lights span:nth-child(3) {
      background: #7fc6b7;
    }
    .explorer-shell .toolbar-title-group {
      display: grid;
      gap: 0.08rem;
      flex: 1 1 auto;
      min-width: 0;
    }
    .explorer-shell .toolbar-title {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .explorer-shell .toolbar-subtitle {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .explorer-shell .toolbar-status {
      padding: 0.34rem 0.68rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.76);
      border: 1px solid rgba(92, 72, 52, 0.12);
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      white-space: nowrap;
    }
    .explorer-shell .toolbar-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.75rem;
    }
    .explorer-shell .toolbar-group {
      display: grid;
      gap: 0.6rem;
      padding: 0.88rem;
      border-radius: 16px;
      border: 1px solid rgba(92, 72, 52, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.68), rgba(255, 255, 255, 0)),
        rgba(255, 253, 249, 0.7);
      min-width: 0;
    }
    .explorer-shell .toolbar-group-actions {
      align-content: start;
    }
    .explorer-shell .toolbar-group-note {
      grid-column: 1 / -1;
    }
    .explorer-shell .toolbar-label {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .toolbar-note {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      line-height: 1.55;
    }
    .explorer-shell .toolbar-pills {
      margin-top: 0.1rem;
    }
    .explorer-shell .toolbar-drawer {
      padding: 0.8rem 0.9rem;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.6);
    }
    .explorer-shell .control-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }
    .explorer-shell .control-field,
    .explorer-shell .control-cluster {
      display: grid;
      gap: 0.6rem;
      padding: 0.95rem;
      border-radius: 16px;
      border: 1px solid var(--explorer-border);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
        var(--explorer-surface-strong);
      min-width: 0;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
    }
    .explorer-shell .control-field-full {
      grid-column: 1 / -1;
    }
    .explorer-shell .control-label,
    .explorer-shell .control-head {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.79rem;
      font-weight: 600;
      letter-spacing: 0.02em;
    }
    .explorer-shell .control-note,
    .explorer-shell .ctrl-note {
      color: var(--explorer-muted);
      font-size: 0.8rem;
      line-height: 1.55;
    }
    .explorer-shell .control-field select,
    .explorer-shell .control-cluster select {
      width: 100%;
    }
    .explorer-shell .panel-step {
      width: 2rem;
      height: 2rem;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(177, 79, 31, 0.22);
      background: rgba(177, 79, 31, 0.08);
      color: var(--explorer-accent);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 700;
      flex: 0 0 auto;
    }
    .explorer-shell .info-tip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 16px;
      height: 16px;
      border: 1px solid var(--explorer-border);
      border-radius: 50%;
      color: var(--explorer-muted);
      font-size: 11px;
      cursor: help;
    }
    .explorer-shell details {
      background: var(--explorer-surface-strong);
      border: 1px solid var(--explorer-border);
      border-radius: 18px;
      padding: 0.85rem 1rem;
    }
    .explorer-shell details + details {
      margin-top: 0.75rem;
    }
    .explorer-shell details summary {
      cursor: pointer;
      font-family: var(--font-ui);
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--explorer-fg);
    }
    .explorer-shell .guide-details .ctrl-note,
    .explorer-shell .faq-stack .control-note {
      margin-top: 0.7rem;
    }
    .explorer-shell .json-block {
      background: #fbf8f4;
      border: 1px solid rgba(92, 72, 52, 0.12);
      border-radius: 14px;
      padding: 0.8rem;
      color: #5f554c;
      font-family: "SFMono-Regular", Consolas, Menlo, monospace;
      font-size: 12px;
      overflow: auto;
      line-height: 1.4;
    }
    .explorer-shell .stage-panel,
    .explorer-shell .grid-card,
    .explorer-shell .analysis-card {
      display: grid;
      gap: 0.95rem;
      padding: 1.15rem;
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(255, 255, 255, 0)),
        linear-gradient(180deg, rgba(249, 245, 239, 0.98), rgba(242, 235, 225, 0.98));
      border: 1px solid rgba(92, 72, 52, 0.12);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.8),
        0 16px 30px rgba(88, 64, 42, 0.07);
      color: var(--explorer-stage-fg);
    }
    .explorer-shell .stage-panel .summary-kicker,
    .explorer-shell .grid-card .summary-kicker,
    .explorer-shell .analysis-card .summary-kicker {
      color: var(--explorer-accent);
    }
    .explorer-shell .stage-panel .pill,
    .explorer-shell .grid-card .pill,
    .explorer-shell .analysis-card .pill {
      background: rgba(255, 255, 255, 0.78);
      border-color: rgba(92, 72, 52, 0.12);
      color: var(--explorer-muted);
    }
    .explorer-shell .stage-panel .story-note,
    .explorer-shell .analysis-card .story-note {
      background: linear-gradient(180deg, rgba(164, 74, 29, 0.05), rgba(164, 74, 29, 0.02));
      border-color: rgba(164, 74, 29, 0.12);
      color: var(--explorer-fg);
    }
    .explorer-shell .grid-card-title,
    .explorer-shell .analysis-card .card-title {
      color: var(--explorer-fg);
    }
    .explorer-shell .stage-title {
      margin: 0.25rem 0 0;
      font-size: clamp(1.25rem, 2.2vw, 1.8rem);
      line-height: 1.08;
      letter-spacing: -0.04em;
    }
    .explorer-shell .stage-copy {
      margin: 0;
      color: var(--explorer-muted);
      font-size: 0.88rem;
      line-height: 1.65;
    }
    .explorer-shell .grid-card-copy,
    .explorer-shell .analysis-copy,
    .explorer-shell .analysis-note {
      color: var(--explorer-stage-muted);
    }
    .explorer-shell .scene-fact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(132px, 1fr));
      gap: 0.75rem;
    }
    .explorer-shell .scene-fact {
      display: grid;
      gap: 0.25rem;
      padding: 0.85rem 0.9rem;
      border-radius: 14px;
      border: 1px solid rgba(92, 72, 52, 0.1);
      background: rgba(255, 255, 255, 0.54);
    }
    .explorer-shell .scene-fact-label,
    .explorer-shell .stage-summary-label {
      color: var(--explorer-stage-muted);
      font-family: var(--font-ui);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .scene-fact-value {
      color: var(--explorer-fg);
      font-size: 0.92rem;
      line-height: 1.35;
    }
    .explorer-shell .stage-summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 0.75rem;
    }
    .explorer-shell .stage-summary {
      display: grid;
      gap: 0.45rem;
      padding: 0.95rem;
      border-radius: 14px;
      border: 1px solid rgba(92, 72, 52, 0.1);
      background: rgba(255, 255, 255, 0.58);
    }
    .explorer-shell .stage-summary.primary {
      background: linear-gradient(180deg, rgba(104, 198, 193, 0.18), rgba(104, 198, 193, 0.06));
    }
    .explorer-shell .stage-summary.accent {
      background: linear-gradient(180deg, rgba(239, 180, 99, 0.22), rgba(239, 180, 99, 0.06));
    }
    .explorer-shell .stage-summary.quiet {
      background: rgba(255, 255, 255, 0.48);
    }
    .explorer-shell .stage-summary-value {
      color: var(--explorer-fg);
      font-size: clamp(1.16rem, 1.8vw, 1.55rem);
      font-weight: 700;
      line-height: 1;
    }
    .explorer-shell .stage-summary-note {
      color: var(--explorer-stage-muted);
      font-size: 0.8rem;
      line-height: 1.55;
    }
    .explorer-shell .grid-wrap {
      overflow: auto;
      max-width: 100%;
      border: 1px solid rgba(92, 72, 52, 0.12);
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
        var(--grid-surface);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.84),
        inset 0 0 0 1px rgba(255, 255, 255, 0.35);
      scrollbar-gutter: stable both-edges;
    }
    .explorer-shell .rl,
    .explorer-shell .cl,
    .explorer-shell .cell {
      border-right: 1px solid rgba(92, 72, 52, 0.1);
      border-bottom: 1px solid rgba(92, 72, 52, 0.1);
    }
    .explorer-shell .rl {
      width: var(--grid-axis-w);
      min-width: var(--grid-axis-w);
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 6px;
      font-size: 11px;
      cursor: pointer;
      position: sticky;
      left: 0;
      z-index: 2;
      background: linear-gradient(180deg, rgba(244, 237, 227, 0.96), rgba(234, 224, 210, 0.96));
      color: var(--explorer-fg);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: background 0.2s ease, color 0.2s ease;
    }
    .explorer-shell .cl {
      width: var(--grid-cell-w);
      min-width: var(--grid-cell-w);
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 4px;
      font-size: 11px;
      font-variant-numeric: tabular-nums;
      cursor: pointer;
      position: sticky;
      top: 0;
      z-index: 3;
      background: linear-gradient(180deg, rgba(244, 237, 227, 0.96), rgba(234, 224, 210, 0.96));
      color: var(--explorer-fg);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: background 0.2s ease, color 0.2s ease;
    }
    .explorer-shell .cell {
      width: var(--grid-cell-w);
      min-width: var(--grid-cell-w);
      height: 36px;
      position: relative;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .explorer-shell .sel {
      outline: 2px solid var(--ring-select);
      outline-offset: -2px;
      box-shadow: 0 0 0 1px rgba(164, 74, 29, 0.45) inset, 0 0 0 2px rgba(255, 255, 255, 0.4) inset;
    }
    .explorer-shell .num {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 700;
      text-shadow: 0 1px 1px rgba(255, 255, 255, 0.28);
    }
    .explorer-shell .cell-emph {
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.26) inset, 0 0 0 1px rgba(92, 72, 52, 0.18);
    }
    .explorer-shell .cell-edited {
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.22) inset,
        0 0 0 1px rgba(92, 72, 52, 0.18),
        0 0 0 1px rgba(255, 118, 98, 0.35);
    }
    .explorer-shell .ring {
      position: absolute;
      inset: 2px;
      border-radius: 5px;
      outline: 2px solid var(--ring-thin);
      outline-offset: -2px;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.22) inset;
    }
    .explorer-shell .ring-thin {
      box-shadow: 0 0 0 1px rgba(239, 180, 99, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.22) inset;
      outline-color: var(--ring-thin);
    }
    .explorer-shell .ring-thick {
      inset: 4px;
      box-shadow: 0 0 0 2px rgba(104, 198, 193, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.22) inset;
      outline-color: var(--ring-thick);
    }
    .explorer-shell .edit-flag {
      position: absolute;
      top: 0;
      right: 0;
      width: 0;
      height: 0;
      border-top: 12px solid #ff7662;
      border-left: 12px solid transparent;
      filter: drop-shadow(0 0 3px rgba(255, 118, 98, 0.45));
      pointer-events: none;
    }
    .explorer-shell .cell-pulse::after {
      content: "";
      position: absolute;
      inset: -6px;
      border: 2px solid var(--ring-thick);
      border-radius: 8px;
      opacity: 0;
      animation: pulseCell 0.8s ease-out;
      pointer-events: none;
    }
    @keyframes pulseCell {
      0% { opacity: 0.8; transform: scale(0.9); }
      50% { opacity: 0.4; transform: scale(1.05); }
      100% { opacity: 0; transform: scale(1.12); }
    }
    .explorer-shell .axis-active {
      background: linear-gradient(180deg, rgba(204, 189, 168, 0.98), rgba(190, 173, 149, 0.98));
      color: var(--explorer-fg);
    }
    .explorer-shell .stage-grid {
      max-height: min(58vh, 42rem);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
    }
    .explorer-shell .comparison-legend {
      display: grid;
      gap: 0.35rem;
      color: var(--explorer-muted);
      font-size: 0.8rem;
      line-height: 1.6;
    }
    .explorer-shell .equation-block {
      padding: 0.85rem 1rem;
      border-radius: 14px;
      border: 1px solid rgba(239, 180, 99, 0.22);
      background: linear-gradient(180deg, rgba(239, 180, 99, 0.1), rgba(239, 180, 99, 0.04));
      color: #6c4a18;
      font-size: 0.82rem;
      line-height: 1.6;
    }
    .explorer-shell .inspector-stack,
    .explorer-shell .dock-list,
    .explorer-shell .faq-stack {
      display: grid;
      gap: 0.75rem;
    }
    .explorer-shell .inspector-banner {
      display: grid;
      gap: 0.28rem;
      padding: 0.9rem 0.95rem;
      border-radius: 14px;
      border: 1px solid rgba(92, 72, 52, 0.1);
      background: rgba(255, 255, 255, 0.56);
    }
    .explorer-shell .inspector-banner-title {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.92rem;
      font-weight: 650;
    }
    .explorer-shell .inspector-banner-copy {
      color: var(--explorer-muted);
      font-size: 0.8rem;
      line-height: 1.55;
    }
    .explorer-shell .inspector-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 0.72rem 0.82rem;
      border-radius: 12px;
      border: 1px solid rgba(92, 72, 52, 0.1);
      background: rgba(255, 255, 255, 0.56);
    }
    .explorer-shell .inspector-key {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .inspector-value {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.88rem;
      font-weight: 600;
      text-align: right;
    }
    .explorer-shell .dock-row {
      display: grid;
      gap: 0.45rem;
      padding: 0.85rem 0.9rem;
      border-radius: 14px;
      border: 1px solid rgba(92, 72, 52, 0.1);
      background: rgba(255, 255, 255, 0.56);
    }
    .explorer-shell .dock-row-head {
      display: grid;
      grid-template-columns: 1.5rem minmax(0, 1fr) auto;
      gap: 0.6rem;
      align-items: center;
    }
    .explorer-shell .dock-row-index {
      width: 1.5rem;
      height: 1.5rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      background: rgba(164, 74, 29, 0.08);
      border: 1px solid rgba(164, 74, 29, 0.14);
      color: var(--explorer-accent);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      font-weight: 700;
    }
    .explorer-shell .dock-row-label {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .dock-row-value {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.86rem;
      font-weight: 600;
      text-align: right;
    }
    .explorer-shell .dock-row-note {
      color: var(--explorer-muted);
      font-size: 0.8rem;
      line-height: 1.55;
    }
    .explorer-shell .dock-footer {
      display: grid;
      gap: 0.3rem;
      padding: 0.9rem 0.95rem;
      border-radius: 14px;
      border: 1px solid rgba(164, 74, 29, 0.12);
      background: linear-gradient(180deg, rgba(164, 74, 29, 0.05), rgba(164, 74, 29, 0.02));
    }
    .explorer-shell .dock-footer-label {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .dock-footer-copy {
      color: var(--explorer-fg);
      font-size: 0.82rem;
      line-height: 1.58;
    }
    .explorer-shell .guide-item {
      display: grid;
      grid-template-columns: 2rem minmax(0, 1fr);
      gap: 0.75rem;
      align-items: start;
      padding: 0.9rem;
      border-radius: 14px;
      border: 1px solid rgba(92, 72, 52, 0.1);
      background: rgba(255, 255, 255, 0.6);
    }
    .explorer-shell .guide-item-label {
      color: var(--explorer-stage-muted);
      font-family: var(--font-ui);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .guide-item-value {
      margin-top: 0.25rem;
      color: var(--explorer-fg);
      font-size: 1.02rem;
      line-height: 1.3;
    }
    .explorer-shell .guide-item-note {
      margin-top: 0.28rem;
      color: var(--explorer-stage-muted);
      font-size: 0.82rem;
      line-height: 1.58;
    }
    .explorer-shell .spark-wrap {
      padding: 0.7rem 0.8rem;
      border-radius: 14px;
      border: 1px solid rgba(92, 72, 52, 0.1);
      background: rgba(255, 255, 255, 0.56);
      overflow-x: auto;
    }
    .explorer-shell .spark {
      width: 260px;
      height: 50px;
      display: block;
    }
    .explorer-shell .inspector-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .explorer-shell table.small {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    .explorer-shell table.small th,
    .explorer-shell table.small td {
      border: 1px solid rgba(92, 72, 52, 0.1);
      padding: 0.42rem 0.52rem;
      text-align: right;
    }
    .explorer-shell table.small th:first-child,
    .explorer-shell table.small td:first-child {
      text-align: left;
    }
    .explorer-shell .preset-flash {
      animation: presetFlash 0.8s ease;
    }
    @keyframes presetFlash {
      0% { box-shadow: 0 0 0 0 rgba(104, 198, 193, 0.28); }
      50% { box-shadow: 0 0 0 16px rgba(104, 198, 193, 0.1); }
      100% { box-shadow: 0 0 0 0 rgba(104, 198, 193, 0); }
    }
    .explorer-shell .computed-flash {
      animation: computedFlash 0.9s ease;
    }
    @keyframes computedFlash {
      0% { box-shadow: 0 0 0 0 rgba(239, 180, 99, 0.18); }
      40% { box-shadow: 0 0 0 12px rgba(239, 180, 99, 0.12); }
      100% { box-shadow: 0 0 0 0 rgba(239, 180, 99, 0); }
    }
    @media (max-width: 1080px) {
      .explorer-shell .workspace-header,
      .explorer-shell .workspace-layout,
      .explorer-shell .inspector-grid {
        grid-template-columns: 1fr;
      }
      .explorer-shell .toolbar-group-note {
        grid-column: auto;
      }
      .explorer-shell .workspace-main {
        order: 1;
      }
      .explorer-shell .control-column {
        order: 2;
      }
    }
    @media (max-width: 720px) {
      .explorer-shell {
        --grid-axis-w: 68px;
        --grid-cell-w: 42px;
      }
      .explorer-shell .hero-card,
      .explorer-shell .panel-card,
      .explorer-shell .support-card,
      .explorer-shell .workspace-toolbar,
      .explorer-shell .stage-panel,
      .explorer-shell .grid-card,
      .explorer-shell .analysis-card {
        padding: 0.95rem;
        border-radius: 18px;
      }
      .explorer-shell .control-grid,
      .explorer-shell .toolbar-grid,
      .explorer-shell .scene-fact-grid,
      .explorer-shell .stage-summary-grid {
        grid-template-columns: 1fr;
      }
      .explorer-shell .stage-grid {
        max-height: 22rem;
      }
    }
  </style>

  <Nav />

  <main class="page essay-page explorer-page">
    <header class="essay-header page-header">
      <div>
        {page.data.eyebrow && <span class="page-eyebrow">{page.data.eyebrow}</span>}
        <h1 class="page-title">{page.data.title}</h1>
        {page.data.lede && <p class="page-lede">{page.data.lede}</p>}
        <div class="page-meta">
          <span class="pill">Rows are training worlds</span>
          <span class="pill">Columns are evaluation slices</span>
          <span class="pill">Guided examples are built in</span>
        </div>
      </div>

      <aside class="essay-side">
        {headerNote?.label && <p class="note-label">{headerNote.label}</p>}
        {renderMarkdownBlocks(headerNote?.body ?? []).map((html) => (
          <div set:html={html}></div>
        ))}
      </aside>
    </header>

    <section class="essay-section">
      <div class="essay-main">
        <h2>{introSection.title}</h2>
        <div set:html={introSection.html}></div>
        <ul class="tip-list">
          {quickTips.map((tip) => (
            <li>{tip}</li>
          ))}
        </ul>
      </div>

      <aside class="essay-side">
        {companionNote?.label && <p class="note-label">{companionNote.label}</p>}
        {renderMarkdownBlocks(companionNote?.body ?? []).map((html) => (
          <div set:html={html}></div>
        ))}
        <ul class="explorer-link-list">
          {companionLinks.map((link) => (
            <li><a href={link.href}>{link.title}</a></li>
          ))}
        </ul>
      </aside>
    </section>

    <section class="section-card explorer-frame" id="explore" aria-label="Explore">
      <div class="explorer-shell">
        <Explorer client:load />
      </div>
    </section>
  </main>
</Layout>
