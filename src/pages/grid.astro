---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Explorer from "../components/Explorer.jsx";
import { getRequiredPageEntry, splitMarkdownSections } from "../lib/page-content";

const page = await getRequiredPageEntry("grid");
const sections = splitMarkdownSections(page.body);
const introSection = sections.find(
  (section) => section.id === "how-to-read-the-toy" || section.id === "how-to-read-this",
) ?? sections[0];

if (!introSection) {
  throw new Error("Missing intro section for the grid explorer.");
}
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style is:global>
    .explorer-page {
      display: grid;
      gap: 1rem;
    }
    .explorer-page .page-header {
      margin-bottom: 0;
      display: grid;
      grid-template-columns: minmax(19rem, 24rem) minmax(0, 1fr);
      gap: 1.25rem;
      align-items: start;
    }
    .explorer-page .page-title {
      margin-bottom: 0;
    }
    .grid-read-note {
      display: grid;
      gap: 0.35rem;
      padding: 0.95rem 1.1rem;
      border-radius: 14px;
      border: 1px solid rgba(92, 72, 52, 0.12);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0)),
        rgba(250, 244, 235, 0.86);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
      align-self: start;
    }
    .grid-read-note-label {
      color: var(--ring-thick);
      font-family: var(--font-ui);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .grid-read-note :where(p) {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }
    .explorer-page-signpost {
      display: grid;
      gap: 0.95rem;
      padding: 1.05rem 1.15rem;
      border-radius: 18px;
      border: 1px solid rgba(92, 72, 52, 0.12);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0)),
        linear-gradient(135deg, rgba(45, 115, 133, 0.08), rgba(191, 134, 66, 0.08));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 16px 32px rgba(88, 64, 42, 0.05);
    }
    .explorer-page-signpost-head {
      display: grid;
      gap: 0.35rem;
    }
    .explorer-page-signpost-kicker {
      color: #2d7385;
      font-family: var(--font-ui);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-page-signpost-title {
      margin: 0;
      color: #10273d;
      font-family: var(--font-ui);
      font-size: clamp(1.08rem, 2vw, 1.4rem);
      font-weight: 650;
      line-height: 1.18;
      letter-spacing: -0.03em;
    }
    .explorer-page-signpost-copy {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
      max-width: 70rem;
    }
    .explorer-signpost-steps,
    .explorer-scenario-grid {
      display: grid;
      gap: 0.75rem;
      grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    }
    .explorer-signpost-step,
    .explorer-scenario-card {
      display: grid;
      gap: 0.38rem;
      padding: 0.88rem 0.95rem;
      border-radius: 14px;
      border: 1px solid rgba(33, 65, 95, 0.12);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
        rgba(251, 254, 255, 0.78);
    }
    .explorer-signpost-step-number {
      width: 1.7rem;
      height: 1.7rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      border: 1px solid rgba(47, 92, 126, 0.18);
      background: rgba(47, 92, 126, 0.08);
      color: #2f5c7e;
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 700;
      line-height: 1;
    }
    .explorer-signpost-step-title,
    .explorer-scenario-card h3 {
      margin: 0;
      color: #10273d;
      font-family: var(--font-ui);
      font-size: 0.94rem;
      font-weight: 650;
      line-height: 1.35;
    }
    .explorer-signpost-step-copy,
    .explorer-scenario-card p {
      margin: 0;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.62;
    }
    .explorer-scenario-drawer {
      display: grid;
      gap: 0.9rem;
      padding: 0.95rem 1rem;
      border-radius: 16px;
      border: 1px solid rgba(33, 65, 95, 0.12);
      background: rgba(255, 255, 255, 0.66);
    }
    .explorer-scenario-drawer summary {
      cursor: pointer;
      color: #10273d;
      font-family: var(--font-ui);
      font-size: 0.92rem;
      font-weight: 650;
      line-height: 1.35;
    }
    .explorer-scenario-drawer[open] summary {
      margin-bottom: 0.85rem;
    }
    .explorer-frame {
      padding: 0.22rem;
      background:
        linear-gradient(180deg, rgba(34, 29, 25, 0.08), rgba(34, 29, 25, 0.02)),
        rgba(255, 250, 243, 0.56);
    }
    .explorer-shell {
      --explorer-surface: rgba(240, 246, 250, 0.96);
      --explorer-surface-strong: rgba(250, 253, 255, 0.98);
      --explorer-surface-soft: rgba(214, 227, 235, 0.84);
      --explorer-border: rgba(33, 65, 95, 0.14);
      --explorer-border-strong: rgba(33, 65, 95, 0.24);
      --explorer-fg: #10273d;
      --explorer-muted: #5d7083;
      --explorer-accent: #2f5c7e;
      --explorer-accent-soft: rgba(47, 92, 126, 0.12);
      --explorer-stage-fg: #10273d;
      --explorer-stage-muted: #607487;
      --ring-thin: #bf8642;
      --ring-thick: #2d7385;
      --ring-select: #10273d;
      --grid-surface: #edf4f8;
      --grid-surface-soft: #d6e3eb;
      --grid-axis-w: 108px;
      --grid-cell-w: 58px;
      --explorer-radius-xl: 18px;
      --explorer-radius-lg: 14px;
      --explorer-radius-md: 12px;
      --explorer-radius-sm: 10px;
    }
    .explorer-shell .workspace-shell {
      display: grid;
      gap: 1rem;
      max-width: 1180px;
      margin: 0 auto;
    }
    .explorer-shell .workspace-header {
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) minmax(20rem, 0.82fr);
      gap: clamp(1rem, 2vw, 1.6rem);
      padding: clamp(1.25rem, 2vw, 1.7rem);
      border-radius: 26px;
      border: 1px solid var(--explorer-border-strong);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 18%),
        radial-gradient(circle at top right, rgba(164, 74, 29, 0.08), transparent 30%),
        linear-gradient(180deg, rgba(247, 242, 235, 0.98), rgba(238, 229, 216, 0.96));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 22px 42px rgba(88, 64, 42, 0.08);
    }
    .explorer-shell .header-main,
    .explorer-shell .preset-dock,
    .explorer-shell .control-column,
    .explorer-shell .workspace-main {
      display: grid;
      gap: 1rem;
      min-width: 0;
    }
    .explorer-shell .header-main {
      align-content: start;
    }
    .explorer-shell .header-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      flex-wrap: wrap;
    }
    .explorer-shell .header-command {
      display: grid;
      gap: 0.45rem;
      padding: 1rem 1.05rem;
      border-radius: var(--explorer-radius-lg);
      border: 1px solid rgba(92, 72, 52, 0.12);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0)),
        rgba(255, 252, 248, 0.74);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
    }
    .explorer-shell .header-command-label,
    .explorer-shell .header-status-label {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .header-command-line {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: clamp(1rem, 1.8vw, 1.35rem);
      font-weight: 650;
      line-height: 1.28;
      letter-spacing: -0.03em;
    }
    .explorer-shell .header-command-trace {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      line-height: 1.55;
    }
    .explorer-shell .header-status-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 0.7rem;
    }
    .explorer-shell .header-status {
      display: grid;
      gap: 0.22rem;
      padding: 0.88rem 0.92rem;
      border-radius: var(--explorer-radius-md);
      border: 1px solid rgba(92, 72, 52, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
        rgba(255, 252, 247, 0.7);
    }
    .explorer-shell .header-status-accent {
      background:
        linear-gradient(180deg, rgba(239, 180, 99, 0.18), rgba(239, 180, 99, 0.04)),
        rgba(255, 250, 240, 0.78);
      border-color: rgba(239, 180, 99, 0.24);
    }
    .explorer-shell .header-status-value {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.96rem;
      font-weight: 650;
      line-height: 1.3;
    }
    .explorer-shell .summary-kicker {
      display: inline-block;
      color: var(--explorer-accent);
      font-family: var(--font-ui);
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .card-title,
    .explorer-shell .panel-title,
    .explorer-shell .stage-title,
    .explorer-shell .grid-card-title {
      font-family: var(--font-ui);
      font-weight: 650;
    }
    .explorer-shell .hero-card,
    .explorer-shell .panel-card,
    .explorer-shell .support-card {
      display: grid;
      gap: 0.9rem;
      padding: 1.1rem;
      border-radius: var(--explorer-radius-xl);
      border: 1px solid var(--explorer-border);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0)),
        var(--explorer-surface);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 14px 26px rgba(88, 64, 42, 0.06);
    }
    .explorer-shell .preset-card {
      align-content: start;
      min-height: 100%;
    }
    .explorer-shell .preset-card-head {
      align-items: center;
    }
    .explorer-shell .card-head,
    .explorer-shell .panel-head,
    .explorer-shell .grid-card-head,
    .explorer-shell .analysis-head,
    .explorer-shell .stage-head {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.8rem;
    }
    .explorer-shell .card-title,
    .explorer-shell .panel-title,
    .explorer-shell .grid-card-title {
      margin: 0.2rem 0 0;
      font-size: 1.08rem;
      line-height: 1.16;
      letter-spacing: -0.03em;
    }
    .explorer-shell .panel-copy,
    .explorer-shell .grid-card-copy,
    .explorer-shell .analysis-copy {
      margin: 0;
      color: var(--explorer-muted);
      font-size: 0.87rem;
      line-height: 1.62;
    }
    .explorer-shell .status-banner,
    .explorer-shell .inline-note,
    .explorer-shell .story-note {
      padding: 0.85rem 1rem;
      border-radius: var(--explorer-radius-md);
      border: 1px solid rgba(47, 92, 126, 0.14);
      background: linear-gradient(180deg, rgba(47, 92, 126, 0.08), rgba(47, 92, 126, 0.03));
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.84rem;
      line-height: 1.55;
    }
    .explorer-shell .summary-inline,
    .explorer-shell .segmented-row,
    .explorer-shell .mode-toggle,
    .explorer-shell .export-actions,
    .explorer-shell .focus-chip-row,
    .explorer-shell .question-button-row,
    .explorer-shell .slider-row,
    .explorer-shell .checkbox-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.55rem;
      min-width: 0;
    }
    .explorer-shell .pill {
      display: inline-block;
      padding: 0.28rem 0.65rem;
      border: 1px solid rgba(92, 72, 52, 0.12);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.72);
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.71rem;
    }
    .explorer-shell .btn {
      border: 1px solid var(--explorer-border);
      background: var(--explorer-surface-strong);
      color: var(--explorer-fg);
      padding: 0.58rem 0.84rem;
      border-radius: var(--explorer-radius-sm);
      cursor: pointer;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      line-height: 1.2;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, box-shadow 160ms ease;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }
    .explorer-shell .btn:hover,
    .explorer-shell .btn:focus-visible,
    .explorer-shell .tutorial-btn:hover,
    .explorer-shell .tutorial-btn:focus-visible {
      transform: translateY(-1px);
      border-color: rgba(47, 92, 126, 0.28);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.72),
        0 10px 18px rgba(27, 56, 84, 0.08);
    }
    .explorer-shell .btn[aria-pressed="true"] {
      border-color: rgba(47, 92, 126, 0.34);
      background: var(--explorer-accent-soft);
      box-shadow: inset 0 0 0 1px rgba(47, 92, 126, 0.14);
    }
    .explorer-shell .btn:disabled {
      cursor: not-allowed;
      opacity: 0.46;
      transform: none;
      border-color: var(--explorer-border);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.46);
    }
    .explorer-shell .btn:disabled:hover,
    .explorer-shell .btn:disabled:focus-visible {
      transform: none;
      border-color: var(--explorer-border);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.46);
    }
    .explorer-shell .btn.ghost {
      background: transparent;
    }
    .explorer-shell .btn.mini {
      padding: 0.48rem 0.74rem;
      font-size: 0.76rem;
    }
    .explorer-shell input[type="range"],
    .explorer-shell select,
    .explorer-shell input[type="checkbox"] {
      background: var(--explorer-surface-strong);
      color: var(--explorer-fg);
      border: 1px solid var(--explorer-border);
      border-radius: var(--explorer-radius-sm);
      padding: 0.68rem 0.86rem;
      font: inherit;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
    }
    .explorer-shell .slider-row input[type="range"] {
      flex: 1 1 11rem;
      min-width: 8rem;
    }
    .explorer-shell .checkbox-row {
      color: var(--explorer-fg);
      font-size: 0.88rem;
    }
    .explorer-shell .checkbox-row input[type="checkbox"] {
      width: auto;
      padding: 0;
    }
    .explorer-shell .tutorials {
      display: grid;
      gap: 0.65rem;
    }
    .explorer-shell .tutorial-btn {
      border: 1px solid var(--explorer-border);
      background: rgba(255, 255, 255, 0.76);
      color: var(--explorer-fg);
      text-align: left;
      padding: 0.85rem 0.95rem;
      border-radius: var(--explorer-radius-md);
      cursor: pointer;
      font-size: 0.84rem;
      line-height: 1.35;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    }
    .explorer-shell .tutorial-btn.active {
      border-color: rgba(47, 92, 126, 0.34);
      box-shadow: inset 0 0 0 1px rgba(47, 92, 126, 0.18);
      background: rgba(47, 92, 126, 0.08);
    }
    .explorer-shell .tutorial-title {
      display: block;
      font-weight: 600;
    }
    .explorer-shell .tutorial-desc {
      display: block;
      margin-top: 0.2rem;
      color: var(--explorer-muted);
      font-size: 0.82rem;
    }
    .explorer-shell .tutorial-note {
      padding: 0.9rem 1rem;
      border-radius: 14px;
      border: 1px solid var(--explorer-border);
      background: rgba(255, 255, 255, 0.7);
      color: var(--explorer-muted);
      font-size: 0.82rem;
      line-height: 1.6;
    }
    .explorer-shell .workspace-layout {
      display: grid;
      grid-template-columns: minmax(18rem, 23rem) minmax(0, 1fr);
      gap: clamp(1rem, 2vw, 1.6rem);
      align-items: start;
      padding: 1rem;
      border-radius: 28px;
      border: 1px solid var(--explorer-border-strong);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.58), rgba(255, 255, 255, 0) 15%),
        linear-gradient(180deg, rgba(243, 236, 227, 0.98), rgba(235, 226, 212, 0.98));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.78),
        0 28px 50px rgba(88, 64, 42, 0.09);
    }
    .explorer-shell .workspace-main {
      grid-template-columns: minmax(0, 1fr) minmax(20rem, 24rem);
      align-items: start;
      gap: clamp(1rem, 2vw, 1.35rem);
    }
    .explorer-shell .control-column {
      align-content: start;
      align-self: start;
      position: sticky;
      top: clamp(0.85rem, 2vw, 1.2rem);
      z-index: 1;
    }
    .explorer-shell .workspace-toolbar {
      display: grid;
      gap: 0.85rem;
      padding: 0.92rem 1rem;
      border-radius: var(--explorer-radius-xl);
      border: 1px solid var(--explorer-border-strong);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0)),
        linear-gradient(180deg, rgba(244, 250, 253, 0.98), rgba(232, 241, 247, 0.98));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.8),
        0 16px 30px rgba(27, 56, 84, 0.08);
    }
    .explorer-shell .toolbar-bar {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      padding-bottom: 0.82rem;
      border-bottom: 1px solid rgba(33, 65, 95, 0.1);
    }
    .explorer-shell .toolbar-guide {
      display: grid;
      gap: 0.22rem;
      flex: 1 1 30rem;
      min-width: 0;
    }
    .explorer-shell .toolbar-guide-copy {
      margin: 0;
      color: var(--explorer-muted);
      font-size: 0.86rem;
      line-height: 1.55;
      max-width: 46rem;
    }
    .explorer-shell .toolbar-summary-label {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .explorer-shell .toolbar-summary-title {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.92rem;
      font-weight: 650;
      line-height: 1.35;
    }
    .explorer-shell .toolbar-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 0.75rem;
      align-items: start;
    }
    .explorer-shell .toolbar-group {
      display: grid;
      gap: 0.6rem;
      padding: 0.82rem 0.88rem;
      border-radius: var(--explorer-radius-lg);
      border: 1px solid rgba(33, 65, 95, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(255, 255, 255, 0)),
        rgba(251, 254, 255, 0.78);
      min-width: 0;
      align-content: start;
    }
    .explorer-shell details.toolbar-group {
      padding: 0.82rem 0.88rem;
      margin: 0;
    }
    .explorer-shell .toolbar-group-actions {
      align-content: start;
    }
    .explorer-shell .toolbar-label {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .toolbar-note {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      line-height: 1.55;
    }
    .explorer-shell .toolbar-pills {
      margin-top: 0.1rem;
    }
    .explorer-shell .toolbar-summary {
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      min-width: 0;
    }
    .explorer-shell .toolbar-summary::-webkit-details-marker {
      display: none;
    }
    .explorer-shell .toolbar-summary-copy {
      display: grid;
      gap: 0.12rem;
      min-width: 0;
      flex: 1 1 auto;
    }
    .explorer-shell .toolbar-summary-actions {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      flex: 0 0 auto;
    }
    .explorer-shell .toolbar-summary-caret {
      width: 0.55rem;
      height: 0.55rem;
      border-right: 1.5px solid var(--explorer-muted);
      border-bottom: 1.5px solid var(--explorer-muted);
      transform: rotate(45deg);
      transition: transform 160ms ease;
    }
    .explorer-shell details[open] > .toolbar-summary .toolbar-summary-caret {
      transform: rotate(225deg);
    }
    .explorer-shell .toolbar-expanded {
      display: grid;
      gap: 0.75rem;
      margin-top: 0.75rem;
    }
    .explorer-shell .toolbar-question-line {
      margin: 0;
      color: var(--explorer-fg);
      font-size: 0.93rem;
      line-height: 1.48;
    }
    .explorer-shell .toolbar-fact-grid,
