---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import ExplorerPageShell from "../components/ExplorerPageShell.astro";
import Explorer from "../components/Explorer.jsx";
import { getRequiredPageEntry, splitMarkdownDocument } from "../lib/page-content";

const page = await getRequiredPageEntry("grid");
const { sections: helpSections } = splitMarkdownDocument(page.body);

if (!helpSections.length) {
  throw new Error("Missing help sections for the grid explorer.");
}
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style is:global>
    body:has(.explorer-page) {
      background: #f5eee3;
    }
    .explorer-shell {
      --explorer-surface: rgba(250, 246, 238, 0.96);
      --explorer-surface-strong: rgba(255, 251, 243, 0.98);
      --explorer-surface-soft: rgba(228, 234, 226, 0.84);
      --explorer-border: rgba(91, 73, 54, 0.16);
      --explorer-border-strong: rgba(48, 106, 108, 0.24);
      --explorer-fg: #1d2f35;
      --explorer-muted: #6f695f;
      --explorer-accent: #2f6f73;
      --explorer-accent-soft: rgba(47, 111, 115, 0.12);
      --explorer-stage-fg: #1d2f35;
      --explorer-stage-muted: #716b62;
      --explorer-hud-line: rgba(47, 111, 115, 0.12);
      --explorer-hud-line-soft: rgba(255, 255, 255, 0.4);
      --explorer-hud-glow: rgba(47, 111, 115, 0.16);
      --explorer-warning-soft: rgba(184, 117, 67, 0.18);
      --ring-thin: #b87543;
      --ring-thick: #2f6f73;
      --ring-select: #1d2f35;
      --grid-surface: #edf1ea;
      --grid-surface-soft: #dce5db;
      --grid-axis-w: 108px;
      --grid-cell-w: 58px;
    }
    .explorer-shell .workspace-shell {
      display: grid;
      gap: 1rem;
      width: min(100%, calc(100vw - 4rem));
      max-width: 1180px;
      margin: 0 auto;
    }
    .explorer-shell .workspace-toolbar,
    .explorer-shell .toolbar-group,
    .explorer-shell .control-cluster,
    .explorer-shell .stage-panel,
    .explorer-shell .grid-card {
      position: relative;
      overflow: clip;
      isolation: isolate;
    }
    .explorer-shell .workspace-toolbar::before,
    .explorer-shell .toolbar-group::before,
    .explorer-shell .control-cluster::before,
    .explorer-shell .stage-panel::before,
    .explorer-shell .grid-card::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.24), transparent 38%),
        repeating-linear-gradient(90deg, transparent 0 22px, rgba(47, 92, 126, 0.03) 22px 23px),
        linear-gradient(180deg, rgba(47, 92, 126, 0.08), transparent 22%);
      pointer-events: none;
      opacity: 0.72;
    }
    .explorer-shell .workspace-toolbar::after,
    .explorer-shell .stage-panel::after,
    .explorer-shell .grid-card::after {
      content: "";
      position: absolute;
      inset: 10px;
      border-radius: var(--explorer-inset-radius, inherit);
      border: 1px solid rgba(255, 255, 255, 0.26);
      pointer-events: none;
      opacity: 0.65;
    }
    .explorer-shell .workspace-main {
      display: grid;
      gap: 1rem;
      min-width: 0;
    }
    .explorer-shell .card-title,
    .explorer-shell .panel-title,
    .explorer-shell .grid-card-title {
      font-family: var(--font-ui);
      font-weight: 650;
    }
    .explorer-shell .panel-head,
    .explorer-shell .grid-card-head {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.8rem;
    }
    .explorer-shell .card-title,
    .explorer-shell .panel-title,
    .explorer-shell .grid-card-title {
      margin: 0.2rem 0 0;
      font-size: 1.08rem;
      line-height: 1.16;
      letter-spacing: 0;
    }
    .explorer-shell .panel-copy {
      margin: 0;
      color: var(--explorer-muted);
      font-size: 0.87rem;
      line-height: 1.62;
    }
    .explorer-shell .segmented-row,
    .explorer-shell .focus-token-row,
    .explorer-shell .slider-row,
    .explorer-shell .checkbox-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.55rem;
      min-width: 0;
    }
    .explorer-shell .btn {
      border: 1px solid rgba(33, 65, 95, 0.18);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(234, 243, 248, 0.9)),
        var(--explorer-surface-strong);
      color: var(--explorer-fg);
      padding: 0.58rem 0.84rem;
      border-radius: var(--explorer-radius-sm);
      cursor: pointer;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      font-weight: 650;
      letter-spacing: 0.03em;
      line-height: 1.2;
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        background 160ms ease,
        box-shadow 160ms ease,
        filter 160ms ease;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        inset 0 -1px 0 rgba(33, 65, 95, 0.05),
        0 0 0 1px rgba(255, 255, 255, 0.18),
        0 10px 18px rgba(19, 38, 58, 0.08);
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.42);
    }
    .explorer-shell .btn:hover,
    .explorer-shell .btn:focus-visible,
    .explorer-shell .tutorial-btn:hover,
    .explorer-shell .tutorial-btn:focus-visible {
      transform: translateY(-1px);
      border-color: rgba(47, 92, 126, 0.34);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(240, 248, 252, 0.96)),
        var(--explorer-surface-strong);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.9),
        inset 0 -1px 0 rgba(33, 65, 95, 0.05),
        0 0 0 1px rgba(47, 92, 126, 0.1),
        0 12px 22px rgba(27, 56, 84, 0.12);
      filter: saturate(1.04);
    }
    .explorer-shell .btn[aria-pressed="true"] {
      border-color: rgba(45, 115, 133, 0.4);
      background:
        linear-gradient(180deg, rgba(211, 232, 239, 0.92), rgba(186, 216, 229, 0.72)),
        var(--explorer-accent-soft);
      box-shadow:
        inset 0 0 0 1px rgba(47, 92, 126, 0.14),
        inset 0 1px 0 rgba(255, 255, 255, 0.52),
        0 0 0 1px rgba(45, 115, 133, 0.12),
        0 12px 20px rgba(27, 56, 84, 0.1);
    }
    .explorer-shell .btn:active,
    .explorer-shell .tutorial-btn:active,
    .explorer-shell .axis-corner-btn:active {
      transform: translateY(0);
    }
    .explorer-shell .btn:disabled {
      cursor: not-allowed;
      opacity: 0.46;
      transform: none;
      border-color: var(--explorer-border);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.46);
    }
    .explorer-shell .btn:disabled:hover,
    .explorer-shell .btn:disabled:focus-visible {
      transform: none;
      border-color: var(--explorer-border);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.46);
    }
    .explorer-shell .btn.ghost {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.16)),
        transparent;
    }
    .explorer-shell .btn.mini {
      padding: 0.48rem 0.74rem;
      font-size: 0.76rem;
    }
    .explorer-shell input[type="range"],
    .explorer-shell select,
    .explorer-shell input[type="checkbox"] {
      background: var(--explorer-surface-strong);
      color: var(--explorer-fg);
      border: 1px solid var(--explorer-border);
      border-radius: var(--explorer-radius-sm);
      padding: 0.68rem 0.86rem;
      font: inherit;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.76),
        inset 0 -1px 0 rgba(33, 65, 95, 0.04);
      transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
      accent-color: var(--ring-thick);
    }
    .explorer-shell input[type="range"]:hover,
    .explorer-shell input[type="range"]:focus-visible,
    .explorer-shell select:hover,
    .explorer-shell select:focus-visible,
    .explorer-shell input[type="checkbox"]:focus-visible {
      border-color: rgba(47, 92, 126, 0.28);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 0 0 1px rgba(47, 92, 126, 0.1),
        0 8px 16px rgba(27, 56, 84, 0.08);
    }
    .explorer-shell .slider-row input[type="range"] {
      flex: 1 1 11rem;
      min-width: 8rem;
    }
    .explorer-shell .checkbox-row {
      color: var(--explorer-fg);
      font-size: 0.88rem;
    }
    .explorer-shell .checkbox-row input[type="checkbox"] {
      width: auto;
      padding: 0;
    }
    .explorer-shell .tutorials {
      display: grid;
      gap: 0.65rem;
    }
    .explorer-shell .tutorial-btn {
      border: 1px solid rgba(33, 65, 95, 0.16);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(241, 247, 251, 0.82)),
        rgba(255, 255, 255, 0.76);
      color: var(--explorer-fg);
      text-align: left;
      padding: 0.85rem 0.95rem;
      border-radius: var(--explorer-radius-md);
      cursor: pointer;
      font-size: 0.84rem;
      line-height: 1.35;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    }
    .explorer-shell .tutorial-btn.active {
      border-color: rgba(45, 115, 133, 0.34);
      box-shadow:
        inset 0 0 0 1px rgba(47, 92, 126, 0.18),
        0 0 0 1px rgba(45, 115, 133, 0.1),
        0 12px 20px rgba(27, 56, 84, 0.08);
      background:
        linear-gradient(180deg, rgba(219, 238, 244, 0.88), rgba(199, 224, 233, 0.72)),
        rgba(47, 92, 126, 0.08);
    }
    .explorer-shell .tutorial-title {
      display: block;
      font-weight: 600;
    }
    .explorer-shell .tutorial-desc {
      display: block;
      margin-top: 0.2rem;
      color: var(--explorer-muted);
      font-size: 0.82rem;
    }
    .explorer-shell .workspace-main {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
      gap: clamp(1rem, 2vw, 1.35rem);
    }
    .explorer-shell .workspace-toolbar {
      --explorer-inset-radius: calc(var(--explorer-radius-xl) - 3px);
      display: grid;
      gap: 0.7rem;
      padding: 0.72rem;
      border-radius: var(--explorer-radius-xl);
      border: 1px solid var(--explorer-border-strong);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0)),
        linear-gradient(180deg, rgba(244, 250, 253, 0.94), rgba(232, 241, 247, 0.9));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.8),
        0 10px 22px rgba(27, 56, 84, 0.07);
    }
    .explorer-shell .toolbar-bar {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      align-items: stretch;
      justify-content: space-between;
      gap: 0.75rem;
      padding-bottom: 0.7rem;
      border-bottom: 1px solid rgba(33, 65, 95, 0.1);
    }
    .explorer-shell .toolbar-action-strip {
      display: inline-flex;
      flex-wrap: wrap;
      align-content: start;
      gap: 0.45rem;
      min-width: 9rem;
    }
    .explorer-shell .toolbar-action-link {
      min-height: 1.9rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.36rem 0.62rem;
      border-radius: var(--explorer-radius-sm);
      border: 1px solid rgba(33, 65, 95, 0.12);
      background: rgba(255, 255, 255, 0.58);
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: 650;
      letter-spacing: 0;
      text-decoration: none;
      appearance: none;
      cursor: pointer;
    }
    .explorer-shell .toolbar-action-link:focus-visible {
      outline: 2px solid rgba(45, 115, 133, 0.34);
      outline-offset: 2px;
    }
    .explorer-shell .toolbar-guide {
      display: grid;
      gap: 0.52rem;
      min-width: 0;
    }
    .explorer-shell .explorer-mode-switch {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
    }
    .explorer-shell .panel-heading-group {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      min-width: 0;
    }
    .explorer-shell .panel-heading-group > div {
      display: grid;
      gap: 0.12rem;
      min-width: 0;
    }
    .explorer-shell .toolbar-guide-copy {
      margin: 0;
      color: var(--explorer-muted);
      font-size: 0.82rem;
      line-height: 1.42;
      max-width: 46rem;
    }
    .explorer-shell .toolbar-selection-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }
    .explorer-shell .toolbar-selection-item {
      display: grid;
      gap: 0.1rem;
      min-width: 7.5rem;
      padding: 0.48rem 0.58rem;
      border-radius: var(--explorer-radius-sm);
      border: 1px solid rgba(33, 65, 95, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
        rgba(251, 254, 255, 0.72);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
    }
    .explorer-shell .toolbar-selection-item-label {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .toolbar-selection-item-value {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: 650;
      line-height: 1.32;
    }
    .explorer-shell .toolbar-summary-label {
      display: block;
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.68rem;
      font-weight: 700;
      line-height: 1.35;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .explorer-shell .toolbar-summary-title {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.92rem;
      font-weight: 650;
      line-height: 1.35;
    }
    .explorer-shell .toolbar-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
      gap: 0.62rem;
      align-items: start;
    }
    .explorer-shell .toolbar-group {
      display: grid;
      gap: 0.48rem;
      padding: 0.64rem 0.68rem;
      border-radius: var(--explorer-radius-md);
      border: 1px solid rgba(33, 65, 95, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0)),
        rgba(251, 254, 255, 0.64);
      min-width: 0;
      align-content: start;
    }
    .explorer-shell .toolbar-group-primary {
      gap: 0.7rem;
    }
    .explorer-shell details.toolbar-group {
      padding: 0.64rem 0.68rem;
      margin: 0;
    }
    .explorer-shell .toolbar-group-actions {
      align-content: start;
    }
    .explorer-shell .toolbar-group-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.7rem;
    }
    .explorer-shell .toolbar-group-head-copy {
      display: grid;
      gap: 0.14rem;
      min-width: 0;
    }
    .explorer-shell .toolbar-current-choice {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.98rem;
      font-weight: 650;
      line-height: 1.3;
      text-wrap: balance;
    }
    .explorer-shell .toolbar-label {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .toolbar-note {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      line-height: 1.55;
    }
    .explorer-shell .toolbar-field-hint {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .explorer-shell .toolbar-summary {
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      min-width: 0;
    }
    .explorer-shell .toolbar-summary::-webkit-details-marker {
      display: none;
    }
    .explorer-shell .toolbar-summary-copy {
      display: grid;
      gap: 0.12rem;
      min-width: 0;
      flex: 1 1 auto;
    }
    .explorer-shell .toolbar-summary-actions {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      flex: 0 0 auto;
    }
    .explorer-shell .toolbar-summary-caret {
      width: 0.55rem;
      height: 0.55rem;
      border-right: 1.5px solid var(--explorer-muted);
      border-bottom: 1.5px solid var(--explorer-muted);
      transform: rotate(45deg);
      transition: transform 160ms ease;
    }
    .explorer-shell details[open] > .toolbar-summary .toolbar-summary-caret {
      transform: rotate(225deg);
    }
    .explorer-shell .toolbar-expanded {
      display: grid;
      gap: 0.75rem;
      margin-top: 0.75rem;
    }
    .explorer-shell .toolbar-summary:focus-visible,
    .explorer-shell details summary:focus-visible {
      outline: var(--focus-outline);
      outline-offset: 4px;
      border-radius: 8px;
    }
    .explorer-shell .control-cluster {
      display: grid;
      gap: 0.6rem;
      padding: 0.95rem;
      border-radius: var(--explorer-radius-lg);
      border: 1px solid var(--explorer-border);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
        var(--explorer-surface-strong);
      min-width: 0;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
    }
    .explorer-shell .control-head {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.79rem;
      font-weight: 600;
      letter-spacing: 0.02em;
    }
    .explorer-shell .ctrl-note {
      color: var(--explorer-muted);
      font-size: 0.8rem;
      line-height: 1.55;
    }
    .explorer-shell .control-cluster select {
      width: 100%;
    }
    .explorer-shell .toolbar-select-field,
    .explorer-shell .grid-jump-field {
      display: grid;
      gap: 0.38rem;
      min-width: 0;
    }
    .explorer-shell .toolbar-select-field select,
    .explorer-shell .grid-jump-field select {
      width: 100%;
    }
    .explorer-shell details {
      background: var(--explorer-surface-strong);
      border: 1px solid var(--explorer-border);
      border-radius: var(--explorer-radius-lg);
      padding: 0.85rem 1rem;
    }
    .explorer-shell details summary {
      cursor: pointer;
      font-family: var(--font-ui);
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--explorer-fg);
    }
    .explorer-shell .json-block {
      background: #fbf8f4;
      border: 1px solid rgba(92, 72, 52, 0.12);
      border-radius: var(--explorer-radius-md);
      padding: 0.8rem;
      color: #5f554c;
      font-family: "SFMono-Regular", Consolas, Menlo, monospace;
      font-size: 12px;
      overflow: auto;
      line-height: 1.4;
    }
    .explorer-shell .stage-panel,
    .explorer-shell .grid-card {
      --explorer-inset-radius: calc(var(--explorer-radius-xl) - 3px);
      display: grid;
      gap: 0.95rem;
      padding: 1.15rem;
      border-radius: var(--explorer-radius-xl);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(255, 255, 255, 0)),
        linear-gradient(180deg, rgba(246, 251, 254, 0.98), rgba(236, 244, 249, 0.98));
      border: 1px solid rgba(33, 65, 95, 0.12);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.8),
        0 16px 30px rgba(27, 56, 84, 0.07);
      color: var(--explorer-stage-fg);
    }
    .explorer-shell .grid-card-outer {
      gap: clamp(1rem, 1.8vw, 1.22rem);
      padding: clamp(1.15rem, 2vw, 1.3rem);
      border-color: rgba(33, 65, 95, 0.14);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 18px 34px rgba(27, 56, 84, 0.08);
    }
    .explorer-shell .grid-card-outer::after {
      inset: 12px;
      border-color: rgba(255, 255, 255, 0.3);
      opacity: 0.72;
    }
    .explorer-shell .grid-card-outer .grid-card-head {
      padding-bottom: 0.9rem;
      border-bottom: 1px solid rgba(33, 65, 95, 0.08);
    }
    .explorer-shell .move-legend {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
      gap: 0.45rem;
      min-width: min(100%, 18rem);
      font-family: var(--font-ui);
    }
    .explorer-shell .move-key {
      display: inline-flex;
      align-items: center;
      gap: 0.38rem;
      min-height: 1.85rem;
      padding: 0.32rem 0.52rem;
      border-radius: var(--explorer-radius-sm);
      border: 1px solid rgba(33, 65, 95, 0.1);
      background: rgba(255, 255, 255, 0.58);
      color: var(--explorer-muted);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .explorer-shell .move-icon {
      width: 1.15rem;
      height: 1.15rem;
      position: relative;
      display: inline-block;
      border-radius: 5px;
      background: rgba(47, 92, 126, 0.08);
      box-shadow: inset 0 0 0 1px rgba(47, 92, 126, 0.12);
      flex: 0 0 auto;
    }
    .explorer-shell .move-icon::before {
      content: "";
      position: absolute;
