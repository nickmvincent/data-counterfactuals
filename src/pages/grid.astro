---
import Layout from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Explorer from "../components/Explorer.jsx";
import { getRequiredPageEntry, splitMarkdownSections } from "../lib/page-content";

const page = await getRequiredPageEntry("grid");
const sections = splitMarkdownSections(page.body);
const introSection = sections.find(
  (section) => section.id === "how-to-read-the-toy" || section.id === "how-to-read-this",
) ?? sections[0];

if (!introSection) {
  throw new Error("Missing intro section for the grid explorer.");
}
---

<Layout
  title={page.data.title}
  description={page.data.description}
>
  <style is:global>
    body:has(.explorer-page) {
      background:
        radial-gradient(circle at top left, rgba(36, 92, 112, 0.15), transparent 30%),
        radial-gradient(circle at top right, rgba(177, 119, 51, 0.12), transparent 24%),
        linear-gradient(180deg, #fbf7ef 0%, #f3ebdf 46%, #ebdfcf 100%);
    }
    .explorer-page {
      display: grid;
      gap: 1rem;
    }
    .explorer-page .page-header {
      width: min(100%, 56rem);
      margin: 0 auto;
      display: grid;
      gap: 0.7rem;
      justify-items: center;
      text-align: center;
    }
    .explorer-page .page-title {
      max-width: 34rem;
      margin: 0;
      font-size: clamp(1.65rem, 3.6vw, 2.5rem);
      line-height: 1.1;
      text-wrap: balance;
    }
    .explorer-help-stack {
      width: min(100%, 56rem);
      margin: 0 auto;
      display: grid;
      gap: 0.75rem;
    }
    .explorer-help-drawer {
      display: grid;
      gap: 0.8rem;
      padding: 0.95rem 1rem;
      border-radius: 16px;
      border: 1px solid rgba(33, 65, 95, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0)),
        rgba(255, 251, 246, 0.76);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 14px 26px rgba(88, 64, 42, 0.04);
    }
    .explorer-help-drawer summary {
      cursor: pointer;
      color: #10273d;
      font-family: var(--font-ui);
      font-size: 0.95rem;
      font-weight: 650;
      line-height: 1.35;
    }
    .explorer-help-drawer[open] summary {
      margin-bottom: 0.15rem;
    }
    .explorer-help-body {
      display: grid;
      gap: 0.7rem;
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.7;
    }
    .explorer-help-body :where(p, ul) {
      margin: 0;
    }
    .explorer-help-list {
      display: grid;
      gap: 0.45rem;
      padding-left: 1.1rem;
    }
    .explorer-help-list li {
      padding-left: 0.08rem;
    }
    .explorer-frame {
      padding: 0.22rem;
      background:
        linear-gradient(180deg, rgba(34, 29, 25, 0.08), rgba(34, 29, 25, 0.02)),
        rgba(255, 250, 243, 0.56);
    }
    .explorer-shell {
      --explorer-surface: rgba(240, 246, 250, 0.96);
      --explorer-surface-strong: rgba(250, 253, 255, 0.98);
      --explorer-surface-soft: rgba(214, 227, 235, 0.84);
      --explorer-border: rgba(33, 65, 95, 0.14);
      --explorer-border-strong: rgba(33, 65, 95, 0.24);
      --explorer-fg: #10273d;
      --explorer-muted: #5d7083;
      --explorer-accent: #2f5c7e;
      --explorer-accent-soft: rgba(47, 92, 126, 0.12);
      --explorer-stage-fg: #10273d;
      --explorer-stage-muted: #607487;
      --explorer-hud-line: rgba(47, 92, 126, 0.12);
      --explorer-hud-line-soft: rgba(255, 255, 255, 0.4);
      --explorer-hud-glow: rgba(45, 115, 133, 0.16);
      --explorer-warning-soft: rgba(191, 134, 66, 0.18);
      --ring-thin: #bf8642;
      --ring-thick: #2d7385;
      --ring-select: #10273d;
      --grid-surface: #edf4f8;
      --grid-surface-soft: #d6e3eb;
      --grid-axis-w: 108px;
      --grid-cell-w: 58px;
      --explorer-radius-xl: 18px;
      --explorer-radius-lg: 14px;
      --explorer-radius-md: 12px;
      --explorer-radius-sm: 10px;
    }
    .explorer-shell .workspace-shell {
      display: grid;
      gap: 1rem;
      max-width: 1180px;
      margin: 0 auto;
    }
    .explorer-shell .workspace-header {
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) minmax(20rem, 0.82fr);
      gap: clamp(1rem, 2vw, 1.6rem);
      padding: clamp(1.25rem, 2vw, 1.7rem);
      border-radius: 26px;
      border: 1px solid var(--explorer-border-strong);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 18%),
        radial-gradient(circle at top right, rgba(164, 74, 29, 0.08), transparent 30%),
        linear-gradient(180deg, rgba(247, 242, 235, 0.98), rgba(238, 229, 216, 0.96));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 22px 42px rgba(88, 64, 42, 0.08);
    }
    .explorer-shell .workspace-header,
    .explorer-shell .workspace-toolbar,
    .explorer-shell .toolbar-group,
    .explorer-shell .control-field,
    .explorer-shell .control-cluster,
    .explorer-shell .stage-panel,
    .explorer-shell .grid-card,
    .explorer-shell .analysis-card,
    .explorer-shell .header-command,
    .explorer-shell .header-status,
    .explorer-shell .scene-fact,
    .explorer-shell .stage-summary,
    .explorer-shell .grid-marker-panel {
      position: relative;
      overflow: clip;
      isolation: isolate;
    }
    .explorer-shell .workspace-header::before,
    .explorer-shell .workspace-toolbar::before,
    .explorer-shell .toolbar-group::before,
    .explorer-shell .control-field::before,
    .explorer-shell .control-cluster::before,
    .explorer-shell .stage-panel::before,
    .explorer-shell .grid-card::before,
    .explorer-shell .analysis-card::before,
    .explorer-shell .header-command::before,
    .explorer-shell .header-status::before,
    .explorer-shell .grid-marker-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.24), transparent 38%),
        repeating-linear-gradient(90deg, transparent 0 22px, rgba(47, 92, 126, 0.03) 22px 23px),
        linear-gradient(180deg, rgba(47, 92, 126, 0.08), transparent 22%);
      pointer-events: none;
      opacity: 0.72;
    }
    .explorer-shell .workspace-header::after,
    .explorer-shell .workspace-toolbar::after,
    .explorer-shell .stage-panel::after,
    .explorer-shell .grid-card::after,
    .explorer-shell .analysis-card::after {
      content: "";
      position: absolute;
      inset: 10px;
      border-radius: inherit;
      border: 1px solid rgba(255, 255, 255, 0.26);
      pointer-events: none;
      opacity: 0.65;
    }
    .explorer-shell .header-main,
    .explorer-shell .preset-dock,
    .explorer-shell .control-column,
    .explorer-shell .workspace-main,
    .explorer-shell .workspace-support-row,
    .explorer-shell .workspace-control-row {
      display: grid;
      gap: 1rem;
      min-width: 0;
    }
    .explorer-shell .header-main {
      align-content: start;
    }
    .explorer-shell .header-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      flex-wrap: wrap;
    }
    .explorer-shell .header-command {
      display: grid;
      gap: 0.45rem;
      padding: 1rem 1.05rem;
      border-radius: var(--explorer-radius-lg);
      border: 1px solid rgba(92, 72, 52, 0.12);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0)),
        rgba(255, 252, 248, 0.74);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
    }
    .explorer-shell .header-command-label,
    .explorer-shell .header-status-label {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .header-command-line {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: clamp(1rem, 1.8vw, 1.35rem);
      font-weight: 650;
      line-height: 1.28;
      letter-spacing: -0.03em;
    }
    .explorer-shell .header-command-trace {
      color: var(--explorer-muted);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      line-height: 1.55;
    }
    .explorer-shell .header-status-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 0.7rem;
    }
    .explorer-shell .header-status {
      display: grid;
      gap: 0.22rem;
      padding: 0.88rem 0.92rem;
      border-radius: var(--explorer-radius-md);
      border: 1px solid rgba(92, 72, 52, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
        rgba(255, 252, 247, 0.7);
    }
    .explorer-shell .header-status-accent {
      background:
        linear-gradient(180deg, rgba(239, 180, 99, 0.18), rgba(239, 180, 99, 0.04)),
        rgba(255, 250, 240, 0.78);
      border-color: rgba(239, 180, 99, 0.24);
    }
    .explorer-shell .header-status-value {
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.96rem;
      font-weight: 650;
      line-height: 1.3;
    }
    .explorer-shell .summary-kicker {
      display: inline-block;
      color: var(--explorer-accent);
      font-family: var(--font-ui);
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .explorer-shell .card-title,
    .explorer-shell .panel-title,
    .explorer-shell .stage-title,
    .explorer-shell .grid-card-title {
      font-family: var(--font-ui);
      font-weight: 650;
    }
    .explorer-shell .hero-card,
    .explorer-shell .panel-card,
    .explorer-shell .support-card {
      display: grid;
      gap: 0.9rem;
      padding: 1.1rem;
      border-radius: var(--explorer-radius-xl);
      border: 1px solid var(--explorer-border);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0)),
        var(--explorer-surface);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 14px 26px rgba(88, 64, 42, 0.06);
    }
    .explorer-shell .preset-card {
      align-content: start;
      min-height: 100%;
    }
    .explorer-shell .preset-card-head {
      align-items: center;
    }
    .explorer-shell .card-head,
    .explorer-shell .panel-head,
    .explorer-shell .grid-card-head,
    .explorer-shell .analysis-head,
    .explorer-shell .stage-head {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.8rem;
    }
    .explorer-shell .card-title,
    .explorer-shell .panel-title,
    .explorer-shell .grid-card-title {
      margin: 0.2rem 0 0;
      font-size: 1.08rem;
      line-height: 1.16;
      letter-spacing: -0.03em;
    }
    .explorer-shell .panel-copy,
    .explorer-shell .grid-card-copy,
    .explorer-shell .analysis-copy {
      margin: 0;
      color: var(--explorer-muted);
      font-size: 0.87rem;
      line-height: 1.62;
    }
    .explorer-shell .status-banner,
    .explorer-shell .inline-note,
    .explorer-shell .story-note {
      padding: 0.85rem 1rem;
      border-radius: var(--explorer-radius-md);
      border: 1px solid rgba(47, 92, 126, 0.14);
      background: linear-gradient(180deg, rgba(47, 92, 126, 0.08), rgba(47, 92, 126, 0.03));
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.84rem;
      line-height: 1.55;
    }
    .explorer-shell .summary-inline,
    .explorer-shell .segmented-row,
    .explorer-shell .mode-toggle,
    .explorer-shell .export-actions,
    .explorer-shell .focus-chip-row,
    .explorer-shell .question-button-row,
    .explorer-shell .slider-row,
    .explorer-shell .checkbox-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.55rem;
      min-width: 0;
    }
    .explorer-shell .pill {
      display: inline-block;
      padding: 0.34rem 0.72rem;
      border: 1px solid rgba(33, 65, 95, 0.16);
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(239, 247, 251, 0.82)),
        rgba(255, 255, 255, 0.7);
      color: var(--explorer-fg);
      font-family: var(--font-ui);
      font-size: 0.71rem;
      font-weight: 650;
      letter-spacing: 0.04em;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.85),
        inset 0 -1px 0 rgba(33, 65, 95, 0.05),
        0 0 0 1px rgba(255, 255, 255, 0.18);
    }
    .explorer-shell .btn {
      border: 1px solid rgba(33, 65, 95, 0.18);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(234, 243, 248, 0.9)),
        var(--explorer-surface-strong);
      color: var(--explorer-fg);
      padding: 0.58rem 0.84rem;
      border-radius: var(--explorer-radius-sm);
      cursor: pointer;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      font-weight: 650;
      letter-spacing: 0.03em;
      line-height: 1.2;
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        background 160ms ease,
        box-shadow 160ms ease,
        filter 160ms ease;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        inset 0 -1px 0 rgba(33, 65, 95, 0.05),
        0 0 0 1px rgba(255, 255, 255, 0.18),
        0 10px 18px rgba(19, 38, 58, 0.08);
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.42);
    }
    .explorer-shell .btn:hover,
    .explorer-shell .btn:focus-visible,
    .explorer-shell .tutorial-btn:hover,
    .explorer-shell .tutorial-btn:focus-visible {
      transform: translateY(-1px);
      border-color: rgba(47, 92, 126, 0.34);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(240, 248, 252, 0.96)),
        var(--explorer-surface-strong);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.9),
        inset 0 -1px 0 rgba(33, 65, 95, 0.05),
        0 0 0 1px rgba(47, 92, 126, 0.1),
        0 12px 22px rgba(27, 56, 84, 0.12);
      filter: saturate(1.04);
    }
    .explorer-shell .btn[aria-pressed="true"] {
      border-color: rgba(45, 115, 133, 0.4);
      background:
        linear-gradient(180deg, rgba(211, 232, 239, 0.92), rgba(186, 216, 229, 0.72)),
        var(--explorer-accent-soft);
      box-shadow:
        inset 0 0 0 1px rgba(47, 92, 126, 0.14),
        inset 0 1px 0 rgba(255, 255, 255, 0.52),
        0 0 0 1px rgba(45, 115, 133, 0.12),
        0 12px 20px rgba(27, 56, 84, 0.1);
    }
    .explorer-shell .btn:active,
    .explorer-shell .tutorial-btn:active,
    .explorer-shell .axis-corner-btn:active {
      transform: translateY(0);
    }
    .explorer-shell .btn:disabled {
      cursor: not-allowed;
      opacity: 0.46;
      transform: none;
      border-color: var(--explorer-border);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.46);
    }
    .explorer-shell .btn:disabled:hover,
    .explorer-shell .btn:disabled:focus-visible {
      transform: none;
      border-color: var(--explorer-border);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.46);
    }
    .explorer-shell .btn.ghost {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.16)),
        transparent;
    }
    .explorer-shell .btn.mini {
      padding: 0.48rem 0.74rem;
      font-size: 0.76rem;
    }
    .explorer-shell input[type="range"],
    .explorer-shell select,
    .explorer-shell input[type="checkbox"] {
      background: var(--explorer-surface-strong);
      color: var(--explorer-fg);
      border: 1px solid var(--explorer-border);
      border-radius: var(--explorer-radius-sm);
      padding: 0.68rem 0.86rem;
      font: inherit;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.76),
        inset 0 -1px 0 rgba(33, 65, 95, 0.04);
      transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
      accent-color: var(--ring-thick);
    }
    .explorer-shell input[type="range"]:hover,
    .explorer-shell input[type="range"]:focus-visible,
    .explorer-shell select:hover,
    .explorer-shell select:focus-visible,
    .explorer-shell input[type="checkbox"]:focus-visible {
      border-color: rgba(47, 92, 126, 0.28);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.82),
        0 0 0 1px rgba(47, 92, 126, 0.1),
        0 8px 16px rgba(27, 56, 84, 0.08);
    }
    .explorer-shell .slider-row input[type="range"] {
      flex: 1 1 11rem;
      min-width: 8rem;
    }
    .explorer-shell .checkbox-row {
      color: var(--explorer-fg);
      font-size: 0.88rem;
    }
    .explorer-shell .checkbox-row input[type="checkbox"] {
      width: auto;
      padding: 0;
    }
    .explorer-shell .tutorials {
      display: grid;
      gap: 0.65rem;
    }
    .explorer-shell .tutorial-btn {
      border: 1px solid rgba(33, 65, 95, 0.16);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(241, 247, 251, 0.82)),
        rgba(255, 255, 255, 0.76);
      color: var(--explorer-fg);
      text-align: left;
      padding: 0.85rem 0.95rem;
      border-radius: var(--explorer-radius-md);
      cursor: pointer;
      font-size: 0.84rem;
      line-height: 1.35;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    }
    .explorer-shell .tutorial-btn.active {
      border-color: rgba(45, 115, 133, 0.34);
      box-shadow:
        inset 0 0 0 1px rgba(47, 92, 126, 0.18),
        0 0 0 1px rgba(45, 115, 133, 0.1),
        0 12px 20px rgba(27, 56, 84, 0.08);
      background:
        linear-gradient(180deg, rgba(219, 238, 244, 0.88), rgba(199, 224, 233, 0.72)),
        rgba(47, 92, 126, 0.08);
    }
    .explorer-shell .tutorial-title {
      display: block;
      font-weight: 600;
    }
    .explorer-shell .tutorial-desc {
      display: block;
      margin-top: 0.2rem;
      color: var(--explorer-muted);
      font-size: 0.82rem;
    }
    .explorer-shell .tutorial-note {
      padding: 0.9rem 1rem;
      border-radius: 14px;
      border: 1px solid var(--explorer-border);
      background: rgba(255, 255, 255, 0.7);
      color: var(--explorer-muted);
      font-size: 0.82rem;
      line-height: 1.6;
    }
    .explorer-shell .workspace-layout {
      display: grid;
      grid-template-columns: minmax(18rem, 23rem) minmax(0, 1fr);
      gap: clamp(1rem, 2vw, 1.6rem);
      align-items: start;
      padding: 1rem;
      border-radius: 28px;
      border: 1px solid var(--explorer-border-strong);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.58), rgba(255, 255, 255, 0) 15%),
        linear-gradient(180deg, rgba(243, 236, 227, 0.98), rgba(235, 226, 212, 0.98));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.78),
        0 28px 50px rgba(88, 64, 42, 0.09);
    }
    .explorer-shell .workspace-main {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
      gap: clamp(1rem, 2vw, 1.35rem);
    }
    .explorer-shell .workspace-support-row {
      grid-template-columns: minmax(0, 1.55fr) minmax(18rem, 0.95fr);
      align-items: start;
      gap: clamp(1rem, 2vw, 1.35rem);
    }
    .explorer-shell .workspace-control-row {
      grid-template-columns: minmax(14rem, 0.9fr) minmax(0, 1.25fr);
      align-items: start;
      gap: 0.95rem;
    }
    .explorer-shell .control-column {
      align-content: start;
      align-self: start;
      position: sticky;
      top: clamp(0.85rem, 2vw, 1.2rem);
      z-index: 1;
    }
    .explorer-shell .workspace-toolbar {
      display: grid;
      gap: 0.85rem;
      padding: 0.92rem 1rem;
      border-radius: var(--explorer-radius-xl);
      border: 1px solid var(--explorer-border-strong);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0)),
        linear-gradient(180deg, rgba(244, 250, 253, 0.98), rgba(232, 241, 247, 0.98));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.8),
        0 16px 30px rgba(27, 56, 84, 0.08);
    }
    .explorer-shell .toolbar-bar {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      padding-bottom: 0.82rem;
      border-bottom: 1px solid rgba(33, 65, 95, 0.1);
    }
    .explorer-shell .toolbar-guide {
      display: grid;
      gap: 0.22rem;
      flex: 1 1 30rem;
      min-width: 0;
    }
    .explorer-shell .toolbar-guide-head,
    .explorer-shell .panel-heading-group {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      min-width: 0;
    }
    .explorer-shell .toolbar-guide-head > div,
    .explorer-shell .panel-heading-group > div {
      display: grid;
      gap: 0.12rem;
      min-width: 0;
    }
    .explorer-shell .toolbar-guide-copy {
      margin: 0;
      color: var(--explorer-muted);
      font-size: 0.86rem;
      line-height: 1.55;
      max-width: 46rem;
    }
