---
import "katex/dist/katex.min.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Data Counterfactuals",
  description = "An interactive explainer for the core idea of data counterfactuals: what changes when the training data changes?",
  ogImage = "/favicon.svg"
} = Astro.props;

const siteUrl = "https://datacounterfactuals.org";
const fullTitle = title === "Data Counterfactuals" ? title : `${title} | Data Counterfactuals`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6efe2" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://esm.sh" />
  </head>
  <body>
    <div class="site-shell">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f6efe2;
    --bg-soft: #ead9c1;
    --surface: rgba(255, 251, 245, 0.8);
    --surface-strong: #fffaf2;
    --surface-ink: #fff2de;
    --fg: #201a16;
    --muted: #655a4f;
    --card: rgba(255, 250, 243, 0.84);
    --card-strong: #fff8ef;
    --border: rgba(92, 72, 52, 0.16);
    --border-strong: rgba(92, 72, 52, 0.28);
    --ring-thick: #b14f1f;
    --ring-thin: #2f6b6f;
    --shadow-soft: 0 18px 36px rgba(88, 64, 42, 0.08);
    --shadow-strong: 0 26px 60px rgba(88, 64, 42, 0.12);
    --measure: 44rem;
    --rail: 17rem;
    --radius-lg: 28px;
    --radius-md: 18px;
    --font-display: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
    --font-body: "Charter", "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
    --font-ui: "Avenir Next", "Aptos", "Segoe UI", sans-serif;
  }
  * {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(182, 96, 45, 0.18), transparent 28%),
      radial-gradient(circle at top right, rgba(47, 107, 111, 0.16), transparent 24%),
      linear-gradient(180deg, #fcf7ef 0%, #f6efe2 40%, #efe2cf 100%);
    color: var(--fg);
    font-family: var(--font-body);
    line-height: 1.7;
    text-rendering: optimizeLegibility;
  }
  ::selection {
    background: rgba(177, 79, 31, 0.18);
  }
  a {
    color: var(--ring-thick);
    text-underline-offset: 0.16em;
  }
  p,
  li {
    hanging-punctuation: first;
  }
  img {
    max-width: 100%;
    display: block;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  strong {
    color: var(--fg);
  }
  .site-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .top-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(14px);
    background: rgba(250, 243, 231, 0.82);
    border-bottom: 1px solid rgba(92, 72, 52, 0.1);
  }
  .nav-inner {
    width: min(1220px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 0.8rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .brand {
    display: grid;
    gap: 0.15rem;
    text-decoration: none;
    color: inherit;
  }
  .brand-label {
    font-family: var(--font-display);
    font-size: 1.38rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .brand-note {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .nav-cluster {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.85rem;
    flex-wrap: wrap;
  }
  .nav-links {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .nav-link {
    padding: 0.45rem 0.1rem;
    border: 0;
    border-bottom: 1px solid transparent;
    text-decoration: none;
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.92rem;
    background: transparent;
    transition: transform 160ms ease, border-color 160ms ease, color 160ms ease;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(177, 79, 31, 0.2);
    color: var(--fg);
  }
  .nav-link[aria-current="page"] {
    border-color: rgba(177, 79, 31, 0.24);
    color: var(--fg);
  }
  .nav-link-aux {
    padding: 0.55rem 0.95rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(47, 107, 111, 0.08);
    color: #19484b;
  }

  .page {
    width: min(1240px, calc(100% - 2rem));
    margin: 0 auto;
    padding: clamp(1.5rem, 2vw, 2.2rem) 0 4rem;
  }
  .page-header {
    display: grid;
    gap: 0.95rem;
    margin-bottom: 2.2rem;
  }
  .page-eyebrow {
    display: inline-block;
    width: fit-content;
    color: var(--ring-thick);
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .page-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5.4rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    max-width: 13ch;
  }
  .page-lede {
    margin: 0;
    max-width: var(--measure);
    color: var(--muted);
    font-size: clamp(1.08rem, 1.45vw, 1.24rem);
    line-height: 1.82;
  }
  .page-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255, 250, 243, 0.84);
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
  }
  .section-card {
    background:
      linear-gradient(180deg, rgba(255, 252, 247, 0.94), rgba(250, 241, 229, 0.82)),
      var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    padding: clamp(1.2rem, 2.2vw, 1.75rem);
  }
  .section-card + .section-card {
    margin-top: 1rem;
  }
  .section-kicker {
    margin: 0 0 0.55rem;
    color: var(--ring-thick);
    font-family: var(--font-ui);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.76rem;
    font-weight: 700;
  }
  .section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.2vw, 2.15rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }
  .section-copy {
    margin-top: 0.9rem;
    color: var(--muted);
    line-height: 1.82;
    max-width: 42rem;
    font-size: 1.04rem;
  }
  .section-copy p {
    margin: 0 0 1rem;
  }
  .section-copy p:last-child {
    margin-bottom: 0;
  }
  .page-grid {
    display: grid;
    gap: 1rem;
  }
  .page-grid.cols-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .page-grid.cols-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.9rem;
    padding: 0.8rem 1.15rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: var(--ring-thick);
    color: #fff7f0;
    text-decoration: none;
    font-family: var(--font-ui);
    font-weight: 700;
    letter-spacing: 0.01em;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    box-shadow: 0 10px 24px rgba(177, 79, 31, 0.22);
  }
  .btn:hover,
  .btn:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(177, 79, 31, 0.28);
  }
  .btn.secondary {
    background: #275b5f;
    box-shadow: 0 10px 24px rgba(39, 91, 95, 0.18);
  }
  .btn.ghost {
    background: rgba(255, 250, 243, 0.68);
    border-color: var(--border);
    color: var(--fg);
    box-shadow: none;
  }
  .chip-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding: 0;
    margin: 0;
  }
  .chip {
    padding: 0.6rem 0.8rem;
    border-radius: 16px;
    background: rgba(255, 250, 243, 0.72);
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: var(--font-ui);
  }
  .stat-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .stat-card {
    background: linear-gradient(180deg, rgba(255, 250, 243, 0.92), rgba(247, 237, 224, 0.78));
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem;
  }
  .stat-card h3 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
  }
  .stat-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }
  .empty-state {
    padding: 1rem;
    border: 1px dashed var(--border-strong);
    border-radius: var(--radius-md);
    color: var(--muted);
    background: rgba(255, 250, 243, 0.56);
  }
  .prose {
    color: var(--muted);
    font-size: clamp(1.05rem, 1.2vw, 1.1rem);
    line-height: 1.92;
    max-width: var(--measure);
  }
  .prose h2,
  .prose h3 {
    color: var(--fg);
    font-family: var(--font-display);
    letter-spacing: -0.02em;
  }
  .prose h2 {
    margin: 2.8rem 0 0.9rem;
    font-size: clamp(1.7rem, 2vw, 2.15rem);
  }
  .prose h3 {
    margin: 2rem 0 0.7rem;
    font-size: 1.28rem;
  }
  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote {
    margin: 0 0 1.15rem;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.2rem;
  }
  .prose li {
    margin-bottom: 0.45rem;
  }
  .prose blockquote {
    padding-left: 1rem;
    border-left: 3px solid rgba(177, 79, 31, 0.25);
    color: #7b6b5c;
    font-style: normal;
  }
  .prose code {
    padding: 0.14rem 0.4rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: rgba(255, 250, 243, 0.9);
    color: var(--fg);
    font-size: 0.9em;
  }
  .prose :where(.katex) {
    color: var(--fg);
  }
  .prose :where(.katex-display) {
    margin: 1.4rem 0 1.55rem;
    padding: 0.85rem 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    border-radius: 18px;
    border: 1px solid rgba(92, 72, 52, 0.12);
    background:
      linear-gradient(180deg, rgba(255, 252, 248, 0.92), rgba(247, 238, 226, 0.72)),
      rgba(255, 250, 243, 0.86);
    box-shadow: var(--shadow-soft);
  }
  .prose :where(.katex-display > .katex) {
    min-width: fit-content;
    padding: 0 0.1rem;
    font-size: 1.03em;
  }

  .essay-page {
    display: grid;
    gap: 2.6rem;
  }
  .essay-header,
  .essay-section {
    display: grid;
    grid-template-columns: minmax(0, var(--measure)) minmax(0, var(--rail));
    gap: clamp(1.1rem, 3vw, 2.5rem);
    align-items: start;
  }
  .essay-main {
    max-width: var(--measure);
    color: var(--muted);
    font-size: clamp(1.04rem, 1.15vw, 1.1rem);
    line-height: 1.88;
  }
  .essay-main > :first-child {
    margin-top: 0;
  }
  .essay-main h2,
  .essay-main h3 {
    color: var(--fg);
    font-family: var(--font-display);
    letter-spacing: -0.02em;
  }
  .essay-main h2 {
    margin: 0 0 0.9rem;
    font-size: clamp(1.75rem, 2vw, 2.2rem);
    line-height: 1.04;
  }
  .essay-main h3 {
    margin: 1.8rem 0 0.55rem;
    font-size: 1.28rem;
    line-height: 1.14;
  }
  .essay-main p,
  .essay-main ul,
  .essay-main ol,
  .essay-main blockquote {
    margin: 0 0 1.15rem;
  }
  .essay-main ul,
  .essay-main ol {
    padding-left: 1.2rem;
  }
  .essay-main li {
    margin-bottom: 0.55rem;
  }
  .essay-main blockquote {
    margin-left: 0;
    padding-left: 1rem;
    border-left: 3px solid rgba(177, 79, 31, 0.25);
    color: #7b6b5c;
  }
  .essay-side {
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.95rem;
    line-height: 1.7;
    border-top: 1px solid var(--border-strong);
    padding-top: 0.9rem;
  }
  .essay-side > :first-child {
    margin-top: 0;
  }
  .essay-side h2,
  .essay-side h3 {
    margin: 0 0 0.55rem;
    color: var(--fg);
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.12;
    letter-spacing: -0.02em;
  }
  .essay-side p,
  .essay-side ul {
    margin: 0 0 0.9rem;
  }
  .essay-side ul {
    list-style: none;
    padding: 0;
  }
  .essay-side li {
    margin: 0;
    padding: 0.75rem 0;
    border-top: 1px solid rgba(92, 72, 52, 0.12);
  }
  .essay-side li:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .essay-wide {
    grid-column: 1 / -1;
  }
  .essay-figure {
    margin: 1.4rem 0 1.1rem;
    padding: 1.15rem;
    border-radius: 30px;
    border: 1px solid rgba(92, 72, 52, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 251, 246, 0.94), rgba(247, 237, 224, 0.76)),
      rgba(255, 250, 243, 0.84);
    box-shadow: var(--shadow-soft);
  }
  .essay-caption {
    margin: 0.8rem 0 0;
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.88rem;
    line-height: 1.65;
  }
  .note-label {
    margin: 0 0 0.45rem;
    color: var(--ring-thick);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .link-cluster {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.2rem;
  }
  .link-cluster li {
    padding: 1rem 0;
    border-top: 1px solid var(--border);
  }
  .link-cluster li:first-child {
    padding-top: 0;
    border-top: 0;
  }
  .link-cluster a {
    color: var(--fg);
    font-family: var(--font-display);
    font-size: 1.16rem;
    line-height: 1.2;
    text-decoration: none;
  }
  .link-cluster a:hover {
    color: var(--ring-thick);
  }
  .link-cluster p {
    margin: 0.35rem 0 0;
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .reference-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
  }
  .reference-card {
    padding: 1.1rem 1.15rem;
    border-radius: 22px;
    border: 1px solid var(--border);
    background: rgba(255, 250, 243, 0.72);
  }
  .reference-card h3 {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: 1.18rem;
    line-height: 1.15;
  }
  .reference-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
    font-family: var(--font-ui);
    font-size: 0.95rem;
  }
  @media (max-width: 960px) {
    .page-grid.cols-2,
    .page-grid.cols-3,
    .stat-grid,
    .essay-header,
    .essay-section {
      grid-template-columns: 1fr;
    }
    .essay-side {
      border-top: 0;
      padding-top: 0;
    }
  }

  @media (max-width: 780px) {
    .nav-inner {
      width: min(100% - 1.25rem, 1240px);
      align-items: flex-start;
      flex-direction: column;
    }
    .nav-cluster {
      width: 100%;
      justify-content: flex-start;
    }
    .page {
      width: min(100% - 1.25rem, 1240px);
      padding-bottom: 3rem;
    }
    .page-title {
      max-width: 12ch;
    }
  }
</style>
