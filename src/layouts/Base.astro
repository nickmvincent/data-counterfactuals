---
import NetworkFooter from "../../helpers/astro/NetworkFooter.astro";
import networkData from "../data/network.json";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Data Counterfactuals",
  description = "A field guide to training-data what-ifs: explore how adding, removing, or corrupting data changes model behavior.",
  ogImage = "/favicon.svg"
} = Astro.props;

const siteUrl = "https://datacounterfactuals.org";
const fullTitle = title === "Data Counterfactuals" ? title : `${title} | Data Counterfactuals`;
const networkLinks = [
  ...(networkData.relatedProjects ?? [])
    .filter((project) => Boolean(project.website))
    .map((project) => ({
      href: project.website!,
      label: project.title || project.name
    })),
  ...(networkData.links?.github ? [{ href: networkData.links.github, label: "GitHub" }] : [])
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6efe2" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://esm.sh" />
  </head>
  <body>
    <div class="site-shell">
      <slot />
      <NetworkFooter links={networkLinks} label="Elsewhere in the project:" />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f6efe2;
    --bg-soft: #ead9c1;
    --surface: rgba(255, 251, 245, 0.8);
    --surface-strong: #fffaf2;
    --surface-ink: #fff2de;
    --fg: #201a16;
    --muted: #655a4f;
    --card: rgba(255, 250, 243, 0.84);
    --card-strong: #fff8ef;
    --border: rgba(92, 72, 52, 0.16);
    --border-strong: rgba(92, 72, 52, 0.28);
    --ring-thick: #b14f1f;
    --ring-thin: #2f6b6f;
    --shadow-soft: 0 18px 36px rgba(88, 64, 42, 0.08);
    --shadow-strong: 0 26px 60px rgba(88, 64, 42, 0.12);
    --radius-lg: 28px;
    --radius-md: 18px;
    --font-display: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
    --font-body: "Avenir Next", "Aptos", "Segoe UI", sans-serif;
  }
  * {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(182, 96, 45, 0.18), transparent 28%),
      radial-gradient(circle at top right, rgba(47, 107, 111, 0.16), transparent 24%),
      linear-gradient(180deg, #fcf7ef 0%, #f6efe2 40%, #efe2cf 100%);
    color: var(--fg);
    font-family: var(--font-body);
    line-height: 1.55;
    text-rendering: optimizeLegibility;
  }
  ::selection {
    background: rgba(177, 79, 31, 0.18);
  }
  a {
    color: var(--ring-thick);
    text-underline-offset: 0.16em;
  }
  img {
    max-width: 100%;
    display: block;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  strong {
    color: var(--fg);
  }
  .site-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .top-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(18px);
    background: rgba(250, 243, 231, 0.72);
    border-bottom: 1px solid rgba(92, 72, 52, 0.1);
  }
  .nav-inner {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 0.9rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .brand {
    display: grid;
    gap: 0.2rem;
    text-decoration: none;
    color: inherit;
  }
  .brand-label {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .brand-note {
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .nav-cluster {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .nav-links {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .nav-link {
    padding: 0.68rem 0.95rem;
    border: 1px solid transparent;
    border-radius: 999px;
    text-decoration: none;
    color: var(--muted);
    font-size: 0.92rem;
    background: rgba(255, 250, 243, 0.72);
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, color 160ms ease;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(177, 79, 31, 0.2);
    background: rgba(255, 250, 243, 0.96);
    color: var(--fg);
  }
  .nav-link[aria-current="page"] {
    background: rgba(177, 79, 31, 0.12);
    border-color: rgba(177, 79, 31, 0.24);
    color: var(--fg);
  }
  .nav-link-aux {
    background: rgba(47, 107, 111, 0.1);
    color: #19484b;
  }

  .page {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: clamp(1.35rem, 2vw, 2rem) 0 4rem;
  }
  .page-header {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .page-eyebrow {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(47, 107, 111, 0.1);
    color: #204f52;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .page-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    max-width: 11ch;
  }
  .page-lede {
    margin: 0;
    max-width: 66ch;
    color: var(--muted);
    font-size: clamp(1.03rem, 1.4vw, 1.16rem);
    line-height: 1.75;
  }
  .page-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255, 250, 243, 0.84);
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 600;
  }
  .section-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    padding: clamp(1.1rem, 2.2vw, 1.6rem);
  }
  .section-card + .section-card {
    margin-top: 1rem;
  }
  .section-kicker {
    margin: 0 0 0.55rem;
    color: var(--ring-thick);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 700;
  }
  .section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.2vw, 2.15rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }
  .section-copy {
    margin-top: 0.9rem;
    color: var(--muted);
    line-height: 1.75;
  }
  .section-copy p {
    margin: 0 0 1rem;
  }
  .section-copy p:last-child {
    margin-bottom: 0;
  }
  .page-grid {
    display: grid;
    gap: 1rem;
  }
  .page-grid.cols-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .page-grid.cols-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.9rem;
    padding: 0.8rem 1.15rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: var(--ring-thick);
    color: #fff7f0;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.01em;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    box-shadow: 0 10px 24px rgba(177, 79, 31, 0.22);
  }
  .btn:hover,
  .btn:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(177, 79, 31, 0.28);
  }
  .btn.secondary {
    background: #275b5f;
    box-shadow: 0 10px 24px rgba(39, 91, 95, 0.18);
  }
  .btn.ghost {
    background: rgba(255, 250, 243, 0.68);
    border-color: var(--border);
    color: var(--fg);
    box-shadow: none;
  }
  .chip-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding: 0;
    margin: 0;
  }
  .chip {
    padding: 0.6rem 0.8rem;
    border-radius: 16px;
    background: rgba(255, 250, 243, 0.72);
    border: 1px solid var(--border);
    color: var(--muted);
  }
  .stat-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .stat-card {
    background: linear-gradient(180deg, rgba(255, 250, 243, 0.92), rgba(247, 237, 224, 0.78));
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem;
  }
  .stat-card h3 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
  }
  .stat-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }
  .empty-state {
    padding: 1rem;
    border: 1px dashed var(--border-strong);
    border-radius: var(--radius-md);
    color: var(--muted);
    background: rgba(255, 250, 243, 0.56);
  }
  .prose {
    color: var(--muted);
    line-height: 1.8;
  }
  .prose h2,
  .prose h3 {
    color: var(--fg);
    font-family: var(--font-display);
    letter-spacing: -0.02em;
  }
  .prose h2 {
    margin: 2.4rem 0 0.9rem;
    font-size: clamp(1.5rem, 2vw, 2rem);
  }
  .prose h3 {
    margin: 1.7rem 0 0.7rem;
    font-size: 1.2rem;
  }
  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote {
    margin: 0 0 1rem;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.2rem;
  }
  .prose li {
    margin-bottom: 0.45rem;
  }
  .prose blockquote {
    padding-left: 1rem;
    border-left: 3px solid rgba(177, 79, 31, 0.25);
    color: #7b6b5c;
    font-style: italic;
  }
  .prose code {
    padding: 0.14rem 0.4rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: rgba(255, 250, 243, 0.9);
    color: var(--fg);
    font-size: 0.9em;
  }

  .network-footer {
    margin-top: auto;
    padding: 1.25rem 0 2rem;
  }
  .network-footer-content {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 1.2rem 1.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: rgba(255, 250, 243, 0.72);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    box-shadow: var(--shadow-soft);
  }
  .network-label {
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .network-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }
  .network-links a {
    color: var(--fg);
    text-decoration: none;
    padding: 0.5rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 250, 243, 0.95);
    border: 1px solid var(--border);
  }
  .network-links a:hover {
    border-color: rgba(177, 79, 31, 0.24);
    color: var(--ring-thick);
  }

  @media (max-width: 960px) {
    .page-grid.cols-2,
    .page-grid.cols-3,
    .stat-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 780px) {
    .nav-inner,
    .network-footer-content {
      width: min(100% - 1.25rem, 1120px);
    }
    .nav-inner {
      align-items: flex-start;
      flex-direction: column;
    }
    .nav-cluster {
      width: 100%;
      justify-content: flex-start;
    }
    .page {
      width: min(100% - 1.25rem, 1120px);
      padding-bottom: 3rem;
    }
    .page-title {
      max-width: 13ch;
    }
    .network-footer-content {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
