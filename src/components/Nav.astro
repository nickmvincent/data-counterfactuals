---
import networkData from "../data/network.json";

const { pathname } = Astro.url;

const links = [
  { href: "/", label: "Overview", title: "What data counterfactuals are and why they matter" },
  { href: "/grid", label: "Grid", title: "Interactive toy grid for exploring train/eval counterfactuals" },
  { href: "/graph", label: "Graph", title: "Subset-lattice companion that treats dataset edits as graph moves" },
  { href: "/memo", label: "Memos", title: "Written notes: the launch post, formalisms, and more" },
  { href: "/collections", label: "Related Areas and Papers", title: "Curated shelf of neighboring literatures and representative papers" },
];

const externalLink = { href: "/advanced.html", label: "3D View", external: true };
const githubUrl = networkData.links?.github;

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<nav class="top-nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand-label">Data Counterfactuals</span>
      <span class="brand-note">What changes when the training data changes?</span>
    </a>

    <div class="nav-cluster">
      <div class="nav-links">
        {links.map(link => (
          <a
            class="nav-link"
            href={link.href}
            title={link.title}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      <a
        class="nav-link nav-link-aux"
        href={externalLink.href}
        target="_blank"
        rel="noreferrer noopener"
        title="Opens in a new tab"
      >
        {externalLink.label} ↗
      </a>
      {githubUrl && (
        <a
          class="nav-link nav-link-aux"
          href={githubUrl}
          target="_blank"
          rel="noreferrer noopener"
        >
          GitHub Repo
        </a>
      )}
    </div>
  </div>
</nav>
