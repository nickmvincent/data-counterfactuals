---
import networkData from "../data/network.json";
import { siteLinks } from "../lib/site-nav";

const { pathname } = Astro.url;

const githubUrl = networkData.links?.github;

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<nav class="top-nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand-label">Data Counterfactuals</span>
      <span class="brand-note">What changes when the training data changes?</span>
    </a>

    <div class="nav-cluster nav-cluster-desktop">
      <div class="nav-links">
        {siteLinks.map(link => (
          <a
            class="nav-link"
            href={link.href}
            title={link.title}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      {githubUrl && (
        <a
          class="nav-link nav-link-aux"
          href={githubUrl}
          target="_blank"
          rel="noreferrer noopener"
        >
          GitHub Repo
        </a>
      )}
    </div>

    <details class="nav-mobile">
      <summary class="nav-mobile-toggle">Menu</summary>
      <div class="nav-mobile-panel">
        <div class="nav-mobile-links">
          <span class="nav-mobile-section-label">Explore the site</span>
          {siteLinks.map((link) => (
            <a
              class="nav-mobile-link"
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              <span>
                <span>{link.label}</span>
                <span class="nav-mobile-link-note">{link.title}</span>
              </span>
            </a>
          ))}
        </div>

        {githubUrl && (
          <div class="nav-mobile-actions">
            <span class="nav-mobile-section-label">Project links</span>
            <a
              class="nav-mobile-action"
              href={githubUrl}
              target="_blank"
              rel="noreferrer noopener"
            >
              <span>GitHub Repo</span>
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        )}
      </div>
    </details>
  </div>
</nav>
