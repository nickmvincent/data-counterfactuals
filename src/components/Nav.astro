---
import networkData from "../data/network.json";
import {
  experimentalSiteLinks,
  frameSiteLink,
  primarySiteLinks,
  secondarySiteLinks,
} from "../lib/site-nav";

const { pathname } = Astro.url;

const githubUrl = networkData.links?.github;
const moreLinks = [
  ...secondarySiteLinks,
  ...(githubUrl ? [{ href: githubUrl, label: "GitHub", external: true }] : []),
];

function isActive(href: string): boolean {
  if (/^(https?:)?\/\//.test(href) || href.endsWith(".html")) return pathname === href;
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}

function isSectionActive(links: typeof primarySiteLinks): boolean {
  return links.some((link) => !link.external && isActive(link.href));
}
---

<nav class="top-nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand-label">Data Counterfactuals</span>
      <span class="brand-note">Training, evaluation, and trust worlds</span>
    </a>

    <div class="nav-cluster nav-cluster-desktop">
      <div class="nav-links">
        {primarySiteLinks.map((link) => (
          <a
            class="nav-link"
            href={link.href}
            title={link.title}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}

        {moreLinks.length > 0 && (
          <details class="nav-dropdown" data-active={isSectionActive(moreLinks) ? "true" : undefined}>
            <summary
              class="nav-link nav-dropdown-toggle"
              title="Primer, examples, glossary, essays, and project links"
            >
              More
            </summary>

            <div class="nav-dropdown-panel">
              {moreLinks.map((link) => (
                <a
                  class="nav-dropdown-link"
                  href={link.href}
                  title={link.title}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noreferrer noopener" : undefined}
                  aria-current={!link.external && isActive(link.href) ? "page" : undefined}
                >
                  <span>
                    <span>{link.label}</span>
                    {link.title && <span class="nav-dropdown-link-note">{link.title}</span>}
                  </span>
                  {link.external && <span aria-hidden="true">↗</span>}
                </a>
              ))}
            </div>
          </details>
        )}
      </div>

      <a
        class="nav-link nav-link-action"
        href={frameSiteLink.href}
        title={frameSiteLink.title}
        aria-current={isActive(frameSiteLink.href) ? "page" : undefined}
      >
        {frameSiteLink.label}
      </a>
    </div>

    <details class="nav-mobile">
      <summary class="nav-mobile-toggle">Menu</summary>
      <div class="nav-mobile-panel">
        <div class="nav-mobile-section">
          <span class="nav-mobile-section-label">Main paths</span>
          {[...primarySiteLinks, frameSiteLink].map((link) => (
            <a
              class="nav-mobile-link"
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              <span>{link.label}</span>
            </a>
          ))}
        </div>

        <details class="nav-mobile-submenu" data-active={isSectionActive(secondarySiteLinks) ? "true" : undefined}>
          <summary>Primer and reference</summary>
          <div class="nav-mobile-section">
            {secondarySiteLinks.map((link) => (
              <a
                class="nav-mobile-link"
                href={link.href}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                <span>{link.label}</span>
              </a>
            ))}
          </div>
        </details>

        <details class="nav-mobile-submenu" data-active={isSectionActive(experimentalSiteLinks) ? "true" : undefined}>
          <summary>Experimental tools</summary>
          <div class="nav-mobile-section">
            {experimentalSiteLinks.map((link) => (
              <a
                class="nav-mobile-link"
                href={link.href}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                <span>{link.label}</span>
              </a>
            ))}
          </div>
        </details>

        {githubUrl && (
          <a class="nav-mobile-link" href={githubUrl} target="_blank" rel="noreferrer noopener">
            <span>GitHub</span><span aria-hidden="true">↗</span>
          </a>
        )}
      </div>
    </details>
  </div>
</nav>
