---
import networkData from "../data/network.json";
import { getSiteNavSections } from "../lib/site-nav";

const { pathname } = Astro.url;

const githubUrl = networkData.links?.github;
const navSections = getSiteNavSections(githubUrl);
const [primarySection, wipSection, projectSection] = navSections;
const primaryLinks = primarySection?.links ?? [];
const wipLinks = wipSection?.links ?? [];
const projectLinks = projectSection?.links ?? [];

function isActive(href: string): boolean {
  if (/^(https?:)?\/\//.test(href) || href.endsWith(".html")) return pathname === href;
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}

function isSectionActive(links: typeof primaryLinks): boolean {
  return links.some((link) => !link.external && isActive(link.href));
}
---

<nav class="top-nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand-label">Data Counterfactuals</span>
      <span class="brand-note">What changes when the training data changes?</span>
    </a>

    <div class="nav-cluster nav-cluster-desktop">
      <div class="nav-links">
        {primaryLinks.map((link) => (
          <a
            class="nav-link"
            href={link.href}
            title={link.title}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}

        {wipLinks.length > 0 && (
          <details class="nav-dropdown" data-active={isSectionActive(wipLinks) ? "true" : undefined}>
            <summary
              class="nav-link nav-dropdown-toggle"
              title="Graph, API, and 3D viewer work-in-progress explorables"
            >
              WIP Explorables
            </summary>

            <div class="nav-dropdown-panel">
              {wipLinks.map((link) => (
                <a
                  class="nav-dropdown-link"
                  href={link.href}
                  title={link.title}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noreferrer noopener" : undefined}
                  aria-current={!link.external && isActive(link.href) ? "page" : undefined}
                >
                  <span>
                    <span>{link.label}</span>
                    {link.title && <span class="nav-dropdown-link-note">{link.title}</span>}
                  </span>
                  {link.external && <span aria-hidden="true">↗</span>}
                </a>
              ))}
            </div>
          </details>
        )}
      </div>

      {projectLinks.map((link) => (
        <a
          class="nav-link nav-link-aux"
          href={link.href}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noreferrer noopener" : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>

    <details class="nav-mobile">
      <summary class="nav-mobile-toggle">Menu</summary>
      <div class="nav-mobile-panel">
        {navSections.map((section) => (
          <div class="nav-mobile-section">
            <span class="nav-mobile-section-label">{section.label}</span>
            {section.links.map((link) => (
              <a
                class="nav-mobile-link"
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noreferrer noopener" : undefined}
                aria-current={!link.external && isActive(link.href) ? "page" : undefined}
              >
                <span>
                  <span>{link.label}</span>
                  {link.title && <span class="nav-mobile-link-note">{link.title}</span>}
                </span>
                {link.external && <span aria-hidden="true">↗</span>}
              </a>
            ))}
          </div>
        ))}
      </div>
    </details>
  </div>
</nav>
