---
const { pathname } = Astro.url;

const links = [
  { href: "/", label: "Start" },
  { href: "/grid", label: "Explorer" },
  { href: "/memo", label: "Memo" },
  { href: "/collections", label: "Reading Lists" },
  { href: "/glossary", label: "Glossary" },
  { href: "/about", label: "About" },
];

const externalLink = { href: "/advanced.html", label: "3D View", external: true };

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<nav class="top-nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand-label">Data Counterfactuals</span>
      <span class="brand-note">A field guide to training-data what-ifs</span>
    </a>

    <div class="nav-cluster">
      <div class="nav-links">
        {links.map(link => (
          <a
            class="nav-link"
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      <a
        class="nav-link nav-link-aux"
        href={externalLink.href}
        target="_blank"
        rel="noreferrer noopener"
      >
        {externalLink.label}
      </a>
    </div>
  </div>
</nav>
