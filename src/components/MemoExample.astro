---
import MiniGrid from "./MiniGrid.jsx";

interface MiniGridExample {
  type: "mini-grid";
  label: string;
  caption: string;
  rows: string[];
  cols: string[];
  values: number[][];
  highlightRow?: number;
  highlightCol?: number;
  compareRow?: number;
  showDelta?: boolean;
  href?: string;
}

interface MoveExample {
  type: "moves";
  label: string;
  caption: string;
}

interface ScopeExample {
  type: "scopes";
  label: string;
  caption: string;
}

type MemoExample = MiniGridExample | MoveExample | ScopeExample;

interface Props {
  id: string;
}

const { id } = Astro.props;

const examples: Record<string, MemoExample> = {
  "leave-one-out-toy": {
    type: "mini-grid",
    label: "Leave-one-out toy example",
    caption:
      "With four toy data objects A, B, C, and D, the lower row leaves out B. The sharp drop on evaluation slice B is the kind of local contrast many attribution methods try to summarize.",
    rows: ["ABCD", "ACD"],
    cols: ["A", "B", "C", "D"],
    values: [
      [0.92, 0.88, 0.85, 0.82],
      [0.78, 0.55, 0.82, 0.8],
    ],
    highlightRow: 0,
    compareRow: 1,
  },
  "toy-grid": {
    type: "mini-grid",
    label: "Toy world with four observations",
    caption:
      "Imagine every possible training set as a row and every evaluation slice as a column. Row moves ask what changed in training; column moves ask what changed in measurement.",
    rows: ["AB", "ABC", "ABCD", "ACD"],
    cols: ["A", "B", "C", "D"],
    values: [
      [0.85, 0.72, 0.45, 0.38],
      [0.88, 0.8, 0.75, 0.52],
      [0.92, 0.88, 0.85, 0.82],
      [0.78, 0.55, 0.82, 0.8],
    ],
    href: "/grid",
  },
  "move-types": {
    type: "moves",
    label: "Three grid moves",
    caption:
      "The same toy square can support different questions: change the training row, change the evaluation column, or change the role and trust state around a data object.",
  },
  "counterfactual-scopes": {
    type: "scopes",
    label: "Three scopes of data counterfactuals",
    caption:
      "The frame starts with fixed-subset comparisons, then widens to new data acquisition and finally to worlds where incentives, platforms, or governance change what data gets produced.",
  },
};

const example = examples[id];

if (!example) {
  throw new Error(`Unknown memo example '${id}'.`);
}

const moveCards = [
  {
    title: "Row move",
    text: "Same evaluation target; train on a nearby data world.",
    kind: "row",
  },
  {
    title: "Column move",
    text: "Same trained model; measure against a different slice.",
    kind: "column",
  },
  {
    title: "Role move",
    text: "The object changes status: trainable, evaluable, reserved, or unavailable.",
    kind: "coupled",
  },
];

const scopeCards = [
  {
    title: "Subset",
    text: "Remove, reweight, repair, or average over data the operator already has.",
  },
  {
    title: "Acquisition",
    text: "Ask which next point, label, source, or contribution would move the system.",
  },
  {
    title: "Data-generating process",
    text: "Change the incentives, governance, platforms, or behavior that create future data.",
  },
];
---

<figure class={`memo-example memo-example-${example.type}`} data-memo-example={id}>
  <figcaption class="memo-example-head">
    <span class="note-label">{example.label}</span>
  </figcaption>

  {
    example.type === "mini-grid" && (
      <MiniGrid
        client:load
        rows={example.rows}
        cols={example.cols}
        values={example.values}
        highlightRow={example.highlightRow}
        highlightCol={example.highlightCol}
        compareRow={example.compareRow}
        showDelta={example.showDelta}
        interactive={false}
      />
    )
  }

  {
    example.type === "moves" && (
      <div class="memo-move-grid" aria-label="Three example data counterfactual moves">
        {moveCards.map((move) => (
          <div class="memo-move-card">
            <div class={`memo-move-diagram memo-move-diagram-${move.kind}`} aria-hidden="true">
              {Array.from({ length: 9 }).map((_, index) => (
                <span class={`memo-move-cell memo-move-cell-${index}`}></span>
              ))}
            </div>
            <h3>{move.title}</h3>
            <p>{move.text}</p>
          </div>
        ))}
      </div>
    )
  }

  {
    example.type === "scopes" && (
      <div class="memo-scope-grid" aria-label="Three scopes of data counterfactuals">
        {scopeCards.map((scope, index) => (
          <div class="memo-scope-card">
            <span>{index + 1}</span>
            <h3>{scope.title}</h3>
            <p>{scope.text}</p>
          </div>
        ))}
      </div>
    )
  }

  <p class="essay-caption">{example.caption}</p>

  {
    example.type === "mini-grid" && example.href && (
      <div class="memo-example-action">
        <a href={example.href} class="btn">Open in Explorer</a>
      </div>
    )
  }
</figure>

<style is:global>
  .memo-example {
    margin: 1.55rem 0 1.45rem;
    padding: 1rem 0 0.2rem;
    border: 0;
    border-top: 1px solid rgba(92, 72, 52, 0.14);
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }
  .memo-example-head {
    margin: 0 0 0.6rem;
  }
  .memo-example .essay-caption {
    margin: 0.8rem 0 0;
  }
  .memo-example-action {
    margin-top: 1rem;
  }
  .memo-example .mini-grid-wrap {
    display: grid;
    gap: 0.75rem;
    align-items: start;
    width: 100%;
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }
  .memo-example .mini-grid {
    gap: 3px;
    width: max-content;
    margin-inline: 0;
  }
  .memo-example .mini-corner,
  .memo-example .mini-row-label,
  .memo-example .mini-col-label,
  .memo-example .mini-cell {
    border-radius: 4px;
  }
  .memo-example .mini-corner {
    width: 58px;
    height: 42px;
    background: rgba(255, 250, 243, 0.5);
    border: 1px solid rgba(92, 72, 52, 0.12);
  }
  .memo-example .mini-col-label {
    min-width: 58px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: rgba(101, 90, 79, 0.9);
    background: rgba(255, 250, 243, 0.56);
    border: 1px solid rgba(92, 72, 52, 0.12);
  }
  .memo-example .mini-col-label.active {
    color: var(--fg);
    background: rgba(177, 79, 31, 0.08);
    border-color: rgba(177, 79, 31, 0.16);
  }
  .memo-example .mini-row-label {
    width: 58px;
    min-height: 46px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 0.8rem;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: rgba(101, 90, 79, 0.9);
    background: rgba(255, 250, 243, 0.56);
    border: 1px solid rgba(92, 72, 52, 0.12);
  }
  .memo-example .mini-row-label.active {
    color: var(--fg);
    background: rgba(47, 107, 111, 0.08);
    border-color: rgba(47, 107, 111, 0.16);
  }
  .memo-example .mini-cell {
    width: 58px;
    min-height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: default;
    position: relative;
    transition: filter 180ms ease, opacity 180ms ease;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
  }
  .memo-example .mini-cell:hover {
    filter: saturate(0.94);
  }
  .memo-example .mini-cell.ring-highlight {
    outline: 2px solid var(--ring-thick);
    outline-offset: -3px;
  }
  .memo-example .mini-cell.ring-compare {
    outline: 2px solid var(--ring-thin);
    outline-offset: -3px;
  }
  .memo-example .mini-cell.selected {
    outline: 2px solid #fff;
    outline-offset: -3px;
  }
  .memo-example .mini-val {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }
  .memo-example .mini-caption,
  .memo-example .mini-tooltip {
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.85rem;
    line-height: 1.64;
  }
  .memo-example .mini-tooltip {
    margin-top: 0;
    padding: 0.72rem 0.9rem;
    border-radius: 4px;
    border: 1px solid rgba(92, 72, 52, 0.12);
    background: rgba(255, 250, 243, 0.92);
    max-width: min(100%, 34rem);
  }
  .memo-move-grid,
  .memo-scope-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .memo-move-card,
  .memo-scope-card {
    min-width: 0;
    padding: 0.95rem;
    border: 1px solid rgba(92, 72, 52, 0.14);
    border-radius: var(--radius-md);
    background: rgba(255, 250, 243, 0.66);
  }
  .memo-move-card h3,
  .memo-scope-card h3 {
    margin: 0.7rem 0 0.35rem;
    color: var(--fg);
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.14;
  }
  .memo-move-card p,
  .memo-scope-card p {
    margin: 0;
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.84rem;
    line-height: 1.58;
  }
  .memo-move-diagram {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    width: min(100%, 8.4rem);
  }
  .memo-move-cell {
    aspect-ratio: 1;
    border: 1px solid rgba(92, 72, 52, 0.12);
    border-radius: 3px;
    background: rgba(234, 217, 193, 0.36);
  }
  .memo-move-diagram-row .memo-move-cell-3,
  .memo-move-diagram-row .memo-move-cell-4,
  .memo-move-diagram-row .memo-move-cell-5 {
    background: rgba(47, 107, 111, 0.14);
    border-color: rgba(47, 107, 111, 0.22);
  }
  .memo-move-diagram-row .memo-move-cell-4,
  .memo-move-diagram-row .memo-move-cell-7,
  .memo-move-diagram-column .memo-move-cell-4,
  .memo-move-diagram-column .memo-move-cell-5,
  .memo-move-diagram-coupled .memo-move-cell-4,
  .memo-move-diagram-coupled .memo-move-cell-8 {
    background: rgba(177, 79, 31, 0.18);
    border-color: rgba(177, 79, 31, 0.28);
  }
  .memo-move-diagram-column .memo-move-cell-1,
  .memo-move-diagram-column .memo-move-cell-4,
  .memo-move-diagram-column .memo-move-cell-7 {
    background: rgba(177, 79, 31, 0.12);
    border-color: rgba(177, 79, 31, 0.22);
  }
  .memo-move-diagram-coupled .memo-move-cell-0,
  .memo-move-diagram-coupled .memo-move-cell-4,
  .memo-move-diagram-coupled .memo-move-cell-8 {
    background: rgba(105, 82, 151, 0.14);
    border-color: rgba(105, 82, 151, 0.24);
  }
  .memo-scope-card span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.55rem;
    height: 1.55rem;
    border-radius: 999px;
    background: rgba(47, 107, 111, 0.12);
    color: var(--fg);
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 700;
  }
  @media (max-width: 760px) {
    .memo-move-grid,
    .memo-scope-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
