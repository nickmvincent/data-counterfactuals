---
import { courseModules } from "../lib/learning-content.js";

interface Props {
  currentId: string;
  compact?: boolean;
}

const { currentId, compact = false } = Astro.props;
const currentIndex = courseModules.findIndex((module) => module.id === currentId);

if (currentIndex < 0) {
  throw new Error(`Unknown course module '${currentId}'.`);
}

const current = courseModules[currentIndex];
const previous = courseModules[currentIndex - 1];
const next = courseModules[currentIndex + 1];
---

<aside class:list={["course-nav", { "course-nav-compact": compact }]} aria-label={`Course navigation for ${current.title}`}>
  <div class="course-nav-head">
    <p class="course-nav-kicker">Module {current.id} of {courseModules.length} · {current.time}</p>
    {compact
      ? <h3>{next ? "Continue the course" : "Complete the course"}</h3>
      : <h2>{next ? "Continue the course" : "Complete the course"}</h2>}
    <p>{current.exercise}</p>
  </div>

  <nav class="course-nav-actions" aria-label="Previous and next course modules">
    {previous
      ? <a class="btn ghost" href={previous.href}>← {previous.title}</a>
      : <a class="btn ghost" href="/learn">← Course map</a>}
    <a class="course-nav-map" href="/learn">Course map</a>
    {next
      ? <a class="btn" href={next.href}>{next.title} →</a>
      : <a class="btn" href="/learn#course-complete">Review the six modules →</a>}
  </nav>
</aside>

<style>
  .course-nav {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.2rem 2rem;
    align-items: end;
    padding: 1.1rem 0;
    border-top: 1px solid var(--border-strong);
    border-bottom: 1px solid var(--border);
  }
  .course-nav-head {
    display: grid;
    gap: 0.42rem;
    max-width: 43rem;
  }
  .course-nav-kicker {
    margin: 0;
    color: var(--ring-thin);
    font: 700 0.76rem/1.4 var(--font-ui);
    letter-spacing: 0.055em;
    text-transform: uppercase;
  }
  .course-nav h2,
  .course-nav h3 {
    margin: 0;
    font-family: var(--font-display);
    line-height: 1.08;
  }
  .course-nav h2 { font-size: clamp(1.55rem, 2.5vw, 2.2rem); }
  .course-nav h3 { font-size: clamp(1.25rem, 2vw, 1.65rem); }
  .course-nav-head > p:last-child {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }
  .course-nav-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.65rem;
    align-items: center;
  }
  .course-nav-map {
    color: var(--muted);
    font: 650 0.82rem/1.4 var(--font-ui);
  }
  .course-nav-compact {
    grid-template-columns: 1fr;
    margin-top: 0.3rem;
    padding: 0.9rem;
    border: 1px solid rgba(47, 107, 111, 0.2);
    background: rgba(47, 107, 111, 0.045);
  }
  .course-nav-compact .course-nav-actions {
    justify-content: flex-start;
  }
  .course-nav-compact :global(.btn) {
    min-height: 2.5rem;
    padding: 0.62rem 0.82rem;
    font-size: 0.82rem;
  }
  @media (max-width: 760px) {
    .course-nav { grid-template-columns: 1fr; }
    .course-nav-actions { justify-content: flex-start; }
  }
</style>
