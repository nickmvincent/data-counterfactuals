---
interface BoardCell {
  colId: string;
  value: string;
  tone?: string;
}

interface BoardRow {
  id: string;
  label: string;
  cells: BoardCell[];
}

interface BoardMark {
  variant?: string;
  row: string;
  col: string;
  tone?: string;
}

interface BoardColumn {
  id: string;
  label: string;
}

interface Props {
  ariaLabel: string;
  rows: BoardRow[];
  columns: BoardColumn[];
  caption?: string;
  variant?: string;
  highlights?: BoardMark[];
  baselines?: BoardMark[];
  minWidth?: string;
  labelWidth?: string;
  columnMin?: string;
}

const {
  ariaLabel,
  rows,
  columns,
  caption,
  variant = "",
  highlights = [],
  baselines = [],
  minWidth = "25rem",
  labelWidth = "6.5rem",
  columnMin = "4.4rem",
} = Astro.props;

function matchesMark(mark: BoardMark, rowId: string, colId: string) {
  return (!mark.variant || mark.variant === variant) && mark.row === rowId && mark.col === colId;
}

function cellTone(row: BoardRow, cell: BoardCell) {
  const highlight = highlights.find((mark) => matchesMark(mark, row.id, cell.colId));
  if (highlight) return highlight.tone || "warm";
  const baseline = baselines.find((mark) => matchesMark(mark, row.id, cell.colId));
  if (baseline) return baseline.tone || "base";
  return cell.tone || "default";
}

const boardTemplate = `${labelWidth} repeat(${columns.length}, minmax(${columnMin}, 1fr))`;
const boardStyle = `--board-min-width: ${minWidth}; --board-template: ${boardTemplate};`;
---

<figure class="counterfactual-board-figure" aria-label={ariaLabel}>
  <div class="counterfactual-board" data-variant={variant} style={boardStyle}>
    <div class="counterfactual-board-row" aria-hidden="true">
      <div class="counterfactual-board-label"></div>
      {columns.map((column) => (
        <div class="counterfactual-board-label">{column.label}</div>
      ))}
    </div>
    {rows.map((row) => (
      <div class="counterfactual-board-row" data-row={row.id}>
        <div class="counterfactual-board-label">{row.label}</div>
        {row.cells.map((cell) => (
          <div
            class="counterfactual-board-cell"
            data-col={cell.colId}
            data-tone={cellTone(row, cell)}
          >
            {cell.value}
          </div>
        ))}
      </div>
    ))}
  </div>
  {caption && <figcaption class="counterfactual-board-caption">{caption}</figcaption>}
</figure>

<style>
  .counterfactual-board-figure {
    margin: 0;
    display: grid;
    gap: 0.7rem;
    min-width: 0;
  }

  .counterfactual-board {
    display: grid;
    gap: 2px;
    overflow-x: auto;
    padding-bottom: 0.15rem;
  }

  .counterfactual-board-row {
    min-width: var(--board-min-width);
    display: grid;
    grid-template-columns: var(--board-template);
    gap: 2px;
  }

  .counterfactual-board-cell,
  .counterfactual-board-label {
    min-height: 2.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.48rem;
    border: 1px solid rgba(92, 72, 52, 0.12);
    background: rgba(255, 250, 243, 0.58);
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.82rem;
    line-height: 1.2;
    font-weight: 650;
  }

  .counterfactual-board-cell {
    color: #203032;
    background: rgba(47, 107, 111, 0.08);
  }

  .counterfactual-board-label {
    justify-content: flex-start;
  }

  .counterfactual-board-cell[data-tone="base"] {
    background: rgba(47, 107, 111, 0.13);
  }

  .counterfactual-board-cell[data-tone="warm"] {
    border-color: rgba(177, 79, 31, 0.28);
    background: rgba(177, 79, 31, 0.12);
    color: var(--fg);
  }

  .counterfactual-board-cell[data-tone="bright"] {
    background: rgba(95, 132, 91, 0.14);
  }

  .counterfactual-board-caption {
    margin: 0;
    max-width: var(--measure);
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.9rem;
    line-height: 1.62;
  }
</style>
