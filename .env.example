# Optional local overrides for the public Semble defaults in `semble.config.json`.
# Copy to `.env.local` if you need to point the site at a different profile or
# force a different cache policy on your machine.

SEMBLE_PROFILE_IDENTIFIER=
SEMBLE_COLLECTION_AT_URIS=
SEMBLE_COLLECTION_NAME_PREFIX=
SEMBLE_API_BASE=https://api.semble.so
SEMBLE_CACHE_PATH=tmp/semble-cache.json
SEMBLE_CACHE_POLICY=network-first

# Optional credentials for `npm run semble:manage -- ...`
# If your login handle matches the public profile above, you can leave
# SEMBLE_LOGIN_IDENTIFIER empty and reuse SEMBLE_PROFILE_IDENTIFIER.
SEMBLE_LOGIN_IDENTIFIER=
SEMBLE_APP_PASSWORD=
SEMBLE_PDS_SERVICE=https://bsky.social
SEMBLE_PDS_ENV=
